---

<Layout title="Contact" description="Contact Chirag Singhal">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <div class="absolute top-0 right-0 w-80 h-80 bg-teal-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Back link -->
    <a href="/connect" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-teal-400 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Connect
    </a>

    <!-- Header -->
    <div class="mb-10 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CONNECT
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Contact</h1>
      <p class="text-lg text-white/40 max-w-2xl">Get in touch directly — I'd love to hear from you.</p>
    </div>

    <!-- Email Hero Card -->
    <a href="mailto:hi@chirag127.in" class="glass-strong p-8 mb-8 reveal group flex items-center gap-6 relative overflow-hidden hover:border-teal-500/30 transition-colors">
      <div class="absolute top-0 right-0 w-48 h-48 bg-teal-500/5 rounded-full blur-[80px] pointer-events-none group-hover:bg-teal-500/10 transition-colors"></div>
      <div class="h-16 w-16 rounded-2xl bg-teal-500/10 flex items-center justify-center flex-shrink-0 group-hover:bg-teal-500/20 transition-colors">
        <svg class="h-8 w-8 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </div>
      <div class="min-w-0 flex-1">
        <h2 class="text-2xl font-bold text-white group-hover:text-teal-400 transition-colors mb-1">Email</h2>
        <p class="text-lg text-white/50">hi@chirag127.in</p>
      </div>
      <svg class="h-6 w-6 text-white/20 flex-shrink-0 group-hover:text-teal-400 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
    </a>

    <!-- Contact Details -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 reveal">
      <div class="glass p-6">
        <div class="flex items-center gap-3 mb-3">
          <svg class="h-5 w-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          <h3 class="text-sm font-semibold text-white/60">Phone</h3>
        </div>
        <a href="tel:+917428449707" class="text-lg text-white/80 hover:text-teal-400 transition-colors">+91 74284-49707</a>
      </div>
      <div class="glass p-6">
        <div class="flex items-center gap-3 mb-3">
          <svg class="h-5 w-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <h3 class="text-sm font-semibold text-white/60">Location</h3>
        </div>
        <p class="text-lg text-white/80">Bhubaneswar, Odisha, India</p>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="reveal">
      <h2 class="text-sm font-semibold text-white/50 uppercase tracking-widest mb-5">Find Me On</h2>
      <div class="space-y-3">
        {contactLinks.filter(l => l.name !== 'Email').map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="glass p-5 group flex items-center gap-4 hover:border-white/10 transition-colors">
            <div class="h-11 w-11 rounded-xl flex items-center justify-center flex-shrink-0 transition-colors" style={`background: ${link.color}15;`}>
              <svg class="h-5 w-5" style={`color: ${link.color}`} fill="currentColor" viewBox="0 0 24 24">
                <path d={iconPaths[link.icon] || ''} />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-semibold text-white group-hover:text-teal-400 transition-colors">{link.name}</h3>
              <p class="text-xs text-white/35 truncate">{link.username}</p>
            </div>
            <svg class="h-4 w-4 text-white/15 flex-shrink-0 group-hover:text-teal-400 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
