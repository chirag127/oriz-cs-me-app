---
/*
 * /status — survival/freshness page (v2 datasheet).
 *
 * Per the ingester contract (knowledge/decisions/ingester-contract.md):
 *   - mono-caps source name, fixed-width left column
 *   - 8-day rolling sparkline (one ●/○ per day, oldest → newest)
 *   - relative last-sync time
 *   - last error truncated to 80 chars
 *
 * Data source: Turso warm-cache `sources` + `events` tables. If Turso is
 * unreachable (no env, no DB yet), the page renders a fallback panel
 * pointing readers at the canonical JSONL repo. This page MUST NOT 500
 * — that would defeat the purpose of a survival page.
 */

import Layout from '../layouts/Layout.astro';

interface SourceRow {
  name: string;
  last_synced_at: string | null;
  last_error: string | null;
}

const LOOKBACK_DAYS = 8;

let sources: SourceRow[] = [];
const countsBySource: Map<string, Map<string, number>> = new Map();
let cacheAvailable = true;
let cacheError: string | null = null;

try {
  const { getReadClient } = await import('../lib/lifestream/db.ts');
  const client = getReadClient();

  const sourcesResult = await client.execute(
    'SELECT name, last_synced_at, last_error FROM sources ORDER BY name',
  );
  sources = sourcesResult.rows.map((r) => ({
    name: String(r.name ?? ''),
    last_synced_at: r.last_synced_at == null ? null : String(r.last_synced_at),
    last_error: r.last_error == null ? null : String(r.last_error),
  }));

  const sinceIso = new Date(
    Date.now() - LOOKBACK_DAYS * 24 * 3600 * 1000,
  ).toISOString();
  const countsResult = await client.execute({
    sql: `
      SELECT source,
             date(occurred_at) AS day,
             COUNT(*) AS n
      FROM events
      WHERE occurred_at >= ?
      GROUP BY source, day
    `,
    args: [sinceIso],
  });
  for (const row of countsResult.rows) {
    const source = String(row.source ?? '');
    const day = String(row.day ?? '');
    const n = Number(row.n ?? 0);
    if (!source || !day) continue;
    let inner = countsBySource.get(source);
    if (!inner) {
      inner = new Map();
      countsBySource.set(source, inner);
    }
    inner.set(day, n);
  }
} catch (err) {
  cacheAvailable = false;
  cacheError = err instanceof Error ? err.message : String(err);
}

function buildDayAxis(days: number): string[] {
  const out: string[] = [];
  const today = new Date();
  for (let i = days - 1; i >= 0; i -= 1) {
    const d = new Date(today);
    d.setUTCDate(d.getUTCDate() - i);
    out.push(d.toISOString().slice(0, 10));
  }
  return out;
}

function truncate(s: string, n = 80): string {
  if (s.length <= n) return s;
  return `${s.slice(0, n - 1)}…`;
}

function relativeTime(iso: string | null): string {
  if (!iso) return 'never';
  const t = new Date(iso).getTime();
  if (Number.isNaN(t)) return 'unknown';
  const diff = Date.now() - t;
  if (diff < 0) return 'just now';
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo ago`;
  const years = Math.floor(days / 365);
  return `${years}y ago`;
}

const dayAxis = buildDayAxis(LOOKBACK_DAYS);
---

<Layout
  title="Status"
  description="Lifestream ingester health — per-source last sync, last error, 8-day activity sparkline. Honest about what's broken."
  breadcrumb="STATUS"
  provenanceSection="/status"
  provenanceApis="turso · github"
>
  <div class="spine">
    <header class="page-head">
      <h1>Status</h1>
      <p class="lede">
        Per-source ingester health. Filled dot = events landed that day,
        hollow = silent. After 7 consecutive silent days an ingester
        auto-pauses per the contract. The rest of the site keeps working
        regardless — this page is the public truth check.
      </p>
    </header>
    <div class="page-counts">
      {sources.length} sources · 8-day rolling window · cache {cacheAvailable ? 'live' : 'unreachable'}
    </div>

    {!cacheAvailable && (
      <section class="band band-fallback">
        <p class="eyebrow band-eyebrow">CACHE NOT CONFIGURED</p>
        <p class="band-note">
          The Turso warm-cache isn&apos;t reachable from this build, so live
          per-source status can&apos;t render. The canonical archive is
          unaffected — it&apos;s plain JSONL in a separate public repo. See
          <a href="https://github.com/chirag127/oriz-me-data" target="_blank" rel="noopener noreferrer">chirag127/oriz-me-data</a>
          for the canonical lifestream archive, or
          <a href="https://github.com/chirag127/oriz-me/blob/main/scripts/README-data-repo.md" target="_blank" rel="noopener noreferrer">scripts/README-data-repo.md</a>
          for the recovery contract.
        </p>
        {cacheError && (
          <p class="cache-error mono">error: {truncate(cacheError, 200)}</p>
        )}
      </section>
    )}

    {cacheAvailable && sources.length === 0 && (
      <section class="band">
        <p class="eyebrow band-eyebrow">NO SOURCES YET</p>
        <p class="band-note">
          No sources have reported sync status yet. Run an ingester to populate
          this page.
        </p>
      </section>
    )}

    {cacheAvailable && sources.length > 0 && (
      <section class="band">
        <p class="eyebrow band-eyebrow">SOURCES — {sources.length}</p>
        <div class="status-rows">
          {sources.map((src) => {
            const dayCounts = countsBySource.get(src.name) ?? new Map();
            const isHealthy =
              !src.last_error &&
              src.last_synced_at !== null &&
              Date.now() - new Date(src.last_synced_at).getTime() <
                7 * 24 * 3600 * 1000;
            return (
              <div class="status-row mono" data-status={isHealthy ? 'good' : 'bad'}>
                <span class="status-name">{src.name.toUpperCase()}</span>
                <span class="status-spark" aria-label="8-day sparkline">
                  {dayAxis.map((day) => {
                    const n = dayCounts.get(day) ?? 0;
                    const ok = n > 0;
                    return (
                      <span
                        class="spark-dot"
                        data-ok={String(ok)}
                        title={`${day}: ${n} event${n === 1 ? '' : 's'}`}
                      >
                        {ok ? '●' : '○'}
                      </span>
                    );
                  })}
                </span>
                <span class="status-time">
                  synced {relativeTime(src.last_synced_at)}
                </span>
                <span class="status-error">
                  {src.last_error ? truncate(src.last_error) : '—'}
                </span>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">CANONICAL FALLBACK</p>
      <p class="band-note">
        Canonical lifestream archive:
        <a href="https://github.com/chirag127/oriz-me-data" target="_blank" rel="noopener noreferrer">chirag127/oriz-me-data</a>.
        Rendered HTML mirror:
        <a href="https://chirag127.github.io/oriz-me/" target="_blank" rel="noopener noreferrer">chirag127.github.io/oriz-me</a>.
        If this page is wrong, both fallbacks still work.
      </p>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/system/">/system</a>
      <span aria-hidden="true">·</span>
      <a href="/system/changelog/">/system/changelog</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .band-note {
    margin: 0;
    color: var(--ink);
    line-height: 1.6;
    font-size: 0.9375rem;
    max-width: 64ch;
  }
  .band-note a {
    color: var(--archival);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .band-fallback .band-note {
    color: var(--ink);
  }
  .cache-error {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-soft);
    word-break: break-all;
  }
  .status-rows {
    display: flex;
    flex-direction: column;
  }
  .status-row {
    display: grid;
    grid-template-columns: 8rem auto 8rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    border-bottom: 1px solid color-mix(in oklab, var(--rule) 50%, transparent);
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .status-row:last-child { border-bottom: 0; }
  .status-name {
    letter-spacing: 0.06em;
    color: var(--ink);
    font-weight: 500;
  }
  .status-spark {
    display: inline-flex;
    gap: 0.18rem;
    line-height: 1;
    font-size: 0.875rem;
  }
  .spark-dot[data-ok="true"] { color: var(--status-good); }
  .spark-dot[data-ok="false"] { color: var(--rule); }
  .status-time { color: var(--ink-soft); }
  .status-error { color: var(--ink-soft); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .status-row[data-status="bad"] .status-name { color: var(--status-bad); }
  .status-row[data-status="bad"] .status-error { color: var(--status-bad); }

  @media (max-width: 720px) {
    .status-row {
      grid-template-columns: 1fr;
      gap: 0.125rem;
      padding-block: 0.625rem;
    }
  }
</style>
