---
import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { hackernews: null };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/social.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[HackerNews] social.json not found.');
}

const hnStats = db.hackernews;
---

<Layout title="HackerNews" description="Chirag Singhal on HackerNews">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <div class="absolute top-0 right-0 w-80 h-80 bg-orange-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Back link -->
    <a href="/connect" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-teal-400 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Connect
    </a>

    <!-- Header -->
    <div class="mb-10 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CONNECT
      </div>
      <div class="flex items-center gap-3 mb-3">
        <div class="h-10 w-10 rounded-xl bg-orange-500/10 flex items-center justify-center">
          <span class="text-xl font-bold text-orange-500">Y</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">HackerNews</h1>
      </div>
      <p class="text-lg text-white/40">My HackerNews profile — {CONFIG.user.hackernews}.</p>
    </div>

    <!-- Profile Hero + Stats -->
    <div class="glass-strong p-8 mb-10 reveal">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-orange-500/20 flex items-center justify-center flex-shrink-0">
          <span class="text-3xl font-bold text-orange-500">Y</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">{CONFIG.user.hackernews}</h2>
          <p class="text-sm text-white/40">HackerNews contributor</p>
        </div>
      </div>

      {hnStats ? (
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center p-4 rounded-lg bg-white/[0.02]">
            <div class="text-2xl font-bold text-orange-500">{hnStats.karma?.toLocaleString()}</div>
            <div class="text-xs text-white/35">Karma</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-white/[0.02]">
            <div class="text-2xl font-bold text-white">{hnStats.submittedCount}</div>
            <div class="text-xs text-white/35">Submissions</div>
          </div>
        </div>
      ) : (
        <div class="text-center py-8">
          <p class="text-white/35">HackerNews data not available. Run fetch-data first.</p>
        </div>
      )}
    </div>

    <!-- About -->
    <div class="glass p-8 mb-10 reveal">
      <h2 class="text-xl font-bold text-white mb-4">About HackerNews</h2>
      <p class="text-sm text-white/40 leading-relaxed">
        HackerNews is a social news website focusing on computer science and entrepreneurship.
        It's run by Y Combinator and is a hub for the tech community.
      </p>
    </div>

    <!-- External Link -->
    <div class="glass p-6 text-center reveal">
      <a href={`https://news.ycombinator.com/user?id=${CONFIG.user.hackernews}`} target="_blank" rel="noopener noreferrer" class="text-sm text-orange-400 hover:text-orange-300 hover:underline">View on HackerNews &rarr;</a>
    </div>
  </main>
</Layout>
