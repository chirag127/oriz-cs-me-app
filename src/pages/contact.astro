---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<BaseLayout
	title="Contact — Chirag Singhal"
	description="How to get in touch with Chirag Singhal."
>
	<div class="page">
		<aside><Sidebar /></aside>
		<section>
			<h1>Contact</h1>
			<p>
				Email: <a href="mailto:chirag@oriz.in">chirag@oriz.in</a>
			</p>
			<p>
				GitHub:
				<a href="https://github.com/chirag127" rel="noopener">@chirag127</a>
			</p>
			<p><em>Stub. More channels coming.</em></p>
		</section>
	</div>
</BaseLayout>

<style>
	.page {
		max-width: 70rem;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: 3rem;
	}
	@media (max-width: 720px) {
		.page { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 1rem; }
	}
	h1 { font-size: 2rem; margin: 0 0 1rem; letter-spacing: -0.01em; }
</style>
