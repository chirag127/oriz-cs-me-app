---
import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { bluesky: null };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/social.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Bluesky] social.json not found.');
}

const bluesky = db.bluesky;
const posts = bluesky?.posts || [];
---

<Layout title="Bluesky" description="Chirag Singhal on Bluesky">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <div class="absolute top-0 right-0 w-80 h-80 bg-sky-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Back link -->
    <a href="/connect" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-teal-400 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Connect
    </a>

    <!-- Header -->
    <div class="mb-10 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CONNECT
      </div>
      <div class="flex items-center gap-3 mb-3">
        <div class="h-10 w-10 rounded-xl bg-sky-500/10 flex items-center justify-center">
          <span class="text-xl">&#x1F98B;</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Bluesky</h1>
      </div>
      <p class="text-lg text-white/40">{CONFIG.user.bluesky} — thoughts and updates.</p>
    </div>

    <!-- Profile Hero -->
    <div class="glass-strong p-8 mb-10 reveal">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-sky-500/20 flex items-center justify-center flex-shrink-0">
          <span class="text-3xl">&#x1F98B;</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">{CONFIG.user.bluesky}</h2>
          <p class="text-sm text-white/40">@{CONFIG.user.bluesky}</p>
        </div>
      </div>
      <p class="text-sm text-white/40 leading-relaxed">Posts on Bluesky — the decentralized social network.</p>
    </div>

    <!-- Recent Posts -->
    <h2 class="text-xl font-semibold text-white mb-6 reveal">Recent Posts</h2>
    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map((post: any) => (
          <a href={post.uri} target="_blank" rel="noopener noreferrer" class="glass p-5 block hover:border-white/10 transition-colors group reveal">
            <p class="text-sm text-white/90 mb-3 leading-relaxed">{post.text}</p>
            <div class="flex items-center gap-4 text-xs text-white/35">
              <span>{new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>&#x2764;&#xFE0F; {post.likeCount}</span>
              <span>&#x1F501; {post.repostCount}</span>
              <span>&#x1F4AC; {post.replyCount}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center reveal">
        <p class="text-white/35">No Bluesky posts found. Run fetch-data first.</p>
      </div>
    )}

    <!-- External Link -->
    <div class="mt-10 glass p-6 text-center reveal">
      <a href={`https://bsky.app/profile/${CONFIG.user.bluesky}`} target="_blank" rel="noopener noreferrer" class="text-sm text-sky-400 hover:text-sky-300 hover:underline">View on Bluesky &rarr;</a>
    </div>
  </main>
</Layout>
