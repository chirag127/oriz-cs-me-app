---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import { skills } from '../../content';

const totalSkills = skills.reduce((sum, s) => sum + s.items.length, 0);
---

<Layout title="Skills" description="Technical skills of Chirag Singhal — filterable by category">
  <CommandPalette />
  <main class="relative mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <div class="absolute top-0 right-0 w-96 h-96 bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Work</a>

    <!-- Page Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        SKILLS
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">Skills</h1>
      <p class="text-base text-white/40">{totalSkills} skills across {skills.length} domains — click a category to filter</p>
    </div>

    <!-- Filter Buttons -->
    <div id="skill-filters" class="flex flex-wrap gap-2 mb-8 reveal">
      <button class="skill-filter active px-4 py-2 text-sm rounded-lg bg-teal-500 text-[#0a0a0f] font-semibold transition-all" data-category="all" type="button">All ({totalSkills})</button>
      {skills.map((s) => (
        <button class="skill-filter px-4 py-2 text-sm rounded-lg bg-white/[0.015] text-white/60 hover:bg-white/[0.025] hover:text-white/80 border border-white/5 transition-all" data-category={s.category} type="button">{s.category} ({s.items.length})</button>
      ))}
    </div>

    <!-- Skills Grid -->
    <div id="skills-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
      {skills.map((category) => (
        <div class="glass p-6 skill-card" data-category={category.category}>
          <h3 class="text-sm font-semibold text-teal-400 mb-4 uppercase tracking-wider">{category.category}</h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map((skill) => (
              <span class="px-3 py-1.5 text-xs rounded-lg bg-white/5 text-white/70 border border-white/5 hover:border-teal-500/20 hover:text-white/90 transition-all cursor-default">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Skill Distribution -->
    <div class="glass p-8 mt-12 reveal">
      <h2 class="text-lg font-bold text-white mb-6">Skill Distribution</h2>
      <div class="space-y-4">
        {skills.map((s) => {
          const pct = Math.round((s.items.length / totalSkills) * 100);
          return (
            <div>
              <div class="flex items-center justify-between text-sm mb-1.5">
                <span class="text-white/60">{s.category}</span>
                <span class="text-white/40">{s.items.length} skills</span>
              </div>
              <div class="h-2 rounded-full bg-white/5 overflow-hidden">
                <div class="h-full rounded-full bg-gradient-to-r from-teal-500 to-teal-400" style={`width: ${pct}%`}></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </main>
  <script is:inline>
    document.querySelectorAll('.skill-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;
        document.querySelectorAll('.skill-filter').forEach(b => {
          b.classList.remove('bg-teal-500', 'text-[#0a0a0f]', 'font-semibold');
          b.classList.add('bg-white/[0.015]', 'text-white/60');
        });
        btn.classList.add('bg-teal-500', 'text-[#0a0a0f]', 'font-semibold');
        btn.classList.remove('bg-white/[0.015]', 'text-white/60');
        document.querySelectorAll('.skill-card').forEach(card => {
          card.style.display = (cat === 'all' || card.dataset.category === cat) ? 'block' : 'none';
        });
      });
    });
  </script>
</Layout>
