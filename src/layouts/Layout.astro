---
/*
 * Layout — v2 datasheet white chrome.
 *
 * Single source of truth for every page on me.oriz.in. Provides:
 *   1. Header (56px, oriz / me wordmark, ⌘K, sign in, theme toggle)
 *   2. Provenance strip (the signature element, with the 4px sync dot)
 *   3. Slot
 *   4. Footer (two-line mono colophon)
 *
 * Per the v2 brief: NO sidebar, NO mega-header, NO mode-switching chrome.
 * NO ambient gradient body, NO glass, NO blur, NO animated reveals.
 *
 * Imports the trimmed CommandPalette so ⌘K works on every page.
 */

import '../styles/global.css';
import '../styles/oriz-ui-overrides.css';
import CommandPalette from '../components/CommandPalette.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ProvenanceStrip from '../components/ProvenanceStrip.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Hide the provenance strip (e.g. on /404 if needed). */
  hideProvenance?: boolean;
  /** Override the right-half tail of the provenance strip with a comma list of APIs. */
  provenanceApis?: string;
  /** Pin the section name on the provenance strip. e.g. '/library'. */
  provenanceSection?: string;
  /** Mono-caps breadcrumb shown right of the wordmark. e.g. 'LIBRARY · FILMS'. */
  breadcrumb?: string;
  /** Override deploy build APIs count. Defaults to 41 per the brief. */
  apiCount?: number | string;
  /** Legacy compatibility — currently unused; absence is the default. */
  fullWidth?: boolean;
}

const {
  title,
  description = 'Chirag Singhal — daily-rebuilt digital identity datasheet. ' +
    'Every datum bears the timestamp it was scraped, every list ' +
    'bears the API it came from.',
  ogImage,
  hideProvenance = false,
  provenanceApis,
  provenanceSection,
  breadcrumb,
  apiCount,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://me.oriz.in');

const pathname = Astro.url.pathname;
const slug =
  pathname === '/'
    ? 'home'
    : pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-');
const resolvedOgImage = ogImage || `/og/${slug}.png`;
const ogImageAbsolute = new URL(resolvedOgImage, Astro.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0f14" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={`Chirag Singhal — ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageAbsolute} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`Chirag Singhal — ${title}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts — IBM Plex Sans Condensed (display), Plex Sans (body),
         JetBrains Mono (utility/data). Per v2 brief these are the only
         allowed faces; Outfit + Inter are explicitly forbidden. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+Condensed:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Chirag Singhal',
        url: 'https://me.oriz.in',
        email: 'hi@chirag127.in',
        jobTitle: 'Software Engineer & AI Specialist',
        worksFor: {
          '@type': 'Organization',
          name: 'Tata Consultancy Services',
        },
        sameAs: [
          'https://github.com/chirag127',
          'https://linkedin.com/in/chirag127',
          'https://dev.to/chirag127',
          'https://bsky.app/profile/chirag127.bsky.social',
        ],
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Bhubaneswar',
          addressRegion: 'Odisha',
          addressCountry: 'India',
        },
      })}
    />

    <title>Chirag Singhal — {title}</title>

    <!-- Per-page head injection (e.g. AgeGatedLayout adds rating + noindex). -->
    <slot name="head" />

    <!-- FOUC theme paint — read explicit override before first paint. The
         v2 site only swaps light/dark; no accent system. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('oriz-me:theme');
          if (saved === 'dark' || saved === 'light') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (_) { /* localStorage may be disabled */ }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header {...(breadcrumb !== undefined ? { breadcrumb } : {})} />
    {!hideProvenance && (
      <ProvenanceStrip
        {...(provenanceApis !== undefined ? { apis: provenanceApis } : {})}
        {...(provenanceSection !== undefined ? { section: provenanceSection } : {})}
      />
    )}

    <main id="main-content" role="main">
      <slot />
    </main>

    <Footer {...(apiCount !== undefined ? { apiCount } : {})} />

    <CommandPalette />
  </body>
</html>

<style is:global>
  /* Datasheet white surface — flat, no gradient, no scroll behavior tricks. */
  html { scroll-behavior: smooth; }
  body { background: var(--paper); color: var(--ink); }

  /* Dark variant explicit attribute override (toggle button writes this). */
  html[data-theme="dark"] {
    --paper: #0b0f14;
    --ink: #e8ecef;
    --ink-soft: #8a95a3;
    --rule: #2a3441;
    --archival: #6ca8e8;
    --archival-wash: #16243a;
    color-scheme: dark;
  }
  html[data-theme="light"] {
    --paper: #fafbfc;
    --ink: #0e1318;
    --ink-soft: #5a6470;
    --rule: #c8cfd6;
    --archival: #0b5394;
    --archival-wash: #e6edf6;
    color-scheme: light;
  }
</style>
