---
/*
 * /code — code activity landing (v2 datasheet).
 *
 * Per the brief: GitHub stats appear here as plain mono tables, NOT as a
 * contribution heatmap. Repos sorted by stars; npm packages and
 * stackoverflow rep also surface as ranked rows.
 */

import Layout from '../../layouts/Layout.astro';
import {
  fetchGitHubRepos,
  fetchGitHubUser,
  fetchLeetCodeStats,
} from '../../lib/api/index';

const [user, repos, leetcode] = await Promise.all([
  fetchGitHubUser().catch(() => null),
  fetchGitHubRepos().catch(
    () => [] as Awaited<ReturnType<typeof fetchGitHubRepos>>,
  ),
  fetchLeetCodeStats().catch(() => null),
]);

interface Repo {
  name?: string;
  full_name?: string;
  html_url?: string;
  stargazers_count?: number;
  language?: string | null;
  description?: string | null;
  pushed_at?: string;
}

const sortedRepos: Repo[] = [...((repos as Repo[]) ?? [])]
  .sort((a, b) => (b.stargazers_count ?? 0) - (a.stargazers_count ?? 0))
  .slice(0, 12);

const totalStars = ((repos as Repo[]) ?? []).reduce(
  (s: number, r: Repo) => s + (r.stargazers_count ?? 0),
  0,
);
---

<Layout
  title="Code"
  description="GitHub repos, npm packages, LeetCode, StackOverflow — daily-synced activity."
  breadcrumb="CODE"
  provenanceSection="/code"
  provenanceApis="github · npm · leetcode · stackoverflow · holopin"
>
  <div class="spine">
    <header class="page-head">
      <h1>Code</h1>
      <p class="lede">
        Open-source repos, package downloads, problem-solving stats. The
        public ledger — every PR, star, package install since 2022.
      </p>
    </header>
    <div class="page-counts">
      {repos?.length ?? 0} repos · {totalStars}+ stars · {leetcode?.totalSolved ?? '500+'} solved · {user?.followers ?? 0} followers
    </div>

    <!-- Top repos -->
    <section class="band">
      <p class="eyebrow band-eyebrow">REPOS — RANKED BY ⋆</p>
      <table class="ranked-table">
        <thead>
          <tr>
            <th class="rank">#</th>
            <th>repo</th>
            <th>language</th>
            <th class="right">stars</th>
          </tr>
        </thead>
        <tbody>
          {sortedRepos.map((repo, i) => {
            const rank = String(i + 1).padStart(2, '0');
            return (
              <tr>
                <td class="rank">{rank}</td>
                <td>
                  <a
                    href={repo.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {repo.name}
                  </a>
                </td>
                <td>{repo.language ?? '—'}</td>
                <td class="right">{repo.stargazers_count ?? 0}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <p class="band-trail mono">
        <a href="/code/repos/">all repos &rarr;</a>
      </p>
    </section>

    <hr class="hairline" />

    <!-- Sub-pages -->
    <section class="band">
      <p class="eyebrow band-eyebrow">SUB-PAGES</p>
      <div class="me-rows">
        <a class="leader-row me-link" href="/code/repos/">
          <span class="leader-name">/code/repos</span>
          <span class="leader-fill">github repositories — full list</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/code/npm/">
          <span class="leader-name">/code/npm</span>
          <span class="leader-fill">published packages + downloads</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/code/stackoverflow/">
          <span class="leader-name">/code/stackoverflow</span>
          <span class="leader-fill">reputation, top answers</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/code/holopin/">
          <span class="leader-name">/code/holopin</span>
          <span class="leader-fill">open-source contribution badges</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
      </div>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/me/">/me</a>
      <span aria-hidden="true">·</span>
      <a href="/work/">/work</a>
      <span aria-hidden="true">·</span>
      <a href="/library/">/library</a>
      <span aria-hidden="true">·</span>
      <a href="/gaming/">/gaming</a>
      <span aria-hidden="true">·</span>
      <a href="/connect/">/connect</a>
      <span aria-hidden="true">·</span>
      <a href="/system/">/system</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .me-rows { display: flex; flex-direction: column; }
  .me-link:hover .leader-name,
  .me-link:hover .leader-fill,
  .me-link:hover .leader-time { color: var(--archival); }
  .me-link:hover { background: var(--archival-wash); }
  .ranked-table a {
    color: var(--archival);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .ranked-table a:hover { text-decoration-color: var(--archival); }
  .band-trail {
    margin: 1rem 0 0;
    font-size: 0.8125rem;
    color: var(--ink-soft);
  }
  .band-trail a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .band-trail a:hover {
    color: var(--archival);
    text-decoration-color: var(--archival);
  }
</style>
