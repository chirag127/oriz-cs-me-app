---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ThemeSwitcher from '../../components/islands/ThemeSwitcher';

---

<Layout title="System Drive" description="Settings, changelog, and system configuration">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Header -->
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--primary-muted)] border border-[var(--primary-subtle)] text-xs text-[var(--primary-lighter)] mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--primary-light)] animate-pulse"></span>
        SYSTEM Drive
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">System Settings</h1>
      <p class="text-lg text-white/40 max-w-2xl">Settings, changelog, and configuration</p>
    </div>

    <!-- Settings Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Theme Card -->
      <div class="glass p-6">
        <div class="h-12 w-12 rounded-xl bg-teal-500/10 flex items-center justify-center mb-4">
          <svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-white mb-4" style="font-family: 'Outfit', sans-serif;">Appearance</h2>
        <ThemeSwitcher client:load />
      </div>

      <!-- Changelog Card -->
      <a href="/system/changelog" class="glass p-6 group hover:border-teal-500/20 transition-colors block">
        <div class="h-12 w-12 rounded-xl bg-teal-500/10 flex items-center justify-center mb-4">
          <svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-white mb-2 group-hover:text-teal-400 transition-colors" style="font-family: 'Outfit', sans-serif;">Changelog</h2>
        <p class="text-sm text-white/40">Version history and updates</p>
      </a>

      <!-- Admin Panel Card -->
      <a href="/system/admin" class="glass p-6 group hover:border-violet-500/20 transition-colors block">
        <div class="h-12 w-12 rounded-xl bg-violet-500/10 flex items-center justify-center mb-4">
          <svg class="h-6 w-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-white mb-2 group-hover:text-violet-400 transition-colors" style="font-family: 'Outfit', sans-serif;">Admin Panel</h2>
        <p class="text-sm text-white/40">Chat history management (admin only)</p>
      </a>
    </div>
  </main>
</Layout>
