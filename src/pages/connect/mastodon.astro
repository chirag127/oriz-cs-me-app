---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { account: null, statuses: [] };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/mastodon.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Mastodon] mastodon.json not found.');
}

const account = db.account;
const statuses = db.statuses || [];

function _stripHtml(html: string) {
  return html?.replace(/<[^>]*>/g, '') || '';
}
---

<Layout title="Mastodon" description="Chirag Singhal on Mastodon">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <div class="absolute top-0 right-0 w-80 h-80 bg-violet-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Back link -->
    <a href="/connect" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-teal-400 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Connect
    </a>

    <!-- Header -->
    <div class="mb-10 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CONNECT
      </div>
      <div class="flex items-center gap-3 mb-3">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">&#x1F418;</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Mastodon</h1>
      </div>
      <p class="text-lg text-white/40">My Mastodon presence — from {account?.username || 'chirag127'}.</p>
    </div>

    <!-- Profile Hero -->
    {account && (
      <div class="glass-strong p-8 mb-10 reveal">
        {account.header && (
          <div class="h-32 rounded-lg mb-6 overflow-hidden -mx-8 -mt-8">
            <img src={account.header} alt="Header" class="w-full h-full object-cover" />
          </div>
        )}
        <div class="flex items-center gap-4 mb-6">
          {account.avatar && <img src={account.avatar} alt="Avatar" class="w-16 h-16 rounded-full flex-shrink-0" />}
          <div>
            <h2 class="text-xl font-bold text-white">{account.displayName}</h2>
            <p class="text-sm text-white/40">@{account.username}@mastodon.social</p>
          </div>
        </div>
        <div class="flex gap-6 mb-4">
          <div><span class="text-lg font-bold text-violet-400">{account.statusesCount?.toLocaleString()}</span> <span class="text-xs text-white/35">Posts</span></div>
          <div><span class="text-lg font-bold text-white">{account.followersCount?.toLocaleString()}</span> <span class="text-xs text-white/35">Followers</span></div>
          <div><span class="text-lg font-bold text-white">{account.followingCount?.toLocaleString()}</span> <span class="text-xs text-white/35">Following</span></div>
        </div>
        {account.fields?.length > 0 && (
          <div class="flex flex-wrap gap-4 pt-4 border-t border-white/5">
            {account.fields.map((f: any) => (
              <div>
                <div class="text-[0.6rem] text-white/30 uppercase">{f.name}</div>
                <div class="text-sm text-white" set:html={f.value}></div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Recent Posts -->
    <h2 class="text-xl font-semibold text-white mb-6 reveal">Recent Posts</h2>
    {statuses.length > 0 ? (
      <div class="space-y-4">
        {statuses.map((status: any) => (
          <a href={status.url} target="_blank" rel="noopener noreferrer" class="glass p-5 block hover:border-white/10 transition-colors group reveal">
            <p class="text-sm text-white/90 mb-3 leading-relaxed" set:html={status.content}></p>
            {status.mediaAttachments?.length > 0 && (
              <div class="grid grid-cols-2 gap-2 mb-3">
                {status.mediaAttachments.slice(0, 4).map((media: any) => (
                  <img src={media.previewUrl || media.url} alt={media.description || 'Media'} class="rounded-lg w-full h-32 object-cover" loading="lazy" />
                ))}
              </div>
            )}
            <div class="flex items-center gap-4 text-xs text-white/35">
              <span>{new Date(status.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>&#x1F501; {status.reblogsCount}</span>
              <span>&#x2B50; {status.favouritesCount}</span>
              <span>&#x1F4AC; {status.repliesCount}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center reveal">
        <p class="text-white/35">No Mastodon posts found. Run fetch-data first.</p>
      </div>
    )}

    <!-- External Link -->
    <div class="mt-10 glass p-6 text-center reveal">
      <a href="https://mastodon.social/@chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-violet-400 hover:text-violet-300 hover:underline">View on Mastodon &rarr;</a>
    </div>
  </main>
</Layout>
