---
import { summary } from '../../content';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

const chapters = [
  {
    year: '2002',
    location: 'Ghaziabad, UP',
    title: 'Born in Ghaziabad',
    color: 'rose',
    tags: ['NCR Region', 'Curious Kid', 'Gadget Hacker'],
    paragraphs: [
      'Grew up in the NCR region — a place where ambition is in the air. Early fascination with computers meant dismantling gadgets before understanding how to use them. Every broken remote control was a lesson in reverse engineering. The curiosity that started everything.',
    ],
  },
  {
    year: '2020',
    location: 'DDPS, Sanjay Nagar',
    title: 'JEE Advanced — AIR 11870',
    color: 'amber',
    tags: ['AIR 11870', '97% CBSE', 'School Topper', 'Top 1%'],
    paragraphs: [
      'Two years of relentless preparation culminated in All India Rank 11870 in JEE Advanced — top 1% of all candidates who appeared. Scored 97% in Class 12th CBSE boards, topping the school. It wasn\'t just about the rank; it was about learning how to stay calm when the stakes are high and how to break complex problems into solvable pieces.',
    ],
  },
  {
    year: '2020 — 2024',
    location: 'Lucknow, India',
    title: 'B.Tech CSE — AKTU',
    color: 'sky',
    tags: ['CGPA 8.81', 'Rank 1', 'Coding Champion', 'Distributed Systems'],
    paragraphs: [
      'Pursued Computer Science and Engineering at Dr. A.P.J. Abdul Kalam Technical University. Graduated as <strong class="text-white/70">College Topper (Rank 1)</strong> with a CGPA of 8.81. This is where theory met practice — learned distributed systems, databases, and built the foundations that power everything I do today. Won Rank 1 in the college coding competition in 2022.',
      'Late nights in the computer lab, debugging code that refused to work until 3 AM, competing in hackathons, and discovering that the best way to learn something is to build it. College wasn\'t just about grades — it was about becoming an engineer.',
    ],
  },
  {
    year: 'Jul 2023 — May 2025',
    location: 'Remote, India',
    title: 'Full Stack Developer — QRsay.com',
    color: 'emerald',
    tags: ['Python', 'Node.js', 'MongoDB', 'Kafka', 'React', 'E-Commerce'],
    paragraphs: [
      'First real-world engineering role. Managed the full software life cycle for a high-traffic food e-commerce platform. Achieved <strong class="text-white/70">40% reduction in API response times</strong>. Built real-time order processing with Kafka. Integrated payment gateways.',
      'This is where I learned that writing code is only 30% of the job — the rest is architecture, communication, and debugging at 2 AM when production is on fire. Working remotely taught me discipline, async communication, and how to ship features that users actually need.',
    ],
  },
  {
    year: 'Jun 2025 — Present',
    location: 'Bhubaneswar, India',
    title: 'Software Engineer — TCS',
    color: 'amber',
    tags: ['Python', 'React', 'CI/CD', 'Enterprise', 'Performance'],
    paragraphs: [
      'Working on enterprise-scale pricing engines, modular data validation pipelines, and automated CI/CD workflows. Reduced processing latency by <strong class="text-white/70">60%</strong> using Python optimization. Refactoring legacy monoliths into maintainable, object-oriented modules.',
      'The enterprise world is a different beast. Here, it\'s not just about writing code that works — it\'s about writing code that works at scale, that\'s secure, that can be maintained by teams of engineers who will come after you. Learning the enterprise side of software engineering — scale, governance, and the art of not breaking production.',
    ],
  },
  {
    year: 'Now',
    location: 'Bhubaneswar / Everywhere',
    title: 'Building Chirag Singhal',
    color: 'violet',
    isCurrent: true,
    tags: [],
    paragraphs: [
      'This digital identity operating system. A real-time personal data engine that pulls from GitHub, Lichess, Last.fm, AniList, Letterboxd, and more. 100% client-side. ₹0 cost. Every line of code open.',
      'Because your digital identity should belong to you — not a corporation. This project represents everything I believe in: open source, privacy-first, and the idea that the best software is the kind that empowers individuals.',
    ],
  },
];

const colorMap: Record<string, { dot: string; badge: string; badgeBg: string }> = {
  rose: { dot: 'bg-rose-400', badge: 'text-rose-400', badgeBg: 'bg-rose-400/10' },
  amber: { dot: 'bg-amber-400', badge: 'text-amber-400', badgeBg: 'bg-amber-400/10' },
  sky: { dot: 'bg-sky-400', badge: 'text-sky-400', badgeBg: 'bg-sky-400/10' },
  emerald: { dot: 'bg-emerald-400', badge: 'text-emerald-400', badgeBg: 'bg-emerald-400/10' },
  violet: { dot: 'bg-violet-400', badge: 'text-violet-400', badgeBg: 'bg-violet-400/10' },
};
---

<Layout title="My Story" description="The journey of Chirag Singhal — from Ghaziabad to building distributed systems">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-violet-500/4 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Page Header -->
    <div class="mb-12 relative">
      <a href="/me" class="inline-flex items-center gap-2 text-sm text-white/30 hover:text-white/50 mb-5 transition-colors group">
        <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Back to Me
      </a>

      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        ME / Story
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">
        My Story
      </h1>
      <p class="text-base text-white/40 max-w-2xl">
        From a curious kid in Ghaziabad to building systems that serve millions. Every line of code is a step in the journey.
      </p>
    </div>

    <!-- Summary Card -->
    <div class="glass-strong p-8 mb-14 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-48 h-48 bg-teal-500/5 rounded-full blur-[80px] pointer-events-none"></div>
      <div class="relative">
        <div class="flex items-center gap-2 mb-4">
          <div class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></div>
          <span class="text-xs font-medium text-teal-400 uppercase tracking-widest">Currently</span>
        </div>
        <p class="text-sm text-white/50 leading-relaxed">
          {summary}
        </p>
      </div>
    </div>

    <!-- Narrative Intro -->
    <div class="mb-14">
      <p class="text-sm text-white/50 leading-relaxed mb-4">
        I was born in 2002 in Ghaziabad, a city in the National Capital Region of India. Growing up surrounded by the buzz of NCR, I was that kid who dismantled every gadget in the house — not to break them, but to understand how they worked. Remote controls, old phones, even the family desktop. My parents weren't always thrilled, but that curiosity became the foundation of everything.
      </p>
      <p class="text-sm text-white/50 leading-relaxed mb-4">
        By the time I reached high school, I knew I wanted to build things with code. The two years of JEE preparation were grueling, but they taught me discipline, pattern recognition, and how to solve hard problems under pressure. When the results came in — AIR 11870 in JEE Advanced, 97% in CBSE boards — it felt like the first chapter closing and a new one beginning.
      </p>
      <p class="text-sm text-white/50 leading-relaxed">
        College at AKTU was where everything clicked. I didn't just attend classes — I devoured every resource on distributed systems, databases, and software architecture I could find. I topped my batch (Rank 1), won coding competitions, and spent late nights building projects that went beyond the curriculum. By the time I graduated, I already had two years of professional development experience under my belt.
      </p>
    </div>

    <!-- Timeline -->
    <h2 class="text-xl font-bold text-white mb-8" style="font-family: var(--font-display, 'Outfit');">The Timeline</h2>
    <div class="relative pl-8 border-l border-white/10 space-y-0">
      {chapters.map((ch) => {
        const c = colorMap[ch.color] || colorMap.violet!;
        return (
          <div class={`mb-12 relative ${ch.isCurrent ? '' : ''}`}>
            <div class={`absolute -left-[2.55rem] h-4 w-4 rounded-full ${c.dot} border-4 border-[var(--color-surface)] ${ch.isCurrent ? 'animate-pulse' : ''}`}></div>
            <div class={`${ch.isCurrent ? 'glass-strong border-violet-400/30' : 'glass'} relative overflow-hidden`}>
              {ch.isCurrent && <div class="absolute top-0 right-0 w-32 h-32 bg-violet-500/8 rounded-full blur-[60px] pointer-events-none"></div>}
              <div class="relative p-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`text-xs font-semibold ${c.badge} ${c.badgeBg} px-2.5 py-0.5 rounded-full`}>{ch.year}</span>
                  <span class="text-xs text-white/30">{ch.location}</span>
                </div>
                <h3 class="text-base font-bold text-white mb-2">{ch.title}</h3>
                {ch.paragraphs.map((p) => (
                  <p class="text-sm text-white/50 leading-relaxed mb-3 last:mb-0" set:html={p} />
                ))}
                {ch.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-3">
                    {ch.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Closing -->
    <div class="mt-14 glass-strong p-8 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-48 h-48 bg-violet-500/5 rounded-full blur-[80px] pointer-events-none"></div>
      <div class="relative">
        <h2 class="text-base font-bold text-white mb-4" style="font-family: var(--font-display, 'Outfit');">What's Next?</h2>
        <p class="text-sm text-white/50 leading-relaxed mb-3">
          I'm 23 now, and the journey is just getting started. Every project I build, every system I design, every bug I fix at 2 AM — it all compounds. I believe in building in public, shipping fast, and learning from failure. The goal isn't to be the smartest person in the room; it's to be the most relentless learner.
        </p>
        <p class="text-sm text-white/50 leading-relaxed">
          If you're reading this and you're building something interesting — reach out. I'm always looking for collaborators, mentors, and fellow builders who believe that code can change the world. One commit at a time.
        </p>
      </div>
    </div>
  </main>
</Layout>
