---
/**
 * Sidebar — minimal navigation listing the 6 routes of me.oriz.in.
 *
 * Stays static and link-only for now. astro-chrome will eventually
 * own the global header/nav; this sidebar is a per-page island
 * specific to the personal site.
 */

const routes = [
	{ href: "/",        label: "Home" },
	{ href: "/now",     label: "Now" },
	{ href: "/uses",    label: "Uses" },
	{ href: "/cv",      label: "CV" },
	{ href: "/contact", label: "Contact" },
	{ href: "/privacy", label: "Privacy" },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<nav class="sidebar" aria-label="Primary">
	<ul>
		{routes.map((r) => {
			const active = (r.href === "/" ? current === "/" : current === r.href);
			return (
				<li>
					<a href={r.href} aria-current={active ? "page" : undefined}>
						{r.label}
					</a>
				</li>
			);
		})}
	</ul>
</nav>

<style>
	.sidebar {
		font-family: var(--font-sans);
		font-size: 0.95rem;
	}
	.sidebar ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.sidebar a {
		color: var(--color-muted, #9b9ba3);
		text-decoration: none;
		padding: 0.25rem 0;
		display: inline-block;
	}
	.sidebar a:hover,
	.sidebar a[aria-current="page"] {
		color: var(--color-fg, #f5f5f7);
	}
</style>
