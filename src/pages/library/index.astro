---
/**
 * Library Drive — Hub for all media consumption.
 * Clean, no-image design with the new teal→violet
 * palette.
 */
import Layout from '../../layouts/Layout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let moviesDb: any = {};
let booksDb: any = {};
let musicDb: any = {};
let animeDb: any = {};

try {
  moviesDb = JSON.parse(
    await fs.readFile(
      path.resolve(
        './src/content/generated/movies.json',
      ),
      'utf-8',
    ),
  );
} catch {}
try {
  booksDb = JSON.parse(
    await fs.readFile(
      path.resolve(
        './src/content/generated/books.json',
      ),
      'utf-8',
    ),
  );
} catch {}
try {
  musicDb = JSON.parse(
    await fs.readFile(
      path.resolve(
        './src/content/generated/music.json',
      ),
      'utf-8',
    ),
  );
} catch {}
try {
  animeDb = JSON.parse(
    await fs.readFile(
      path.resolve(
        './src/content/generated/anime.json',
      ),
      'utf-8',
    ),
  );
} catch {}

const moviesWatched =
  moviesDb.watched?.length || 0;
const moviesShows =
  moviesDb.shows?.length || 0;
const moviesWatchlist =
  moviesDb.watchlist?.length || 0;
const booksRead = booksDb.read?.length || 0;
const booksReading =
  booksDb.reading?.length || 0;
const booksQueued =
  booksDb.wantToRead?.length || 0;
const musicScrobbles =
  musicDb.lastfm?.stats?.playcount || 0;
const musicArtists =
  musicDb.lastfm?.topArtists?.length || 0;
const animeWatching =
  animeDb.anime?.watching?.length || 0;
const animeCompleted =
  animeDb.anime?.completed?.length || 0;

interface Category {
  title: string;
  href: string;
  icon: string;
  accent: string;
  description: string;
  stats: { label: string; value: string | number }[];
  subPages: { label: string; href: string }[];
}

const categories: Category[] = [
  {
    title: 'Movies',
    href: '/library/movies',
    icon: '🎬',
    accent: 'teal',
    description:
      'Films tracked via Trakt',
    stats: [
      {
        label: 'Movies',
        value: moviesWatched || 0,
      },
      {
        label: 'Top Rated',
        value: (moviesDb.watched || []).filter((m: any) => m.rating).length,
      },
      {
        label: 'Watchlist',
        value: moviesWatchlist || 0,
      },
    ],
    subPages: [
      {
        label: 'All Watched',
        href: '/library/movies-watched',
      },
      {
        label: 'Top Rated',
        href: '/library/movies-rated',
      },
      {
        label: 'Watchlist',
        href: '/library/movies-watchlist',
      },
    ],
  },
  {
    title: 'TV Shows',
    href: '/library/shows',
    icon: '📺',
    accent: 'violet',
    description:
      'TV shows tracked via Trakt',
    stats: [
      {
        label: 'Tracked',
        value: moviesShows || 0,
      },
      {
        label: 'Episodes',
        value: (moviesDb.shows || []).reduce((acc: number, s: any) => acc + (s.episodesWatched || 0), 0),
      },
    ],
    subPages: [
      {
        label: 'All Tracked',
        href: '/library/shows-watched', // We will create this
      },
    ],
  },
  {
    title: 'Anime',
    href: '/library/anime',
    icon: '🌸',
    accent: 'sky',
    description:
      'Anime tracked via AniList',
    stats: [
      {
        label: 'Watching',
        value: animeWatching || 0,
      },
      {
        label: 'Completed',
        value: animeCompleted || 0,
      },
    ],
    subPages: [
      {
        label: 'Completed',
        href: '/library/anime-completed',
      },
      {
        label: 'Plan to Watch',
        href: '/library/anime-plan-to-watch',
      },
      { label: 'Manga', href: '/library/manga' },
    ],
  },
  {
    title: 'Books',
    href: '/library/books',
    icon: '📚',
    accent: 'violet',
    description:
      'Reading diary from OpenLibrary',
    stats: [
      { label: 'Read', value: booksRead || 0 },
      {
        label: 'Reading',
        value: booksReading || 0,
      },
      { label: 'Queued', value: booksQueued || 0 },
    ],
    subPages: [
      {
        label: 'Read',
        href: '/library/books-read',
      },
      {
        label: 'Want to Read',
        href: '/library/books-want-to-read',
      },
    ],
  },
  {
    title: 'Music',
    href: '/library/music',
    icon: '🎵',
    accent: 'rose',
    description:
      'Listening habits from Last.fm',
    stats: [
      {
        label: 'Scrobbles',
        value: musicScrobbles
          ? musicScrobbles.toLocaleString()
          : '0',
      },
      {
        label: 'Artists',
        value: musicArtists || 0,
      },
    ],
    subPages: [
      {
        label: 'Top Artists',
        href: '/library/music-top-artists',
      },
      {
        label: 'Top Tracks',
        href: '/library/music-top-tracks',
      },
      {
        label: 'Recent',
        href: '/library/music-recent',
      },
    ],
  },
];

const accentColors: Record<string, {
  text: string;
  bg: string;
  border: string;
}> = {
  teal: {
    text: 'text-teal-400',
    bg: 'bg-teal-500/5',
    border: 'border-teal-500/15',
  },
  sky: {
    text: 'text-sky-400',
    bg: 'bg-sky-500/5',
    border: 'border-sky-500/15',
  },
  violet: {
    text: 'text-violet-400',
    bg: 'bg-violet-500/5',
    border: 'border-violet-500/15',
  },
  rose: {
    text: 'text-rose-400',
    bg: 'bg-rose-500/5',
    border: 'border-rose-500/15',
  },
};

const moreLinks = [
  {
    title: 'Manga',
    href: '/library/manga',
    icon: '📖',
  },
  {
    title: 'Podcasts',
    href: '/library/podcasts',
    icon: '🎙️',
  },
  {
    title: 'Twitch',
    href: '/library/twitch',
    icon: '🟣',
  },
  {
    title: 'Videos',
    href: '/library/videos',
    icon: '▶️',
  },
];
---

<Layout
  title="Library"
  description="Everything I watch, read, and listen to"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-10"
  >
    <!-- Header -->
    <div class="mb-10">
      <h1
        class="text-3xl font-black text-white mb-2"
        style="font-family:
          var(--font-display, 'Outfit');"
      >
        Library
      </h1>
      <p class="text-sm text-white/35">
        Everything I watch, read, and listen to —
        tracked automatically.
      </p>
    </div>

    <!-- Main Category Cards -->
    <div
      class="grid grid-cols-1 md:grid-cols-2  gap-5
        mb-12"
    >
      {categories.map((cat) => {
        const colors = accentColors[cat.accent];
        return (
          <a
            href={cat.href}
            class="group p-6 rounded-2xl
              bg-white/[0.015] border border-white/5
              hover:border-white/10
              hover:bg-white/[0.025]
              transition-all duration-300"
          >
            <!-- Header -->
            <div
              class="flex items-center gap-3 mb-4"
            >
              <div
                class={`flex items-center
                  justify-center h-11 w-11
                  rounded-xl ${colors.bg}
                  text-xl`}
              >
                {cat.icon}
              </div>
              <div class="min-w-0 flex-1">
                <h2
                  class="text-lg font-bold text-white
                    group-hover:text-white/90
                    transition-colors flex
                    items-center gap-2"
                  style="font-family:
                    var(--font-display, 'Outfit');"
                >
                  {cat.title}
                  <svg
                    class="h-3.5 w-3.5 text-white/15
                      group-hover:text-white/40
                      group-hover:translate-x-0.5
                      transition-all"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M9 5l7 7-7 7" />
                  </svg>
                </h2>
                <p
                  class="text-xs text-white/25
                    mt-0.5"
                >
                  {cat.description}
                </p>
              </div>
            </div>

            <!-- Stats -->
            <div
              class="flex items-center gap-5  mb-4
                py-3 border-y border-white/[0.03]"
            >
              {cat.stats.map((stat) => (
                <div>
                  <div
                    class={`text-xl font-black
                      ${colors.text}`}
                    style="font-family:
                      var(--font-display, 'Outfit');"
                  >
                    {stat.value}
                  </div>
                  <div
                    class="text-[8px] text-white/20
                      uppercase tracking-widest
                      font-semibold"
                  >
                    {stat.label}
                  </div>
                </div>
              ))}
            </div>

            <!-- Sub-pages -->
            {cat.subPages.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {cat.subPages.map((sp) => (
                  <span
                    class="text-[9px] px-2.5 py-1
                      rounded-md bg-white/[0.03]
                      text-white/30
                      border border-white/[0.03]
                      font-semibold
                      group-hover:bg-white/[0.05]
                      group-hover:text-white/40
                      transition-colors"
                  >
                    {sp.label}
                  </span>
                ))}
              </div>
            )}
          </a>
        );
      })}
    </div>

    <!-- More Collections -->
    <div class="mb-10">
      <div
        class="flex items-center gap-3 mb-5"
      >
        <span
          class="h-px flex-1 bg-white/5"
        ></span>
        <span
          class="text-[9px] text-white/20
            uppercase tracking-widest
            font-semibold px-3"
        >
          More Collections
        </span>
        <span
          class="h-px flex-1 bg-white/5"
        ></span>
      </div>

      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-3"
      >
        {moreLinks.map((link) => (
          <a
            href={link.href}
            class="group p-4 rounded-xl
              bg-white/[0.01]
              border border-white/[0.03]
              hover:border-white/8
              hover:bg-white/[0.02]
              transition-all duration-200"
          >
            <div class="text-xl mb-2">
              {link.icon}
            </div>
            <h3
              class="text-sm font-semibold
                text-white/60
                group-hover:text-[var(--primary-light)]
                transition-colors"
            >
              {link.title}
            </h3>
          </a>
        ))}
      </div>
    </div>

    <!-- Footer note -->
    <div
      class="p-6 rounded-xl bg-white/[0.01]
        border border-white/[0.03] text-center"
    >
      <div
        class="flex items-center justify-center
          gap-2 mb-2"
      >
        <svg
          class="h-4 w-4 text-[var(--primary-light)]/50"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <span
          class="text-xs font-medium text-white/30"
        >
          Build-Time Sync
        </span>
      </div>
      <p class="text-xs text-white/20">
        All data is fetched at build time via
        GitHub Actions.
      </p>
    </div>
  </div>
</Layout>
