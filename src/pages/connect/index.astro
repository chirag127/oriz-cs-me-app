---

<Layout title="Connect Drive" description="Social profiles, contact info, and ways to connect with Chirag Singhal">  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 relative">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--color-primary)]/5 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Header -->
    <div class="mb-12 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/40 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
        CONNECT Drive
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Connect</h1>
      <p class="text-lg text-white/40 max-w-2xl">All platforms and social profiles — find me wherever you are.</p>
    </div>

    <!-- Email Hero Card -->
    <a href="mailto:hi@chirag127.in" class="glass-strong p-8 mb-10 reveal group flex items-center gap-6 relative overflow-hidden hover:border-[var(--color-primary)]/30 transition-colors">
      <div class="absolute top-0 right-0 w-48 h-48 bg-[var(--color-primary)]/5 rounded-full blur-[80px] pointer-events-none"></div>
      <div class="h-16 w-16 rounded-2xl bg-[var(--color-primary)]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)]/15 transition-colors">
        <svg class="h-8 w-8 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </div>
      <div class="min-w-0 flex-1">
        <h2 class="text-2xl font-bold text-white group-hover:text-[var(--color-primary)] transition-colors mb-1">Email Me</h2>
        <p class="text-lg text-white/50">hi@chirag127.in</p>
        <p class="text-sm text-white/30 mt-1">The best way to reach me for collaborations, opportunities, or just to say hi.</p>
      </div>
      <svg class="h-6 w-6 text-white/20 flex-shrink-0 group-hover:text-[var(--color-primary)] group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
    </a>

    <!-- Dev & Professional -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-5">
        <svg class="h-4 w-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
        <h2 class="text-sm font-semibold text-white/50 uppercase tracking-widest">Dev & Professional</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {devLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="glass p-5 group flex items-center gap-4 hover:border-white/10 transition-colors">
            <div class="h-11 w-11 rounded-xl flex items-center justify-center flex-shrink-0 transition-colors" style={`background: ${link.color}12;`}>
              <svg class="h-5 w-5" style={`color: ${link.color}`} fill="currentColor" viewBox="0 0 24 24">
                <path d={iconPaths[link.icon] || 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z'}/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-primary)] transition-colors">{link.name}</h3>
              <p class="text-xs text-white/35 truncate">{link.username}</p>
            </div>
            <svg class="h-4 w-4 text-white/15 flex-shrink-0 group-hover:text-white/40 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Social -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-5">
        <svg class="h-4 w-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        <h2 class="text-sm font-semibold text-white/50 uppercase tracking-widest">Social</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {socialPlatformLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="glass p-5 group flex items-center gap-4 hover:border-white/10 transition-colors">
            <div class="h-11 w-11 rounded-xl flex items-center justify-center flex-shrink-0 transition-colors" style={`background: ${link.color}12;`}>
              <svg class="h-5 w-5" style={`color: ${link.color}`} fill="currentColor" viewBox="0 0 24 24">
                <path d={iconPaths[link.icon] || 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z'}/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-primary)] transition-colors">{link.name}</h3>
              <p class="text-xs text-white/35 truncate">{link.username}</p>
