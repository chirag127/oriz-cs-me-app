{
  "name": "chirag-website",
  "type": "module",
  "version": "1.0.0",
  "description": "Chirag Singhal — Digital Identity Operating System for Chirag Singhal",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "tsx scripts/mirror-content.ts && tsx scripts/generate-og-images.ts",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "mirror-content": "tsx scripts/mirror-content.ts",
    "generate-og": "tsx scripts/generate-og-images.ts",
    "validate-content": "tsx scripts/validate-content.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "typecheck": "astro check && tsc --noEmit",
    "type-check": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.2",
    "@aws-sdk/client-s3": "^3.1025.0",
    "@emailjs/browser": "^4.4.1",
    "@heyputer/puter.js": "^2.2.14",
    "@libsql/client": "^0.17.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@types/react": "^19.2.14",
    "astro": "^6.1.0",
    "dexie": "^4.3.0",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "minisearch": "^7.2.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.9",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react-dom": "^19.2.3",
    "@vercel/og": "^0.11.1",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.7.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  }
}
