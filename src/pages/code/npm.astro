---
import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { npm: { packages: [] } };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/dev-stats.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[NPM] dev-stats.json not found.');
}

const packages = db.npm?.packages || [];
const totalDownloads = packages.reduce(
  (s: number, p: any) => s + (p.downloads || 0),
  0,
);
---

<Layout title="NPM Packages" description="Chirag Singhal's NPM packages — download stats and details">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <!-- Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CODE
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">NPM Packages</h1>
      <p class="text-base text-white/40">Published packages by @{CONFIG.user.username} — with download stats.</p>
    </div>

    <!-- Hero Stats -->
    <div class="glass-strong p-6 mb-10 flex flex-wrap gap-8 reveal">
      <div>
        <div class="text-2xl font-bold text-red-400">{packages.length}</div>
        <div class="text-xs text-white/40">Packages</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white">{totalDownloads.toLocaleString()}</div>
        <div class="text-xs text-white/40">Monthly Downloads</div>
      </div>
    </div>

    {packages.length > 0 ? (
      <div class="space-y-4">
        {packages.map((pkg: any) => (
          <div class="glass p-6 hover:border-white/10 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-base font-semibold text-white">{pkg.name}</h3>
                  {pkg.version && <span class="text-[0.6rem] px-2 py-0.5 rounded-full bg-red-500/10 text-red-400 font-mono">v{pkg.version}</span>}
                </div>
                {pkg.description && <p class="text-sm text-white/40 mb-3">{pkg.description}</p>}
                <div class="flex items-center gap-3 flex-wrap">
                  {pkg.downloads !== undefined && (
                    <span class="text-xs text-teal-400 font-medium">{pkg.downloads.toLocaleString()} monthly downloads</span>
                  )}
                  {pkg.keywords?.length > 0 && (
                    <div class="flex gap-1 flex-wrap">
                      {pkg.keywords.slice(0, 5).map((kw: string) => (
                        <span class="text-[0.55rem] px-1.5 py-0.5 rounded-full bg-white/5 text-white/30">{kw}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <button
                  type="button"
                  class="copy-btn p-2 rounded-lg bg-white/5 hover:bg-white/10 text-white/30 hover:text-white/60 transition-colors"
                  title="Copy install command"
                  data-cmd={`npm install ${pkg.name}`}
                >
                  <svg class="h-4 w-4 icon-copy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" /></svg>
                  <svg class="h-4 w-4 icon-check hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                </button>
                <a
                  href={`https://www.npmjs.com/package/${pkg.name}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-2 rounded-lg bg-white/5 hover:bg-white/10 text-white/30 hover:text-red-400 transition-colors"
                  title="View on NPM"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-white/40">No NPM packages found. Run fetch-data first.</p>
        <p class="text-xs text-white/25 mt-2">Or check <a href={`https://www.npmjs.com/~${CONFIG.user.username}`} target="_blank" class="text-red-400 hover:underline">NPM profile</a></p>
      </div>
    )}

    <div class="mt-10 glass p-6 text-center">
      <a href={`https://www.npmjs.com/~${CONFIG.user.username}`} target="_blank" rel="noopener noreferrer" class="text-sm text-red-400 hover:underline">View NPM Profile →</a>
    </div>
  </main>
  <script is:inline>
    document.querySelectorAll('.copy-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var cmd = this.dataset.cmd;
        var iconCopy = this.querySelector('.icon-copy');
        var iconCheck = this.querySelector('.icon-check');
        navigator.clipboard.writeText(cmd).then(function () {
          iconCopy?.classList.add('hidden');
          iconCheck?.classList.remove('hidden');
          setTimeout(function () {
            iconCopy?.classList.remove('hidden');
            iconCheck?.classList.add('hidden');
          }, 2000);
        });
      });
    });
  </script>
</Layout>
