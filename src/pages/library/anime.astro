---
import AgeGatedLayout from '../../layouts/AgeGatedLayout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import EmptyState from '../../components/EmptyState.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: { watching: [], completed: [] } };

try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn(
    '[Anime Hub] anime.json not found. Run pnpm run fetch-data first.',
  );
}

const currentlyWatching = db.anime?.watching || [];
const completedAnime = db.anime?.completed || [];

function scoreColor(score: number | null): string {
  if (!score) return '#52525b';
  if (score >= 8) return '#34d399';
  if (score >= 6) return '#2dd4bf';
  return '#fbbf24';
}

const hasApiData = currentlyWatching.length > 0 || completedAnime.length > 0;
const totalWatched = completedAnime.length;
const totalWatching = currentlyWatching.length;
const meanScore =
  hasApiData && completedAnime.length > 0
    ? (
        completedAnime.reduce((s: number, e: any) => s + (e.score || 0), 0) /
        completedAnime.filter((e: any) => e.score).length
      ).toFixed(1)
    : '—';

const fallbackGradients = [
  'linear-gradient(135deg, #0ea5e9, #0284c7)',
  'linear-gradient(135deg, #0d9488, #0f766e)',
  'linear-gradient(135deg, #4f46e5, #4338ca)',
  'linear-gradient(135deg, #db2777, #be185d)',
  'linear-gradient(135deg, #1e293b, #0f172a)',
  'linear-gradient(135deg, #111827, #000000)',
];
const fallbackEmojis = ['🌸', '🍱', '⛩️', '🗡️', '👺', '🍜', '🎋', '🎏'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<AgeGatedLayout contentLabel="Anime" declinePath="/library/" title="Anime" description="Chirag Singhal's anime watchlist - currently watching and completed">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Breadcrumb -->
    <a
      href="/library"
      class="inline-flex items-center gap-1.5
        text-xs text-white/20
        hover:text-white/40 transition-colors mb-8"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path d="M15 19l-7-7 7-7" />
      </svg>
      Library Drive
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-xs font-medium text-sky-400 mb-4">
        DISCOVER
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-sky-500/10 flex items-center justify-center">
          <span class="text-xl">🌸</span>
        </div>
        <h1 class="text-4xl font-bold text-white uppercase tracking-tighter" style="font-family: 'Outfit', sans-serif;">Anime</h1>
      </div>
      <p class="text-white/40">Watchlist and completed history synced automatically.</p>
    </div>

    {!hasApiData && (
      <EmptyState
        emoji="🌸"
        title="Anime not loaded yet"
        message="Run fetch-data with `ANILIST_USER` set. Empty for now — populate locally or via the CI Firestore sync."
      />
    )}

    <!-- Quick Navigation -->
    <div class="flex flex-wrap gap-2 mb-12">
      <a href="/library/anime-completed" class="text-[10px] px-4 py-2 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 transition-all font-bold uppercase tracking-widest">Completed</a>
      <a href="/library/anime-plan-to-watch" class="text-[10px] px-4 py-2 rounded-full bg-rose-500/10 text-rose-400 border border-rose-500/20 hover:bg-rose-500/20 transition-all font-bold uppercase tracking-widest">Queue</a>
      <a href="/library/manga" class="text-[10px] px-4 py-2 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 transition-all font-bold uppercase tracking-widest">Manga</a>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {[
        { label: 'Watching', value: totalWatching, color: 'text-sky-400' },
        { label: 'Completed', value: totalWatched, color: 'text-emerald-400' },
        { label: 'Mean Score', value: meanScore, color: 'text-teal-400' },
        { 
          label: 'Episodes', 
          value: hasApiData 
            ? currentlyWatching.reduce((sum: number, e: any) => sum + (e.progress || 0), 0) + completedAnime.reduce((sum: number, e: any) => sum + (e.episodes || 0), 0)
            : 0,
          color: 'text-violet-400' 
        }
      ].map(stat => (
        <div class="p-5 glass rounded-2xl border border-white/5 text-center">
          <div class={`text-3xl font-black ${stat.color} truncate`} style="font-family: 'Outfit', sans-serif;">{stat.value}</div>
          <div class="text-[9px] text-white/20 uppercase tracking-[0.2em] mt-1 font-bold">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Currently Watching -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xl font-bold text-white relative inline-block uppercase tracking-tight">
          Currently Watching
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
        </h2>
        <span class="h-2.5 w-2.5 rounded-full bg-emerald-400 animate-pulse"></span>
      </div>

      {currentlyWatching.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {currentlyWatching.map((entry: any, i: number) => {
            const vis = getVisuals(entry.title);
            const progress = entry.episodes ? Math.round((entry.progress / entry.episodes) * 100) : 0;
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-sky-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
                <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                  
                  {entry.coverUrl ? (
                    <img src={entry.coverUrl} alt={entry.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                      <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                    </div>
                  )}

                  {progress > 0 && (
                    <div class="absolute bottom-0 left-0 right-0 h-1 bg-black/40 z-20">
                      <div class="h-full bg-sky-400" style={`width: ${progress}%`}></div>
                    </div>
                  )}

                  {entry.score && (
                    <div class="absolute top-2 right-2 z-20 bg-black/60 backdrop-blur-md rounded-full px-2 py-0.5 border border-white/10">
                      <span class="text-[10px] font-bold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                    </div>
                  )}
                </div>
                <div class="px-3 pb-4">
                  <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-sky-400 transition-colors uppercase tracking-tight">{entry.title}</h3>
                  <p class="text-[10px] text-white/30 truncate mt-0.5 font-medium">{entry.progress} / {entry.episodes || '?'} eps</p>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12 text-white/20 text-sm glass rounded-2xl border border-white/5">
          Not currently watching any anime.
        </div>
      )}
    </section>

    <hr class="border-white/5 mb-16" />

    <!-- Completed -->
    <section class="mb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-bold text-white relative inline-block uppercase tracking-tight">
          Recent Completed
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
        </h2>
        <a href="/library/anime-completed" class="text-[10px] uppercase tracking-widest text-white/20 hover:text-emerald-400 transition-colors font-bold">
           Browse Full List →
        </a>
      </div>

      {completedAnime.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {completedAnime.slice(0, 12).map((entry: any, i: number) => {
            const vis = getVisuals(entry.title);
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
                <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                  
                  {entry.coverUrl ? (
                    <img src={entry.coverUrl} alt={entry.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                      <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                    </div>
                  )}

                  {entry.score && (
                    <div class="absolute top-2 right-2 z-20 bg-black/60 backdrop-blur-md rounded-full px-2 py-0.5 border border-white/10 font-bold text-[10px]" style={`color: ${scoreColor(entry.score)}`}>
                      {entry.score}
                    </div>
                  )}
                </div>
                <div class="px-3 pb-4">
                  <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-emerald-400 transition-colors uppercase tracking-tight">{entry.title}</h3>
                  <p class="text-[10px] text-white/30 truncate mt-0.5 font-medium">{entry.episodes || '?'} ch</p>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12 text-white/20 text-sm glass rounded-2xl border border-white/5">
          No completed anime tracked on AniList.
        </div>
      )}
    </section>

    <!-- AniList Profile Link -->
    <div class="mt-20 py-12 border-t border-white/5 text-center">
      <a href="https://anilist.co/user/chirag127" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-sky-500/10 text-sky-500 hover:text-sky-400 hover:bg-sky-500/20 font-bold text-xs uppercase tracking-widest transition-all">
        Full History on AniList
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </main>
</AgeGatedLayout>
