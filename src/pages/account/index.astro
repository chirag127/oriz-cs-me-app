---
import AccountPanel from '../../components/AccountPanel.tsx';
/*
 * /account — sign-in surface for me.oriz.in.
 *
 * The wordmark + ⌘K + sign-in are the only chrome affordances. Sign-in
 * lives on this dedicated page so the AccountPanel React island can
 * lazy-load Firebase only when the visitor lands here. Every site in the
 * family routes its `sign in` link to the same path.
 */
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Account"
  description="Sign in across the oriz family — Google, GitHub, email link, or anonymous."
  breadcrumb="ACCOUNT"
  provenanceSection="/account"
  provenanceApis="firebase auth"
>
  <div class="spine">
    <header class="page-head">
      <h1>Account</h1>
      <p class="lede">
        Sign in once, signed in across <code>oriz.in</code>,
        <code>blog.oriz.in</code>, <code>journal.oriz.in</code>, every other
        family site. The session is held by Firebase Auth with the auth
        domain pinned at <code>auth.oriz.in</code>.
      </p>
    </header>

    <section class="band">
      <AccountPanel client:only="react" siteName="oriz / me" />
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/me/">/me</a>
      <span aria-hidden="true">·</span>
      <a href="/connect/">/connect</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .page-head code {
    font-family: var(--font-mono);
    background: var(--archival-wash);
    padding: 0.125em 0.375em;
    font-size: 0.875em;
  }
</style>
