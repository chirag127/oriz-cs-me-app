---
/**
 * TV Shows Hub — Redesigned with only TV show contents.
 * No colored image placeholders.
 */
import Layout from '../../layouts/Layout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

interface Show {
  title: string;
  year: number;
  rating: number | null;
  genres: string[];
  episodesWatched: number;
  category?: string;
  posterUrl?: string;
}

let db = {
  shows: [] as Show[],
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch {
  console.warn(
    '[Shows] movies.json not found.',
  );
}

const shows = db.shows || [];

// Show stats
const showCount = shows.length;
const totalEpisodes = shows.reduce(
  (s, sh) => s + (sh.episodesWatched || 0),
  0,
);

const recentShows = [...shows].slice(0, 8);
const fallbackGradients = [
  'linear-gradient(135deg, #2e1065, #4c1d95)',
  'linear-gradient(135deg, #1e3a8a, #1e40af)',
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #78350f, #92400e)',
  'linear-gradient(135deg, #44403c, #57534e)',
  'linear-gradient(135deg, #171717, #262626)',
];
const fallbackEmojis = ['📺', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout
  title="TV Shows"
  description="TV show diary — tracked via Trakt"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-12"
  >
    <!-- Breadcrumb -->
    <a
      href="/library"
      class="inline-flex items-center gap-1.5
        text-xs text-white/20
        hover:text-white/40 transition-colors mb-8"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path d="M15 19l-7-7 7-7" />
      </svg>
      Library Drive
    </a>

    <!-- Header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        DISCOVER
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">📺</span>
        </div>
        <h1 class="text-4xl font-bold text-white uppercase tracking-tighter" style="font-family: 'Outfit', sans-serif;">TV Shows</h1>
      </div>
      <p class="text-white/40">TV diary and series tracking — synced automatically.</p>
    </div>

    <!-- Quick Navigation -->
    <div class="flex flex-wrap gap-2 mb-12">
      <a
        href="/library/shows-watched"
        class="text-[10px] px-4 py-2 rounded-full
          bg-violet-500/10 text-violet-400
          border border-violet-500/20
          hover:bg-violet-500/20
          transition-all font-bold
          uppercase tracking-widest"
      >
        All History ({showCount})
      </a>
    </div>

    <!-- Stats Grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16"
    >
      {[
        {
          label: 'Total Shows',
          value: showCount,
          color: 'text-violet-400',
        },
        {
          label: 'Episodes Watched',
          value: totalEpisodes,
          color: 'text-sky-400',
        },
      ].map((stat) => (
        <div
          class="p-5 glass rounded-2xl
            border border-white/5 text-center"
        >
          <div
            class={`text-3xl font-black ${stat.color} truncate`}
            style="font-family: 'Outfit', sans-serif;"
          >
            {stat.value}
          </div>
          <div
            class="text-[9px] text-white/20
              uppercase tracking-[0.2em] mt-1
              font-bold"
          >
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- ═══ TRACKED SHOWS (RECENT) ═══ -->
    <section class="mb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-bold text-white relative inline-block uppercase tracking-tight">
          Recent Activity
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-violet-400 to-transparent rounded-full"></span>
        </h2>
        <a href="/library/shows-watched" class="text-[10px] uppercase tracking-widest text-white/20 hover:text-violet-400 transition-colors font-bold">
          View Complete History →
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
        {recentShows.map((show, i) => {
          const vis = getVisuals(show.title);
          return (
            <div class="glass rounded-2xl border border-white/5 hover:border-violet-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 40}ms`}>
              <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                
                {show.posterUrl ? (
                  <img src={show.posterUrl} alt={show.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                    <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                  </div>
                )}

                <!-- Episode Badge -->
                <div class="absolute top-2 right-2 z-20 bg-black/60 backdrop-blur-md rounded-full px-2 py-0.5 border border-white/10">
                  <span class="text-[10px] font-bold text-violet-400">
                    {show.episodesWatched || 0} <span class="text-[8px] text-white/30 uppercase">eps</span>
                  </span>
                </div>
              </div>

              <div class="px-3 pb-4">
                <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-violet-400 transition-colors">
                  {show.title}
                </h3>
                <p class="text-[10px] text-white/30 truncate mt-0.5">
                  {show.year} · {(show.genres || [])[0]}
                </p>
              </div>
            </div>
          );
        })}
      </div>
      
      <div class="flex justify-center">
        <a href="/library/shows-watched" class="text-xs px-4 py-2 rounded-lg bg-white/[0.03] border border-white/5 hover:bg-white/[0.05] text-white/60 hover:text-white transition-colors">
          View all tracked shows
        </a>
      </div>
    </section>

    <!-- Trakt Profile Link -->
    <div class="mt-20 p-6 rounded-2xl bg-gradient-to-br from-red-500/5 to-rose-500/5 border border-red-500/10 text-center flex flex-col items-center">
      <div class="h-12 w-12 rounded-full bg-red-500/10 text-red-400 flex items-center justify-center text-xl mb-4">
        📽️
      </div>
      <h3 class="text-lg font-bold text-white mb-2">Complete Profile</h3>
      <p class="text-sm text-white/40 mb-6 max-w-md">
        For the complete, unfiltered history of every episode I've watched, rated, and reviewed.
      </p>
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500/10 text-red-400 font-semibold text-sm hover:bg-red-500/20 hover:scale-105 transition-all outline-none focus:ring-2 focus:ring-red-500/50">
        View Trakt Profile
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
