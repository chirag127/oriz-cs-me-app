---

<Layout title="Gear & Setup" description="The tools, products, and gadgets Chirag uses — from dev setup to daily carry">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Page Header -->
    <div class="mb-10">
      <a href="/me" class="inline-flex items-center gap-2 text-sm text-white/30 hover:text-white/50 mb-5 transition-colors group">
        <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Back to Me
      </a>

      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        ME / Gear
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">
        Gear & Setup
      </h1>
      <p class="text-base text-white/40 max-w-2xl">
        Everything I own and use — from dev tools to daily gadgets. No sponsorships, just what actually works.
      </p>
    </div>

    <!-- Tab Navigation -->
    <div class="flex gap-2 mb-10 overflow-x-auto scrollbar-hidden pb-2">
      <button class="gear-tab active px-4 py-2 rounded-xl text-sm font-medium bg-teal-500/10 text-teal-400 border border-teal-500/20 whitespace-nowrap transition-all" data-tab="software">
        Software & Dev
      </button>
      <button class="gear-tab px-4 py-2 rounded-xl text-sm font-medium bg-white/5 text-white/50 border border-white/10 whitespace-nowrap hover:bg-white/10 transition-all" data-tab="products">
        Products & Gadgets
      </button>
      <button class="gear-tab px-4 py-2 rounded-xl text-sm font-medium bg-white/5 text-white/50 border border-white/10 whitespace-nowrap hover:bg-white/10 transition-all" data-tab="amazon">
        Amazon Orders
      </button>
    </div>

    <!-- Software & Dev Tab -->
    <div id="tab-software" class="tab-content space-y-10">
      {usesData.map((category) => {
        const meta = categoryIcons[category.category] || { icon: "M5 13l4 4L19 7", color: "text-teal-400" };
        return (
          <section>
            <div class="flex items-center gap-3 mb-5">
              <div class={`h-9 w-9 rounded-lg bg-white/5 flex items-center justify-center`}>
                <svg class={`h-4 w-4 ${meta.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={meta.icon} /></svg>
              </div>
              <h2 class="text-base font-bold text-white">{category.category}</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {category.items.map((item) => (
                <div class="glass p-5 flex items-start gap-4">
                  <div class="h-2 w-2 rounded-full bg-teal-400/60 mt-2 flex-shrink-0"></div>
                  <div>
                    <h3 class="text-sm font-semibold text-white">{item.name}</h3>
                    <p class="text-xs text-white/40 mt-1">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </div>

    <!-- Products & Gadgets Tab -->
    <div id="tab-products" class="tab-content hidden space-y-10">
      {gearCategories.map((category) => (
        <section>
          <div class="flex items-center gap-3 mb-5">
            <div class="h-9 w-9 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class={`h-4 w-4 ${category.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={category.icon} /></svg>
            </div>
            <h2 class="text-base font-bold text-white">{category.name}</h2>
            <span class="text-xs text-white/30">{category.items.length} items</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {category.items.map((item) => (
              <div class="glass p-4 flex flex-col gap-2">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="text-sm font-semibold text-white leading-tight">{item.name}</h3>
                  <span class="text-xs font-bold text-emerald-400 whitespace-nowrap">{item.price}</span>
                </div>
                <p class="text-xs text-white/40">{item.note}</p>
              </div>
            ))}
          </div>
        </section>
      ))}
      <div class="glass p-4 flex items-center gap-3">
        <svg class="h-5 w-5 text-white/30 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <p class="text-xs text-white/40">Products purchased from Flipkart and Amazon. Prices are at time of purchase.</p>
      </div>
    </div>

    <!-- Amazon Orders Tab -->
    <div id="tab-amazon" class="tab-content hidden space-y-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-10 w-10 rounded-xl bg-orange-500/10 flex items-center justify-center">
          <svg class="h-5 w-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-white">Amazon Orders</h2>
          <p class="text-sm text-white/40 mt-0.5">My recent purchases from Amazon.in</p>
        </div>
      </div>

      <div class="space-y-4">
        {amazonOrders.map((order) => (
          <div class="glass p-5 rounded-2xl border border-white/5 flex flex-col sm:flex-row gap-4 justify-between sm:items-center">
            <div class="space-y-2">
              <div class="flex items-center gap-3">
                <span class="text-sm font-semibold text-white">{order.date}</span>
                <span class="text-xs text-white/30">Order #{order.orderNumber}</span>
              </div>
              <ul class="space-y-1">
                {order.items.map((item) => (
                  <li class="text-sm text-white/50 flex items-start gap-2">
                    <span class="text-teal-400/50 mt-1">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="flex flex-row sm:flex-col items-center sm:items-end justify-between sm:justify-center gap-2 border-t border-white/10 sm:border-0 pt-3 sm:pt-0 mt-2 sm:mt-0">
              <span class="text-lg font-bold text-white">₹{order.total.toFixed(2)}</span>
              <span class={`text-[10px] font-bold px-2.5 py-1 rounded-md uppercase tracking-wider ${
                order.status === 'Delivered' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' :
                order.status === 'Cancelled' ? 'bg-red-500/10 text-red-400 border border-red-500/20' :
                order.status === 'Payment Needed' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' :
                'bg-blue-500/10 text-blue-400 border border-blue-500/20'
              }`}>
                {order.status}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-14 glass p-6 flex items-center gap-4">
      <svg class="h-5 w-5 text-teal-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <p class="text-xs text-white/40">This page is inspired by <a href="https://uses.tech" target="_blank" rel="noopener noreferrer" class="text-teal-400/70 hover:text-teal-400 transition-colors">uses.tech</a>. Updated periodically as my stack evolves.</p>
    </div>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll('.gear-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.gear-tab').forEach(function(b) {
        b.classList.remove('active', 'bg-teal-500/10', 'text-teal-400', 'border-teal-500/20');
        b.classList.add('bg-white/5', 'text-white/50', 'border-white/10');
      });
      btn.classList.remove('bg-white/5', 'text-white/50', 'border-white/10');
      btn.classList.add('active', 'bg-teal-500/10', 'text-teal-400', 'border-teal-500/20');
      document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.add('hidden'); });
      document.getElementById('tab-' + tab).classList.remove('hidden');
    });
  });
</script>
