---
/*
 * Header — 56px single-line bar in `--ink` on `--paper`, hairline baseline.
 *
 * Layout per the v2 brief:
 *
 *   ┌────────────────────────────────────────────────────────────────┐
 *   │  oriz / me                              ⌘K  · sign in  · ☼/☾  │
 *   └────────────────────────────────────────────────────────────────┘
 *
 * NO mega-nav, NO logo lockup, NO avatar. Right side is three text-only
 * affordances in mono: `⌘K` (command palette), `sign in` (the ONLY auth
 * surface — opens `<AccountPanel>`), `☼` / `☾` for theme toggle.
 *
 * Optional breadcrumb in mono caps tracked +0.15em on tool/section pages
 * (e.g. `LIBRARY · FILMS`).
 */

import Wordmark from './Wordmark.astro';

interface Props {
  /** Breadcrumb shown right of the wordmark in mono caps. e.g. 'LIBRARY · FILMS'. */
  breadcrumb?: string;
}

const { breadcrumb } = Astro.props;
---

<header class="header">
  <div class="spine header-row">
    <div class="header-left">
      <Wordmark href="/" />
      {breadcrumb && (
        <span class="breadcrumb mono" aria-label={breadcrumb}>
          {breadcrumb}
        </span>
      )}
    </div>
    <nav class="header-right" aria-label="Site actions">
      <button
        type="button"
        class="cmdk-trigger mono"
        data-cmdk-open
        aria-label="Open command palette (Cmd+K)"
      >
        ⌘K
      </button>
      <span class="sep mono" aria-hidden="true">·</span>
      <a class="sign-in" href="/account/">sign in</a>
      <span class="sep mono" aria-hidden="true">·</span>
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle light or dark theme"
      >
        <span class="sun" aria-hidden="true">☼</span>
        <span class="moon" aria-hidden="true">☾</span>
      </button>
    </nav>
  </div>
  <hr class="hairline" />
</header>

<script is:inline>
  (function () {
    // Wire the theme toggle. Persist in localStorage; default to OS
    // preference. The site only swaps light/dark — no accent picker.
    var btn = document.getElementById('theme-toggle');
    var KEY = 'oriz-me:theme';
    function apply(theme) {
      document.documentElement.setAttribute('data-theme', theme);
    }
    try {
      var saved = localStorage.getItem(KEY);
      if (saved === 'dark' || saved === 'light') apply(saved);
    } catch (_) {}
    if (btn) {
      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme');
        var next;
        if (current === 'dark' || current === 'light') {
          next = current === 'dark' ? 'light' : 'dark';
        } else {
          // Fall through OS preference into an explicit override.
          var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          next = dark ? 'light' : 'dark';
        }
        apply(next);
        try { localStorage.setItem(KEY, next); } catch (_) {}
      });
    }
    // Cmd+K shortcut + button trigger — open the existing CommandPalette.
    var cmdkBtn = document.querySelector('[data-cmdk-open]');
    function openPalette() {
      var p = document.getElementById('command-palette');
      if (p) {
        p.classList.remove('hidden');
        var input = document.getElementById('command-input');
        if (input) input.focus();
      }
    }
    if (cmdkBtn) cmdkBtn.addEventListener('click', openPalette);
    document.addEventListener('keydown', function (e) {
      var meta = e.metaKey || e.ctrlKey;
      if (meta && (e.key === 'k' || e.key === 'K')) {
        e.preventDefault();
        openPalette();
      } else if (e.key === 'Escape') {
        var p = document.getElementById('command-palette');
        if (p) p.classList.add('hidden');
      }
    });
  })();
</script>

<style>
  .header {
    background: var(--paper);
  }
  .header-row {
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .header-left {
    display: inline-flex;
    align-items: baseline;
    gap: 1rem;
    min-width: 0;
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink-soft);
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .header-right {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cmdk-trigger,
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 12px;
    height: 28px;
    padding: 0 0.55rem;
    cursor: pointer;
    letter-spacing: 0.06em;
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .cmdk-trigger:hover,
  .theme-toggle:hover {
    border-color: var(--archival);
    color: var(--archival);
  }
  .theme-toggle {
    width: 32px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    line-height: 1;
  }
  .theme-toggle .moon { display: none; }
  :root[data-theme="dark"] .theme-toggle .sun { display: none; }
  :root[data-theme="dark"] .theme-toggle .moon { display: inline; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .theme-toggle .sun { display: none; }
    :root:not([data-theme="light"]) .theme-toggle .moon { display: inline; }
  }
  .sign-in {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: var(--ink-soft);
    letter-spacing: 0.04em;
  }
  .sign-in:hover {
    color: var(--archival);
    text-decoration-color: var(--archival);
  }
  .sep {
    color: var(--rule);
    font-size: 12px;
  }

  @media (max-width: 480px) {
    .breadcrumb { display: none; }
    .cmdk-trigger { display: none; }
  }
</style>
