---
import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { holopin: null };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/dev-stats.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Holopin] dev-stats.json not found.');
}

const badges = db.holopin?.badges || [];
---

<Layout title="Holopin Badges" description="Chirag Singhal's Holopin badges — open source achievements">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <!-- Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CODE
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">Holopin Badges</h1>
      <p class="text-base text-white/40">Open source contribution badges — from @{CONFIG.user.holopin}.</p>
    </div>

    <!-- Stats Row -->
    <div class="glass-strong p-6 mb-10 flex flex-wrap gap-8 reveal">
      <div>
        <div class="text-2xl font-bold text-blue-400">{badges.length}</div>
        <div class="text-xs text-white/40">Badges Earned</div>
      </div>
    </div>

    {badges.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 mb-10">
        {badges.map((badge: any) => (
          <a
            href={badge.link || `https://holopin.io/@${CONFIG.user.holopin}`}
            target="_blank"
            rel="noopener noreferrer"
            class="glass p-4 text-center group hover:border-blue-500/30 transition-colors"
          >
            {badge.imageUrl && (
              <img
                src={badge.imageUrl}
                alt={badge.name || badge.alt || 'Badge'}
                class="w-full h-24 object-contain mb-3 group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            )}
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-blue-400 transition-colors">
              {badge.name || badge.alt || 'Badge'}
            </h3>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-white/40">No Holopin badges found. Run fetch-data first.</p>
        <p class="text-xs text-white/25 mt-2">Or check <a href={`https://holopin.io/@${CONFIG.user.holopin}`} target="_blank" class="text-blue-400 hover:underline">Holopin profile</a></p>
      </div>
    )}

    <div class="glass p-6 text-center">
      <a href={`https://holopin.io/@${CONFIG.user.holopin}`} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-400 hover:underline">View on Holopin &rarr;</a>
    </div>
  </main>
</Layout>
