---
import { experience, summary } from '../../content';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

const highlightMetrics = [
  { label: 'Latency Reduction', value: '60%', desc: 'Optimized pricing engines at TCS' },
  { label: 'API Speed Boost', value: '40%', desc: 'Database tuning at QRsay' },
  { label: 'Distributed Outlets', value: 'Multiple', desc: 'Kafka event-driven sync' },
  { label: 'E-commerce Scale', value: 'High-Traffic', desc: 'Food platform at QRsay' },
];
---

<Layout title="Career Timeline" description="Professional experience of Chirag Singhal — TCS, QRsay">
  <CommandPalette />
  <main class="relative mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <div class="absolute top-0 right-0 w-96 h-96 bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Work</a>

    <!-- Page Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CAREER
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">Career Timeline</h1>
      <p class="text-base text-white/40 max-w-2xl">{summary.split('.').slice(0, 2).join('.')}.</p>
    </div>

    <!-- Impact Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 reveal-stagger">
      {highlightMetrics.map((m) => (
        <div class="glass p-5 text-center">
          <div class="text-xl font-bold text-teal-400">{m.value}</div>
          <div class="text-xs font-medium text-white/60 mt-1">{m.label}</div>
          <div class="text-[10px] text-white/30 mt-0.5">{m.desc}</div>
        </div>
      ))}
    </div>

    <!-- Timeline -->
    <div class="relative pl-8 border-l-2 border-teal-500/20">
      {experience.map((exp, i) => (
        <div class="mb-12 reveal">
          <!-- Timeline dot -->
          <div class="absolute -left-[2.55rem] flex items-center justify-center">
            <div class={`h-4 w-4 rounded-full border-2 border-teal-500/30 ${i === 0 ? 'bg-teal-400 shadow-[0_0_12px_rgba(20,184,166,0.5)]' : 'bg-teal-500/60'}`}></div>
          </div>
          {i === 0 && (
            <span class="absolute -left-[6rem] top-0 text-[10px] text-teal-400 font-semibold uppercase tracking-wider whitespace-nowrap">Current</span>
          )}
          <!-- Card -->
          <div class="glass p-8 hover:border-teal-500/15 transition-all duration-300">
            <div class="flex flex-wrap items-center gap-3 mb-2">
              <span class="text-sm text-teal-400 font-semibold">{exp.date}</span>
              <span class="text-xs text-white/20">·</span>
              <span class="text-xs text-white/30">{exp.location}</span>
            </div>
            <h2 class="text-xl font-bold text-white mb-1">{exp.title}</h2>
            <p class="text-sm text-teal-400 font-medium mb-5">{exp.company}</p>
            <ul class="space-y-3">
              {exp.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-white/60">
                  <svg class="h-4 w-4 text-teal-400/60 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- What I Bring -->
    <div class="glass-strong p-8 mt-8 reveal">
      <h2 class="text-lg font-bold text-white mb-6">What I Bring</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex items-start gap-3">
          <div class="h-10 w-10 rounded-lg bg-teal-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <div>
            <div class="text-sm font-medium text-white">Performance Engineering</div>
            <div class="text-xs text-white/40">60% latency reduction, 40% API speed boosts</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="h-10 w-10 rounded-lg bg-violet-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          </div>
          <div>
            <div class="text-sm font-medium text-white">Full-Stack Ownership</div>
            <div class="text-xs text-white/40">End-to-end SDLC from backend to UI</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="h-10 w-10 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <div class="text-sm font-medium text-white">Security & CI/CD</div>
            <div class="text-xs text-white/40">DevSecOps, automated testing, reduced rollback rates</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="h-10 w-10 rounded-lg bg-amber-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          </div>
          <div>
            <div class="text-sm font-medium text-white">Event-Driven Architecture</div>
            <div class="text-xs text-white/40">Kafka-based real-time order processing systems</div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
