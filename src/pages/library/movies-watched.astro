---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { watched: [], stats: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Movies Watched] movies.json not found.');
}

const watched = db.watched || [];
const sortedByDate = [...watched].sort(
  (a: any, b: any) =>
    new Date(b.watchedAt || 0).getTime() - new Date(a.watchedAt || 0).getTime(),
);

const genreCounts: Record<string, number> = {};
watched.forEach((m: any) => {
  if (m.genres?.[0])
    genreCounts[m.genres[0]] = (genreCounts[m.genres[0]] || 0) + 1;
});
const topGenres = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const validRatings = watched.filter((m: any) => m.rating);
const avgRating =
  validRatings.length > 0
    ? (
        validRatings.reduce((s: number, m: any) => s + m.rating, 0) /
        validRatings.length
      ).toFixed(1)
    : 'N/A';

const totalRuntime = watched.reduce(
  (s: number, m: any) => s + (m.runtime || 0),
  0,
);
const totalHours = Math.round(totalRuntime / 60);

const fallbackGradients = [
  'linear-gradient(135deg, #0c1445, #1a237e)',
  'linear-gradient(135deg, #1b3a2d, #2e7d32)',
  'linear-gradient(135deg, #4a148c, #e91e63)',
  'linear-gradient(135deg, #795548, #d7ccc8)',
  'linear-gradient(135deg, #1e3a5f, #0f4c75)',
  'linear-gradient(135deg, #bf360c, #e65100)',
];
const fallbackEmojis = ['🎬', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Watched Movies" description="All movies Chirag Singhal has watched">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/movies" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Movies
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-medium text-emerald-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
          <span class="text-xl">✅</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Watched Movies</h1>
      </div>
      <p class="text-white/40">All {watched.length} films I've watched - sorted by most recent.</p>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-6 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-emerald-400">{watched.length}</div>
        <div class="text-xs text-white/30">Films</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{avgRating}</div>
        <div class="text-xs text-white/30">Avg Rating</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-sky-400">{totalHours}h</div>
        <div class="text-xs text-white/30">Watch Time</div>
      </div>
      {topGenres.slice(0, 3).map(([genre, count]) => (
        <div>
          <div class="text-lg font-bold text-violet-400">{count}</div>
          <div class="text-xs text-white/30">{genre}</div>
        </div>
      ))}
    </div>

    {sortedByDate.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {sortedByDate.map((movie: any, i: number) => {
          const vis = getVisuals(movie.title);
          return (
          <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
            <div class="aspect-[2/3] rounded-t-2xl mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              {movie.posterUrl ? (
                <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover relative z-10 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
              {movie.rating && (
                <div class="absolute top-1.5 right-1.5 z-20 bg-black/50 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                  <span class="text-[0.6rem] font-semibold" style={`color: ${movie.rating >= 8 ? '#34d399' : '#2dd4bf'}`}>{movie.rating}</span>
                </div>
              )}
            </div>
            <div class="px-3 pb-3">
              <h3 class="text-xs font-semibold text-white truncate group-hover:text-emerald-400 transition-colors">{movie.title}</h3>
              <span class="text-[0.65rem] text-white/20 truncate max-w-full block">{movie.year} · {(movie.genres||[])[0]}</span>
            </div>
          </div>
        )})}
      </div>
    ) : (
      <div class="glass p-12 text-center rounded-2xl border border-white/5">
        <p class="text-white/30">No watched movies found.</p>
      </div>
    )}

    {watched.length === 0 && (
      <div
        class="text-center py-20 text-white/20
          text-sm"
      >
        No movies tracked yet. Run
        <code class="text-teal-400/50">
          pnpm run fetch-data
        </code>
        to sync.
      </div>
    )}

    <!-- Trakt Profile Link -->
    <div class="mt-16 text-center">
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500/10 text-red-500 hover:text-red-400 hover:bg-red-500/20 font-semibold text-sm transition-all">
        View complete profile on Trakt
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </main>
</Layout>
