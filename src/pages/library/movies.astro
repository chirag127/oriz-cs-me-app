---
/**
 * Movies Hub — restyled to v2 datasheet with age-gate per
 * knowledge/decisions/age-gating-policy.md. The listing page itself goes
 * behind the gate so adult-flagged poster URLs never leak before the
 * visitor confirms 18+.
 */
import AgeGatedLayout from '../../layouts/AgeGatedLayout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';
import EmptyState from '../../components/EmptyState.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

interface Movie {
  title: string;
  year: number;
  rating: number | null;
  genres: string[];
  watchedAt: string | null;
  posterUrl?: string;
  runtime?: number;
  overview?: string;
}

let db = {
  watched: [] as Movie[],
  watchlist: [] as Movie[],
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch {
  console.warn(
    '[Movies] movies.json not found.',
  );
}

const movies = db.watched || [];
const watchlist = db.watchlist || [];

const hasData = (movies.length || 0) + (watchlist.length || 0) > 0;

// Movie stats
const movieCount = movies.length;
const ratedMovies = movies.filter((m) => m.rating);
const avgMovieRating = ratedMovies.length > 0
  ? (
      ratedMovies.reduce(
        (s, m) => s + (m.rating || 0),
        0,
      ) / ratedMovies.length
    ).toFixed(1)
  : '—';

const topRatedMovies = [...movies]
  .filter((m) => m.rating)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 8);

const recentMovies = [...movies].slice(0, 8);

// Genre analysis (movies only)
const genreCounts: Record<string, number> = {};
movies.forEach((m) => {
  (m.genres || []).forEach((g: string) => {
    genreCounts[g] = (genreCounts[g] || 0) + 1;
  });
});
const topGenres = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([g]) => g);
const fallbackGradients = [
  'linear-gradient(135deg, #064e3b, #065f46)',
  'linear-gradient(135deg, #1e3a8a, #1e40af)',
  'linear-gradient(135deg, #4c1d95, #5b21b6)',
  'linear-gradient(135deg, #78350f, #92400e)',
  'linear-gradient(135deg, #831843, #9d174d)',
  'linear-gradient(135deg, #0f172a, #1e293b)',
];
const fallbackEmojis = ['🎬', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<AgeGatedLayout
  title="Movies"
  description="Film diary — tracked via Trakt"
  contentLabel="Films"
  declinePath="/library/"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-12"
  >
    <!-- Breadcrumb -->
    <a
      href="/library"
      class="inline-flex items-center gap-1.5
        text-xs text-white/20
        hover:text-white/40 transition-colors mb-8"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path d="M15 19l-7-7 7-7" />
      </svg>
      Library Drive
    </a>

    <!-- Header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-medium text-emerald-400 mb-4">
        DISCOVER
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
          <span class="text-xl">🎬</span>
        </div>
        <h1 class="text-4xl font-bold text-white uppercase tracking-tighter" style="font-family: 'Outfit', sans-serif;">Movies</h1>
      </div>
      <p class="text-white/40">Film diary and watchlists — synced automatically.</p>
    </div>

    {!hasData && (
      <EmptyState
        emoji="🎬"
        title="Movies not loaded yet"
        message="Trakt history loads from CI once `TRAKT_*` env vars are set. See `.env.example` for the list."
      />
    )}

    <!-- Quick Navigation -->
    <div class="flex flex-wrap gap-2 mb-12">
      <a
        href="/library/movies-watched"
        class="text-[10px] px-4 py-2 rounded-full
          bg-emerald-500/10 text-emerald-400
          border border-emerald-500/20
          hover:bg-emerald-500/20
          transition-all font-bold
          uppercase tracking-widest"
      >
        History ({movieCount})
      </a>
      <a
        href="/library/movies-rated"
        class="text-[10px] px-4 py-2 rounded-full
          bg-amber-500/10 text-amber-400
          border border-amber-500/20
          hover:bg-amber-500/20
          transition-all font-bold
          uppercase tracking-widest"
      >
        Ranked
      </a>
      <a
        href="/library/movies-watchlist"
        class="text-[10px] px-4 py-2 rounded-full
          bg-rose-500/10 text-rose-400
          border border-rose-500/20
          hover:bg-rose-500/20
          transition-all font-bold
          uppercase tracking-widest"
      >
        Queue ({watchlist.length})
      </a>
    </div>

    <!-- Stats Grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16"
    >
      {[
        {
          label: 'Films Logged',
          value: movieCount,
          color: 'text-emerald-400',
        },
        {
          label: 'Mean Rating',
          value: avgMovieRating,
          color: 'text-amber-400',
        },
        {
          label: 'Plan to Watch',
          value: watchlist.length,
          color: 'text-rose-400',
        },
        {
          label: 'Top Genre',
          value: topGenres[0] || 'N/A',
          color: 'text-sky-400',
        },
      ].map((stat) => (
        <div
          class="p-5 glass rounded-2xl
            border border-white/5 text-center"
        >
          <div
            class={`text-3xl font-black ${stat.color} truncate`}
            style="font-family: 'Outfit', sans-serif;"
          >
            {stat.value}
          </div>
          <div
            class="text-[9px] text-white/20
              uppercase tracking-[0.2em] mt-1
              font-bold"
          >
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- ═══ RECENTLY WATCHED ═══ -->
    <section class="mb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-bold text-white relative inline-block uppercase tracking-tight">
          Recently Watched
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
        </h2>
        <a href="/library/movies-watched" class="text-[10px] uppercase tracking-widest text-white/20 hover:text-emerald-400 transition-colors font-bold">
          View All History →
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
        {recentMovies.map((movie, i) => {
          const vis = getVisuals(movie.title);
          return (
            <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 40}ms`}>
              <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                
                {movie.posterUrl ? (
                  <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                    <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                  </div>
                )}

                {movie.rating && (
                  <div class="absolute top-2 right-2 z-20 bg-black/60 backdrop-blur-md rounded-full px-2 py-0.5 border border-white/10">
                    <span class="text-[10px] font-bold text-emerald-400">{movie.rating}</span>
                  </div>
                )}
              </div>

              <div class="px-3 pb-4">
                <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-emerald-400 transition-colors">
                  {movie.title}
                </h3>
                <p class="text-[10px] text-white/30 truncate mt-0.5">
                  {movie.year} · {(movie.genres || [])[0]}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ═══ TOP RATED ═══ -->
    {topRatedMovies.length > 0 && (
      <section class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl font-bold text-white relative inline-block uppercase tracking-tight">
            Top Rated
            <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-amber-400 to-transparent rounded-full"></span>
          </h2>
          <a href="/library/movies-rated" class="text-[10px] uppercase tracking-widest text-white/20 hover:text-amber-400 transition-colors font-bold">
            View Ranking →
          </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {topRatedMovies.map((movie, i) => {
            const vis = getVisuals(movie.title);
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-amber-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 40}ms`}>
                <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                  
                  {movie.posterUrl ? (
                    <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                      <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                    </div>
                  )}

                  <div class="absolute top-2 right-2 z-20 bg-amber-500/20 backdrop-blur-md rounded-full px-2 py-0.5 border border-amber-500/30">
                    <span class="text-[10px] font-black text-amber-400">{movie.rating}</span>
                  </div>
                </div>

                <div class="px-3 pb-4">
                  <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-amber-400 transition-colors">
                    {movie.title}
                  </h3>
                  <p class="text-[10px] text-white/30 truncate mt-0.5">
                    {movie.year} · {(movie.genres || [])[0]}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Trakt Profile Link -->
    <div class="mt-20 p-6 rounded-2xl bg-gradient-to-br from-red-500/5 to-rose-500/5 border border-red-500/10 text-center flex flex-col items-center">
      <div class="h-12 w-12 rounded-full bg-red-500/10 text-red-400 flex items-center justify-center text-xl mb-4">
        📽️
      </div>
      <h3 class="text-lg font-bold text-white mb-2">Complete Profile</h3>
      <p class="text-sm text-white/40 mb-6 max-w-md">
        For the complete, unfiltered history of everything I've watched, rated, and reviewed.
      </p>
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500/10 text-red-400 font-semibold text-sm hover:bg-red-500/20 hover:scale-105 transition-all outline-none focus:ring-2 focus:ring-red-500/50">
        View Trakt Profile
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</AgeGatedLayout>
