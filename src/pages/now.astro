---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<BaseLayout
	title="Now — Chirag Singhal"
	description="What I'm currently focused on. A nownownow.com-style page."
>
	<div class="page">
		<aside><Sidebar /></aside>
		<section>
			<h1>Now</h1>
			<p class="muted">Last updated: TBD</p>
			<p>
				This is a <a href="https://nownownow.com" rel="noopener">/now</a>
				page — what I'm currently focused on.
			</p>
			<p><em>Stub. Coming soon.</em></p>
		</section>
	</div>
</BaseLayout>

<style>
	.page {
		max-width: 70rem;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: 3rem;
	}
	@media (max-width: 720px) {
		.page { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 1rem; }
	}
	h1 { font-size: 2rem; margin: 0 0 0.5rem; letter-spacing: -0.01em; }
	.muted { color: var(--color-muted, #9b9ba3); margin: 0 0 1.5rem; }
</style>
