---
/**
 * All Tracked Shows — Full history of TV Shows
 */
import Layout from '../../layouts/Layout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let shows: any[] = [];

try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/movies.json'),
    'utf-8',
  );
  const db = JSON.parse(raw);
  shows = db.shows || [];
} catch {
  console.warn('[Shows] movies.json not found.');
}

const totalEpisodes = shows.reduce((acc, s) => acc + (s.episodesWatched || 0), 0);
const sortedByDate = [...shows].sort(
  (a: any, b: any) =>
    new Date(b.watchedAt || 0).getTime() - new Date(a.watchedAt || 0).getTime(),
);

const fallbackGradients = [
  'linear-gradient(135deg, #0c1445, #1a237e)',
  'linear-gradient(135deg, #1b3a2d, #2e7d32)',
  'linear-gradient(135deg, #4a148c, #e91e63)',
  'linear-gradient(135deg, #795548, #d7ccc8)',
  'linear-gradient(135deg, #1e3a5f, #0f4c75)',
  'linear-gradient(135deg, #bf360c, #e65100)',
];
const fallbackEmojis = ['📺', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout
  title="All Tracked Shows"
  description="Complete TV show tracking history"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-12"
  >
    <!-- Breadcrumb -->
    <div class="flex items-center gap-1.5
      text-xs text-white/20 mb-8">
      <a
        href="/library"
        class="hover:text-white/40 transition-colors"
      >Library</a>
      <span>/</span>
      <a
        href="/library/shows"
        class="hover:text-white/40 transition-colors"
      >TV Shows</a>
      <span>/</span>
      <span class="text-white/40">History</span>
    </div>

    <!-- Header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        HISTORY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">📺</span>
        </div>
        <h1 class="text-4xl font-bold text-white uppercase tracking-tighter" style="font-family: 'Outfit', sans-serif;">Tracked Shows</h1>
      </div>
      <p class="text-white/40">{shows.length} shows tracked · {totalEpisodes} episodes watched.</p>
    </div>

    <!-- Grid Layout -->
    {sortedByDate.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
        {sortedByDate.map((show, i) => {
          const vis = getVisuals(show.title);
          return (
            <div class="glass rounded-2xl border border-white/5 hover:border-violet-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                
                {show.posterUrl ? (
                  <img src={show.posterUrl} alt={show.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                    <span class="drop-shadow-lg opacity-50">{vis.emoji}</span>
                  </div>
                )}

                <!-- Episode Badge -->
                <div class="absolute top-2 right-2 z-20 bg-black/60 backdrop-blur-md rounded-full px-2 py-0.5 border border-white/10">
                  <span class="text-[10px] font-bold text-violet-400">
                    {show.episodesWatched || 0} <span class="text-[8px] text-white/30 uppercase">eps</span>
                  </span>
                </div>
              </div>

              <div class="px-3 pb-4">
                <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-violet-400 transition-colors">
                  {show.title}
                </h3>
                <p class="text-[10px] text-white/30 truncate mt-0.5">
                  {show.year} · {(show.genres || [])[0]}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div
        class="text-center py-20 text-white/20
          text-sm glass rounded-2xl border border-white/5"
      >
        No shows tracked yet. Run
        <code class="text-violet-400/50 mx-1">
          pnpm run fetch-data
        </code>
        to sync.
      </div>
    )}

    <!-- Trakt Profile Link -->
    <div class="mt-20 py-8 border-t border-white/5 text-center">
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-red-500/10 text-red-500 hover:text-red-400 hover:bg-red-500/20 font-bold text-xs uppercase tracking-widest transition-all">
        Full History on Trakt
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
