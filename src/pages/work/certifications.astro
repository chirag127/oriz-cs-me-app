---
import { honors, certifications } from '../../content';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
---

<Layout title="Certifications & Honors" description="Professional certifications and honors of Chirag Singhal">
  <CommandPalette />
  <main class="relative mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <div class="absolute top-0 right-0 w-96 h-96 bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-64 h-64 bg-violet-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Work</a>

    <!-- Page Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CREDENTIALS
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">Certifications & Honors</h1>
      <p class="text-base text-white/40">{honors.length} honors and {certifications.length} professional certifications</p>
    </div>

    <!-- Honors Grid -->
    <div class="mb-12 reveal">
      <div class="flex items-center gap-3 mb-6">
        <svg class="h-5 w-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <h2 class="text-xl font-bold text-white">Honors & Awards</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {honors.map((honor) => (
          <div class="glass p-6 hover:border-amber-500/15 transition-all duration-300 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-amber-500/5 rounded-full blur-[60px] pointer-events-none"></div>
            <div class="relative flex items-start gap-4">
              <div class="h-12 w-12 rounded-xl bg-amber-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
              </div>
              <div class="flex-1">
                <h3 class="text-base font-semibold text-white mb-1">{honor.title}</h3>
                <p class="text-sm text-white/50 mb-2">{honor.description}</p>
                <div class="flex items-center gap-2 text-xs text-white/30">
                  <span>{honor.location}</span>
                  <span>·</span>
                  <span>{honor.year}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Professional Certifications -->
    <div class="mb-12 reveal">
      <div class="flex items-center gap-3 mb-6">
        <svg class="h-5 w-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
        <h2 class="text-xl font-bold text-white">Professional Certifications</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {certifications.map((cert) => (
          <div class="glass p-6 hover:border-teal-500/15 transition-all duration-300 flex items-center gap-4">
            <div class="h-12 w-12 rounded-xl bg-teal-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-white">{cert}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Summary Stats -->
    <div class="glass p-8 reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-teal-400">{honors.length}</div>
          <div class="text-xs text-white/40 mt-1">Honors</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-teal-400">{certifications.length}</div>
          <div class="text-xs text-white/40 mt-1">Certifications</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-teal-400">8.81</div>
          <div class="text-xs text-white/40 mt-1">CGPA</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-teal-400">AIR 11870</div>
          <div class="text-xs text-white/40 mt-1">JEE Advanced</div>
        </div>
      </div>
    </div>
  </main>
</Layout>
