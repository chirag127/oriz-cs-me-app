---
import AgeGatedLayout from '../../layouts/AgeGatedLayout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: { manga: [] } };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Manga] anime.json not found.');
}

const manga = db.anime?.manga || db.manga || [];
const reading = manga.filter((m: any) => m.status === 'CURRENT');
const completed = manga.filter((m: any) => m.status === 'COMPLETED');
const planning = manga.filter((m: any) => m.status === 'PLANNING');

function scoreColor(score: number | null): string {
  if (!score) return '#52525b';
  if (score >= 8) return '#34d399';
  if (score >= 6) return '#2dd4bf';
  return '#fbbf24';
}

const fallbackGradients = [
  'linear-gradient(135deg, #4c1d95, #5b21b6)',
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #78350f, #92400e)',
  'linear-gradient(135deg, #1e3a8a, #1e40af)',
  'linear-gradient(135deg, #831843, #9d174d)',
  'linear-gradient(135deg, #1e293b, #0f172a)',
];
const fallbackEmojis = ['📕', '📖', '📘', '📕', '📗', '📙', '🔖', '📓'];

function getVisuals(title: string | undefined | null) {
  const safeTitle = title || 'Untitled';
  const idx = [...safeTitle].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<AgeGatedLayout contentLabel="Anime" declinePath="/library/" title="Manga" description="Chirag Singhal's manga list - from AniList">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">📕</span>
        </div>
        <h1 class="text-4xl font-bold text-white uppercase tracking-tighter" style="font-family: 'Outfit', sans-serif;">Manga</h1>
      </div>
      <p class="text-white/40">Reading list syncing from AniList.</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 mb-16">
      {[
        { label: 'Reading', value: reading.length, color: 'text-sky-400' },
        { label: 'Completed', value: completed.length, color: 'text-emerald-400' },
        { label: 'Wishlist', value: planning.length, color: 'text-rose-400' }
      ].map(stat => (
        <div class="p-5 glass rounded-2xl border border-white/5 text-center">
          <div class={`text-2xl font-black ${stat.color}`} style="font-family: 'Outfit', sans-serif;">{stat.value}</div>
          <div class="text-[9px] text-white/20 uppercase tracking-widest mt-1 font-bold">{stat.label}</div>
        </div>
      ))}
    </div>

    {reading.length > 0 && (
      <section class="mb-20">
        <h2 class="text-xl font-bold text-white mb-8 relative inline-block uppercase tracking-tight">
          Currently Reading
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {reading.map((entry: any, i: number) => {
            const vis = getVisuals(entry.title);
            const progress = entry.chapters ? Math.round((entry.progress / entry.chapters) * 100) : 0;
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-sky-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
                <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                  {entry.coverUrl ? (
                    <img src={entry.coverUrl} alt={entry.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                      <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                    </div>
                  )}
                  {progress > 0 && (
                    <div class="absolute bottom-0 left-0 right-0 h-1 bg-black/40 z-20">
                      <div class="h-full bg-sky-400" style={`width: ${progress}%`}></div>
                    </div>
                  )}
                </div>
                <div class="px-3 pb-4">
                  <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-sky-400 transition-colors">{entry.title}</h3>
                  <p class="text-[10px] text-white/30 truncate mt-0.5 font-medium">{entry.progress || 0} ch</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    {completed.length > 0 && (
      <section class="mb-20">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-bold text-white mb-8 relative inline-block uppercase tracking-tight">
          Completed
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {completed.map((entry: any, i: number) => {
            const vis = getVisuals(entry.title);
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
                <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                  {entry.coverUrl ? (
                    <img src={entry.coverUrl} alt={entry.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                      <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                    </div>
                  )}
                  {entry.score && (
                    <div class="absolute top-2 right-2 z-20 bg-black/60 backdrop-blur-md rounded-full px-2 py-0.5 border border-white/10 font-bold text-[9px]" style={`color: ${scoreColor(entry.score)}`}>
                      {entry.score}
                    </div>
                  )}
                </div>
                <div class="px-3 pb-4">
                  <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-emerald-400 transition-colors">{entry.title}</h3>
                  <p class="text-[10px] text-white/30 truncate mt-0.5 font-medium">{entry.chapters || '?'} ch</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    {planning.length > 0 && (
      <section class="mb-20">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-bold text-white mb-8 relative inline-block uppercase tracking-tight">
          Wishlist
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-rose-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {planning.map((entry: any, i: number) => {
            const vis = getVisuals(entry.title);
            return (
              <div class="glass rounded-2xl border border-white/5 opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
                <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                  {entry.coverUrl ? (
                    <img src={entry.coverUrl} alt={entry.title} class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                      <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                    </div>
                  )}
                </div>
                <div class="px-3 pb-4">
                  <h3 class="text-xs font-bold text-white/60 truncate">{entry.title}</h3>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    {manga.length === 0 && (
      <div class="glass p-12 text-center rounded-2xl border border-white/5"><p class="text-white/30">No manga data found. Run fetch-data first.</p></div>
    )}
  </main>
</AgeGatedLayout>
