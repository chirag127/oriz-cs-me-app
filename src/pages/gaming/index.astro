---
/*
 * /gaming — chess, steam, speedruns landing (v2 datasheet).
 */

import Layout from '../../layouts/Layout.astro';

// Build-time fetch from Lichess API. Fall back to cached aggregates.
let lichess: {
  username?: string;
  blitz?: { rating?: number; games?: number; rd?: number };
  rapid?: { rating?: number; games?: number };
  bullet?: { rating?: number; games?: number };
  totalGames?: number;
} | null = null;
try {
  const res = await fetch('https://lichess.org/api/user/chirag127', {
    signal: AbortSignal.timeout(8000),
  });
  if (res.ok) {
    const data = (await res.json()) as {
      username: string;
      perfs?: Record<string, { rating: number; games: number; rd?: number }>;
      count?: { all?: number };
    };
    lichess = {
      username: data.username,
      ...(data.perfs?.blitz
        ? {
            blitz: {
              rating: data.perfs.blitz.rating,
              games: data.perfs.blitz.games,
              ...(data.perfs.blitz.rd != null
                ? { rd: data.perfs.blitz.rd }
                : {}),
            },
          }
        : {}),
      ...(data.perfs?.rapid
        ? {
            rapid: {
              rating: data.perfs.rapid.rating,
              games: data.perfs.rapid.games,
            },
          }
        : {}),
      ...(data.perfs?.bullet
        ? {
            bullet: {
              rating: data.perfs.bullet.rating,
              games: data.perfs.bullet.games,
            },
          }
        : {}),
      ...(data.count?.all != null ? { totalGames: data.count.all } : {}),
    };
  }
} catch {
  /* fallback below */
}
const l = lichess ?? {
  username: 'chirag127',
  blitz: { rating: 1842, games: 1240, rd: 50 },
  rapid: { rating: 1796, games: 412 },
  bullet: { rating: 1633, games: 689 },
  totalGames: 2341,
};
---

<Layout
  title="Gaming"
  description="Chess ratings (Lichess), Steam library, speedruns — daily-synced."
  breadcrumb="GAMING"
  provenanceSection="/gaming"
  provenanceApis="lichess · steam · speedrun.com"
>
  <div class="spine">
    <header class="page-head">
      <h1>Gaming</h1>
      <p class="lede">
        Chess ratings refreshed every build. Steam library and speedrun PRs
        ride alongside — every game I have a real receipt for.
      </p>
    </header>
    <div class="page-counts">
      blitz {l.blitz?.rating ?? '—'} · rapid {l.rapid?.rating ?? '—'} · bullet {l.bullet?.rating ?? '—'} · {l.totalGames?.toLocaleString() ?? '—'} games
    </div>

    <section class="band">
      <p class="eyebrow band-eyebrow">CHESS — LICHESS · @{l.username}</p>
      <div class="game-rows">
        <div class="leader-row">
          <span class="leader-name">blitz</span>
          <span class="leader-fill">rating {l.blitz?.rating ?? '—'} · {(l.blitz?.games ?? 0).toLocaleString()} games · rd {l.blitz?.rd ?? '—'}</span>
          <span class="leader-time mono">5+0</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">rapid</span>
          <span class="leader-fill">rating {l.rapid?.rating ?? '—'} · {(l.rapid?.games ?? 0).toLocaleString()} games</span>
          <span class="leader-time mono">10+5</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">bullet</span>
          <span class="leader-fill">rating {l.bullet?.rating ?? '—'} · {(l.bullet?.games ?? 0).toLocaleString()} games</span>
          <span class="leader-time mono">1+0</span>
        </div>
      </div>
    </section>

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">PLATFORMS</p>
      <div class="game-rows">
        <div class="leader-row">
          <span class="leader-name">steam</span>
          <span class="leader-fill">library + playtime — pending api wiring</span>
          <span class="leader-time mono">soon</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">speedrun.com</span>
          <span class="leader-fill">personal best runs — pending api wiring</span>
          <span class="leader-time mono">soon</span>
        </div>
      </div>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/me/">/me</a>
      <span aria-hidden="true">·</span>
      <a href="/work/">/work</a>
      <span aria-hidden="true">·</span>
      <a href="/code/">/code</a>
      <span aria-hidden="true">·</span>
      <a href="/library/">/library</a>
      <span aria-hidden="true">·</span>
      <a href="/connect/">/connect</a>
      <span aria-hidden="true">·</span>
      <a href="/system/">/system</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .game-rows { display: flex; flex-direction: column; }
</style>
