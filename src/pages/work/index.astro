---
/*
 * /work — career, skills, projects landing page (v2 datasheet).
 *
 * Per the v2 brief: per-section provenance, counts in mono, leader-dotted
 * ranked tables. NO grids of cover images, NO carousels, NO ambient blur.
 */

import {
  certifications,
  education,
  experience,
  honors,
  projects,
  skills,
} from '../../content';
import Layout from '../../layouts/Layout.astro';

const featured = projects.filter((p) => p.featured);
const totalSkills = skills.reduce((sum, s) => sum + s.items.length, 0);
const totalCredentials =
  education.length + honors.length + certifications.length;
const top = experience[0];
const topTitle = top?.title ?? 'Software Engineer';
const topCompany = top?.company ?? 'TCS';
const topDate = top?.date ?? '2026';
---

<Layout
  title="Work"
  description="Career timeline, skills, projects, education — Chirag Singhal"
  breadcrumb="WORK"
  provenanceSection="/work"
  provenanceApis="github · linkedin · authored"
>
  <div class="spine">
    <header class="page-head">
      <h1>Work</h1>
      <p class="lede">
        {experience.length} companies · {projects.length} projects · {totalSkills} skills · {totalCredentials} credentials.
        The full career timeline + every project that ships at least once.
      </p>
    </header>
    <div class="page-counts">
      {topTitle} · {topCompany} · {topDate}
    </div>

    <!-- Career timeline -->
    <section class="band">
      <p class="eyebrow band-eyebrow">CAREER</p>
      <div class="timeline">
        {experience.map((role) => (
          <div class="timeline-row">
            <span class="timeline-rule" aria-hidden="true">─</span>
            <span class="timeline-year">{(role.date.split(' ')[0] ?? '').slice(0, 4)}</span>
            <span class="timeline-rule" aria-hidden="true">──</span>
            <span class="timeline-label">
              {role.title}, {role.company}
              <span class="timeline-meta mono">· {role.location}</span>
            </span>
          </div>
        ))}
      </div>
      <p class="band-trail mono">
        <a href="/work/career/">expanded timeline &rarr;</a>
      </p>
    </section>

    <hr class="hairline" />

    <!-- Featured projects -->
    <section class="band">
      <p class="eyebrow band-eyebrow">FEATURED PROJECTS — {featured.length}</p>
      <table class="ranked-table">
        <thead>
          <tr>
            <th class="rank">#</th>
            <th>name</th>
            <th>stack</th>
            <th class="right">link</th>
          </tr>
        </thead>
        <tbody>
          {featured.slice(0, 10).map((project, i) => {
            const linkHref = project.link.startsWith('http')
              ? project.link
              : `https://${project.link}`;
            const stack = project.tech.split(', ').slice(0, 2).join(' · ');
            const rank = String(i + 1).padStart(2, '0');
            return (
              <tr>
                <td class="rank">{rank}</td>
                <td>{project.name}</td>
                <td>{stack}</td>
                <td class="right">
                  <a href={linkHref} target="_blank" rel="noopener noreferrer">
                    {project.link.replace(/^https?:\/\//, '').replace(/\/$/, '')}
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <p class="band-trail mono">
        <a href="/work/projects/">all {projects.length} projects &rarr;</a>
      </p>
    </section>

    <hr class="hairline" />

    <!-- Skills (collapsed mono ledger) -->
    <section class="band">
      <p class="eyebrow band-eyebrow">SKILLS — {skills.length} CATEGORIES, {totalSkills} ITEMS</p>
      <div class="skill-rows">
        {skills.map((cat) => (
          <div class="leader-row">
            <span class="leader-name">{cat.category.toLowerCase()}</span>
            <span class="leader-fill">{cat.items.join(' · ')}</span>
            <span class="leader-time mono">{cat.items.length}</span>
          </div>
        ))}
      </div>
      <p class="band-trail mono">
        <a href="/work/skills/">skills detail &rarr;</a>
      </p>
    </section>

    <hr class="hairline" />

    <!-- Sub-pages -->
    <nav class="section-nav" aria-label="Section navigation">
      <a href="/work/career/">/work/career</a>
      <span aria-hidden="true">·</span>
      <a href="/work/projects/">/work/projects</a>
      <span aria-hidden="true">·</span>
      <a href="/work/skills/">/work/skills</a>
      <span aria-hidden="true">·</span>
      <a href="/work/education/">/work/education</a>
      <span aria-hidden="true">·</span>
      <a href="/work/certifications/">/work/certifications</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .timeline,
  .skill-rows {
    display: flex;
    flex-direction: column;
  }
  .timeline-meta {
    color: var(--ink-soft);
    font-size: 0.8125rem;
    margin-left: 0.5ch;
  }
  .ranked-table a {
    color: var(--archival);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .ranked-table a:hover {
    text-decoration-color: var(--archival);
  }
  .band-trail {
    margin: 1rem 0 0;
    font-size: 0.8125rem;
    color: var(--ink-soft);
  }
  .band-trail a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .band-trail a:hover {
    color: var(--archival);
    text-decoration-color: var(--archival);
  }
</style>
