---
/*
 * /library — books, films, anime, music landing (v2 datasheet).
 *
 * Per the v2 brief: per-section provenance, counts in mono, leader-dotted
 * ranked tables. NO grids of cover images, NO carousels.
 *
 * Films + anime sub-pages are AGE-GATED at the route level — see
 * /library/movies-rated.astro etc which use AgeGatedLayout when adult-flagged
 * rows are present.
 */

import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';

interface JsonShape {
  [k: string]: unknown;
}
async function readJson(rel: string): Promise<JsonShape> {
  try {
    const txt = await fs.readFile(
      path.resolve(`./src/content/generated/${rel}`),
      'utf-8',
    );
    return JSON.parse(txt) as JsonShape;
  } catch {
    return {};
  }
}

const [moviesDb, booksDb, musicDb, animeDb] = await Promise.all([
  readJson('movies.json'),
  readJson('books.json'),
  readJson('music.json'),
  readJson('anime.json'),
]);

const moviesWatched = (moviesDb.watched as unknown[] | undefined)?.length ?? 0;
const moviesRated = (moviesDb.rated as unknown[] | undefined)?.length ?? 0;
const moviesWatchlist =
  (moviesDb.watchlist as unknown[] | undefined)?.length ?? 0;

const booksRead = (booksDb.read as unknown[] | undefined)?.length ?? 0;
const booksReading = (booksDb.reading as unknown[] | undefined)?.length ?? 0;
const booksQueued = (booksDb.wantToRead as unknown[] | undefined)?.length ?? 0;

const lastfm = musicDb.lastfm as
  | { stats?: { playcount?: number }; topArtists?: unknown[] }
  | undefined;
const musicScrobbles = lastfm?.stats?.playcount ?? 0;
const musicArtists = lastfm?.topArtists?.length ?? 0;

const anime = animeDb.anime as
  | { watching?: unknown[]; completed?: unknown[]; planToWatch?: unknown[] }
  | undefined;
const animeWatching = anime?.watching?.length ?? 0;
const animeCompleted = anime?.completed?.length ?? 0;
const animePtw = anime?.planToWatch?.length ?? 0;

const showsCount = (moviesDb.shows as unknown[] | undefined)?.length ?? 0;

const totalCount = moviesWatched + booksRead + animeCompleted;
---

<Layout
  title="Library"
  description="Films, books, anime, music — daily-synced from Letterboxd, Trakt, AniList, Last.fm, OpenLibrary."
  breadcrumb="LIBRARY"
  provenanceSection="/library"
  provenanceApis="letterboxd · trakt · anilist · last.fm · openlibrary"
>
  <div class="spine">
    <header class="page-head">
      <h1>Library</h1>
      <p class="lede">
        Every film logged, book finished, episode watched, scrobble counted.
        Five upstream APIs, one ledger.
      </p>
    </header>
    <div class="page-counts">
      {moviesWatched.toLocaleString()} films · {booksRead.toLocaleString()} books · {animeCompleted.toLocaleString()} anime · {musicScrobbles.toLocaleString()} scrobbles
    </div>

    <!-- Counts ledger -->
    <section class="band">
      <p class="eyebrow band-eyebrow">SOURCES</p>
      <div class="lib-rows">
        <div class="leader-row">
          <span class="leader-name">letterboxd</span>
          <span class="leader-fill">{moviesWatched.toLocaleString()} films watched · {moviesRated.toLocaleString()} rated · {moviesWatchlist.toLocaleString()} queued</span>
          <span class="leader-time mono">films</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">openlibrary</span>
          <span class="leader-fill">{booksRead.toLocaleString()} read · {booksReading.toLocaleString()} reading · {booksQueued.toLocaleString()} queued</span>
          <span class="leader-time mono">books</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">anilist</span>
          <span class="leader-fill">{animeCompleted.toLocaleString()} completed · {animeWatching.toLocaleString()} watching · {animePtw.toLocaleString()} ptw</span>
          <span class="leader-time mono">anime</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">last.fm</span>
          <span class="leader-fill">{musicScrobbles.toLocaleString()} scrobbles · {musicArtists.toLocaleString()} top artists</span>
          <span class="leader-time mono">music</span>
        </div>
      </div>
    </section>

    <hr class="hairline" />

    <!-- Sub-pages — every detail page lives behind one of these. -->
    <section class="band">
      <p class="eyebrow band-eyebrow">SUB-PAGES — {totalCount.toLocaleString()} ENTRIES</p>
      <div class="lib-rows">
        <a class="leader-row me-link" href="/library/movies/">
          <span class="leader-name">/library/movies</span>
          <span class="leader-fill">letterboxd films, ratings, watchlist</span>
          <span class="leader-time mono">{moviesWatched.toLocaleString()}</span>
        </a>
        <a class="leader-row me-link" href="/library/shows/">
          <span class="leader-name">/library/shows</span>
          <span class="leader-fill">tv shows + episodes (trakt)</span>
          <span class="leader-time mono">{showsCount.toLocaleString()}</span>
        </a>
        <a class="leader-row me-link" href="/library/books/">
          <span class="leader-name">/library/books</span>
          <span class="leader-fill">openlibrary — read, reading, queued</span>
          <span class="leader-time mono">{booksRead.toLocaleString()}</span>
        </a>
        <a class="leader-row me-link" href="/library/anime/">
          <span class="leader-name">/library/anime</span>
          <span class="leader-fill">anilist tracking — 18+ entries gated</span>
          <span class="leader-time mono">{animeCompleted.toLocaleString()}</span>
        </a>
        <a class="leader-row me-link" href="/library/manga/">
          <span class="leader-name">/library/manga</span>
          <span class="leader-fill">anilist + mangadex reading</span>
          <span class="leader-time mono">manga</span>
        </a>
        <a class="leader-row me-link" href="/library/music/">
          <span class="leader-name">/library/music</span>
          <span class="leader-fill">last.fm scrobbles + top artists</span>
          <span class="leader-time mono">{musicScrobbles.toLocaleString()}</span>
        </a>
        <a class="leader-row me-link" href="/library/podcasts/">
          <span class="leader-name">/library/podcasts</span>
          <span class="leader-fill">listened episodes</span>
          <span class="leader-time mono">podcasts</span>
        </a>
        <a class="leader-row me-link" href="/library/videos/">
          <span class="leader-name">/library/videos</span>
          <span class="leader-fill">youtube + bilibili + nebula</span>
          <span class="leader-time mono">videos</span>
        </a>
      </div>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/me/">/me</a>
      <span aria-hidden="true">·</span>
      <a href="/work/">/work</a>
      <span aria-hidden="true">·</span>
      <a href="/code/">/code</a>
      <span aria-hidden="true">·</span>
      <a href="/gaming/">/gaming</a>
      <span aria-hidden="true">·</span>
      <a href="/connect/">/connect</a>
      <span aria-hidden="true">·</span>
      <a href="/system/">/system</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .lib-rows { display: flex; flex-direction: column; }
  .me-link:hover .leader-name,
  .me-link:hover .leader-fill,
  .me-link:hover .leader-time { color: var(--archival); }
  .me-link:hover { background: var(--archival-wash); }
</style>
