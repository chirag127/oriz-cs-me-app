---
/*
 * CommandPalette — ⌘K trigger for v2 datasheet.
 *
 * Restyled from the v1 glassmorph version. Datasheet white card with a
 * hairline border, no blur, no shadow. The palette opens via the Header's
 * `[data-cmdk-open]` button and the Cmd/Ctrl+K shortcut wired in Header.astro.
 *
 * Static index of every section + every sub-page. No filtering API — the
 * input client-side hides non-matching rows.
 */
---

<div
  id="command-palette"
  class="hidden palette-root"
  role="dialog"
  aria-modal="true"
  aria-label="Command palette"
>
  <div class="palette-backdrop" data-cmdk-close></div>
  <div class="palette-card">
    <div class="palette-input-row">
      <span class="palette-prompt mono" aria-hidden="true">⌘</span>
      <input
        type="text"
        id="command-input"
        placeholder="search…"
        autocomplete="off"
      />
      <kbd class="mono">ESC</kbd>
    </div>
    <hr class="hairline" />
    <div id="command-results" class="palette-results">
      <p class="palette-eyebrow mono">SECTIONS</p>
      <a href="/" class="palette-row">
        <span class="palette-row-key mono">/</span>
        <span class="palette-row-name">home</span>
        <span class="palette-row-desc">datasheet hub</span>
      </a>
      <a href="/me/" class="palette-row">
        <span class="palette-row-key mono">/me</span>
        <span class="palette-row-name">about</span>
        <span class="palette-row-desc">numeric aggregates</span>
      </a>
      <a href="/work/" class="palette-row">
        <span class="palette-row-key mono">/work</span>
        <span class="palette-row-name">career &amp; projects</span>
        <span class="palette-row-desc">resume + projects</span>
      </a>
      <a href="/code/" class="palette-row">
        <span class="palette-row-key mono">/code</span>
        <span class="palette-row-name">code</span>
        <span class="palette-row-desc">repos · packages · stats</span>
      </a>
      <a href="/library/" class="palette-row">
        <span class="palette-row-key mono">/library</span>
        <span class="palette-row-name">library</span>
        <span class="palette-row-desc">films · books · music · anime</span>
      </a>
      <a href="/gaming/" class="palette-row">
        <span class="palette-row-key mono">/gaming</span>
        <span class="palette-row-name">gaming</span>
        <span class="palette-row-desc">chess · steam · speedruns</span>
      </a>
      <a href="/connect/" class="palette-row">
        <span class="palette-row-key mono">/connect</span>
        <span class="palette-row-name">connect</span>
        <span class="palette-row-desc">contact · profiles</span>
      </a>
      <a href="/system/" class="palette-row">
        <span class="palette-row-key mono">/system</span>
        <span class="palette-row-name">system</span>
        <span class="palette-row-desc">build manifest</span>
      </a>
      <a href="/status/" class="palette-row">
        <span class="palette-row-key mono">/status</span>
        <span class="palette-row-name">status</span>
        <span class="palette-row-desc">ingester health</span>
      </a>

      <p class="palette-eyebrow mono">LIBRARY</p>
      <a href="/library/movies/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/library/movies</span>
        <span class="palette-row-desc">films watched, rated</span>
      </a>
      <a href="/library/books/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/library/books</span>
        <span class="palette-row-desc">books read, queued</span>
      </a>
      <a href="/library/music/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/library/music</span>
        <span class="palette-row-desc">last.fm scrobbles</span>
      </a>
      <a href="/library/anime/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/library/anime</span>
        <span class="palette-row-desc">anilist tracking</span>
      </a>
      <a href="/library/manga/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/library/manga</span>
        <span class="palette-row-desc">manga reading</span>
      </a>

      <p class="palette-eyebrow mono">WORK</p>
      <a href="/work/career/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/work/career</span>
        <span class="palette-row-desc">timeline</span>
      </a>
      <a href="/work/projects/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/work/projects</span>
        <span class="palette-row-desc">open-source projects</span>
      </a>
      <a href="/work/skills/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/work/skills</span>
        <span class="palette-row-desc">technical skills</span>
      </a>
      <a href="/work/education/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/work/education</span>
        <span class="palette-row-desc">degrees + honors</span>
      </a>

      <p class="palette-eyebrow mono">CONNECT</p>
      <a href="/connect/contact/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/connect/contact</span>
        <span class="palette-row-desc">contact form</span>
      </a>
      <a href="/account/" class="palette-row palette-row-sub">
        <span class="palette-row-key mono">/account</span>
        <span class="palette-row-desc">sign in</span>
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var input = document.getElementById('command-input');
    var results = document.getElementById('command-results');
    var palette = document.getElementById('command-palette');

    function close() { if (palette) palette.classList.add('hidden'); }

    document.querySelectorAll('[data-cmdk-close]').forEach(function (el) {
      el.addEventListener('click', close);
    });

    if (input && results) {
      input.addEventListener('input', function (e) {
        var query = e.target.value.toLowerCase();
        results.querySelectorAll('a').forEach(function (link) {
          var text = link.textContent.toLowerCase();
          link.style.display = text.indexOf(query) >= 0 ? '' : 'none';
        });
      });
    }
  })();
</script>

<style>
  .palette-root {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }
  .palette-root.hidden { display: none; }
  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklab, var(--ink) 32%, transparent);
  }
  .palette-card {
    position: relative;
    width: min(640px, calc(100% - 2rem));
    background: var(--paper);
    border: 1px solid var(--rule);
    color: var(--ink);
    max-height: 70vh;
    display: flex;
    flex-direction: column;
  }
  .palette-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
  }
  .palette-prompt {
    color: var(--ink-soft);
    font-size: 14px;
  }
  #command-input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: none;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0;
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  #command-input::placeholder { color: var(--ink-soft); }
  .palette-input-row kbd {
    border: 1px solid var(--rule);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    background: var(--paper);
    border-radius: 0;
    letter-spacing: 0.06em;
  }
  .palette-results {
    overflow-y: auto;
    padding: 0.5rem 0.5rem 1rem;
  }
  .palette-eyebrow {
    margin: 0.875rem 0.5rem 0.375rem;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-soft);
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .palette-row {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.55rem 0.75rem;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.9375rem;
  }
  .palette-row:hover,
  .palette-row:focus-visible {
    background: var(--archival-wash);
    color: var(--archival);
    outline: none;
  }
  .palette-row-key {
    color: var(--ink-soft);
    font-size: 0.8125rem;
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .palette-row:hover .palette-row-key,
  .palette-row:focus-visible .palette-row-key { color: var(--archival); }
  .palette-row-name { color: inherit; }
  .palette-row-desc {
    color: var(--ink-soft);
    font-size: 0.8125rem;
    text-align: right;
    font-family: var(--font-mono);
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .palette-row-sub { padding-left: 1rem; }

  @media (max-width: 480px) {
    .palette-row {
      grid-template-columns: 1fr;
      gap: 0.125rem;
    }
    .palette-row-desc { text-align: left; }
  }
</style>
