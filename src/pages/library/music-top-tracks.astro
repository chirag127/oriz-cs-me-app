---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { lastfm: {}, listenbrainz: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/music.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Music Top Tracks] music.json not found.');
}

const topTracks = db.lastfm?.topTracks || [];
const lbTracks = db.listenbrainz?.topTracks || [];
const topAlbums = db.lastfm?.topAlbums || [];

const fallbackGradients = [
  'linear-gradient(135deg, #e11d48, #881337)',
  'linear-gradient(135deg, #1e3a5f, #7c3aed)',
  'linear-gradient(135deg, #d97706, #b91c1c)',
  'linear-gradient(135deg, #7c3aed, #db2777)',
  'linear-gradient(135deg, #0c4a6e, #1e40af)',
  'linear-gradient(135deg, #065f46, #047857)',
];
const fallbackEmojis = ['🎵', '🎶', '🎤', '🎧', '🎸', '🎹'];

function getVisuals(name: string) {
  if (!name)
    return { gradient: fallbackGradients[0], emoji: fallbackEmojis[0] };
  const idx = [...name].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Top Tracks" description="Chirag Singhal's most played tracks">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/music" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Music
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-teal-500/10 flex items-center justify-center">
          <span class="text-xl">🎵</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Top Tracks & Albums</h1>
      </div>
      <p class="text-white/40">Most played tracks and albums - weekly data.</p>
    </div>

    <!-- Top Tracks -->
    <section class="mb-16">
      <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
        Top Tracks (7 Days)
        <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-violet-400 to-transparent rounded-full"></span>
      </h2>
      {topTracks.length > 0 ? (
        <div class="space-y-2">
          {topTracks.map((track: any, i: number) => (
            <a href={track.url} target="_blank" rel="noopener noreferrer" class="glass p-4 flex items-center gap-4 hover:border-violet-500/15 transition-colors group rounded-2xl border border-white/5">
              <span class="text-sm font-bold text-teal-400 w-8 text-right">{i + 1}</span>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg shrink-0" style={`background: ${getVisuals(track.name).gradient}`}>
                {track.imageUrl ? (
                  <img src={track.imageUrl} alt={track.name} class="w-full h-full object-cover rounded-lg" />
                ) : (
                  <span>{getVisuals(track.name).emoji}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate group-hover:text-teal-400 transition-colors">{track.name}</h3>
                <p class="text-xs text-white/30 truncate">{track.artist}</p>
              </div>
              <span class="text-xs text-violet-400 font-medium shrink-0">{track.playcount} plays</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center rounded-2xl border border-white/5"><p class="text-white/30">No track data available.</p></div>
      )}
    </section>

    <!-- Top Albums -->
    {topAlbums.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Top Albums (7 Days)
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-violet-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
          {topAlbums.map((album: any, i: number) => {
            const vis = getVisuals(album.name);
            return (
            <a href={album.url} target="_blank" rel="noopener noreferrer" class="glass rounded-2xl border border-white/5 hover:border-teal-500/15 transition-all group cursor-default block" style={`animation-delay: ${i * 40}ms`}>
              <div class="aspect-square rounded-t-2xl mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
                {album.imageUrl ? (
                  <img src={album.imageUrl} alt={album.name} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <span class="drop-shadow-lg">{vis.emoji}</span>
                )}
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-xs font-semibold text-white truncate group-hover:text-teal-400 transition-colors">{album.name}</h3>
                <p class="text-[0.65rem] text-white/20 truncate">{album.artist} · {album.playcount} plays</p>
              </div>
            </a>
          )})}
        </div>
      </section>
    )}

    <!-- ListenBrainz Top Tracks -->
    {lbTracks.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          ListenBrainz - Top Tracks
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-violet-400 to-transparent rounded-full"></span>
        </h2>
        <div class="space-y-2">
          {lbTracks.map((track: any, i: number) => (
            <div class="glass p-4 flex items-center gap-4 rounded-2xl border border-white/5">
              <span class="text-sm font-bold text-violet-400 w-8 text-right">{i + 1}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate">{track.name}</h3>
                <p class="text-xs text-white/30 truncate">{track.artist}</p>
              </div>
              <span class="text-xs text-violet-400 font-medium shrink-0">{track.listenCount} listens</span>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
