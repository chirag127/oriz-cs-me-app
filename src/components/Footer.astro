---
/*
 * Footer — two-line mono block in `--ink-soft` 12px, datasheet white.
 *
 *   ── this page was built 2026-06-19T03:07Z from 41 APIs ────────────
 *   oriz/me · MIT · ₹0 to host · source on github · part of oriz.in
 *
 * The first line is the same provenance primitive as the header strip,
 * but for the BUILD (not the data sync — they are usually but not always
 * the same time). The second line is the colophon. NO newsletter, NO
 * social-icon strip, NO "made with love."
 */

interface Props {
  /** Override the source-API count (default 41 per the brief). */
  apiCount?: number | string;
}

const { apiCount = 41 } = Astro.props;

const deployTimeRaw =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString();
function toCompactIso(input: string): string {
  const date = new Date(input);
  if (Number.isNaN(date.getTime())) return input;
  const iso = date.toISOString();
  return `${iso.slice(0, 16)}Z`;
}
const builtAt = toCompactIso(deployTimeRaw);
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev';
---

<footer class="footer">
  <hr class="hairline" />
  <div class="spine footer-block">
    <p class="line mono">
      <span class="dash" aria-hidden="true">──</span>
      this page was built
      <time datetime={deployTimeRaw}>{builtAt}</time>
      from {apiCount} APIs
      <span class="dash long" aria-hidden="true">────────────</span>
    </p>
    <p class="line mono">
      <a class="link" href="/">oriz/me</a>
      <span class="dot" aria-hidden="true">·</span>
      <a
        class="link"
        href="https://github.com/chirag127/oriz-me/blob/main/LICENSE"
        target="_blank"
        rel="noopener noreferrer"
      >MIT</a>
      <span class="dot" aria-hidden="true">·</span>
      <span>₹0 to host</span>
      <span class="dot" aria-hidden="true">·</span>
      <a
        class="link"
        href="https://github.com/chirag127/oriz-me"
        target="_blank"
        rel="noopener noreferrer"
      >source on github</a>
      <span class="dot" aria-hidden="true">·</span>
      <a class="link" href="https://oriz.in">part of oriz.in</a>
      <span class="dot" aria-hidden="true">·</span>
      <code class="sha">{gitSha}</code>
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
  }
  .footer-block {
    padding-block: 1.25rem 2rem;
  }
  .line {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.5ch;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    line-height: 1.7;
    letter-spacing: 0.02em;
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .line + .line { margin-top: 0.125rem; }
  .dash {
    color: var(--rule);
    letter-spacing: 0;
  }
  .dash.long {
    flex: 0 1 auto;
    overflow: hidden;
    white-space: nowrap;
  }
  .link {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: transparent;
  }
  .link:hover {
    color: var(--archival);
    text-decoration-color: var(--archival);
  }
  .dot {
    color: var(--rule);
  }
  .sha {
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 11px;
  }
  time {
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .dash.long { display: none; }
  }
</style>
