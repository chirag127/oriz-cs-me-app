---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import { projects } from '../../content';

const featuredProjects = projects.filter((p) => p.featured);
const otherProjects = projects.filter((p) => !p.featured);
const allTechs = [...new Set(projects.flatMap((p) => p.tech.split(', ')))];
---

<Layout title="Projects" description="All {projects.length} projects by Chirag Singhal — Oriz, NexusAI, TubeDigest, Olivia, and more">
  <CommandPalette />
  <main class="relative mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <div class="absolute top-0 right-0 w-96 h-96 bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-64 h-64 bg-violet-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Work
    </a>

    <!-- Page Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        PROJECTS
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">Projects</h1>
      <p class="text-base text-white/40">{featuredProjects.length} featured + {otherProjects.length} additional — {projects.length} total</p>
    </div>

    <!-- Featured Projects -->
    <div class="mb-16 reveal">
      <div class="flex items-center gap-3 mb-6">
        <svg class="h-5 w-5 text-teal-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <h2 class="text-xl font-bold text-white">Featured Projects</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project) => (
          <div class="glass p-6 group relative overflow-hidden hover:border-teal-500/15 transition-all duration-300 flex flex-col">
            <div class="absolute top-0 right-0 w-32 h-32 bg-teal-500/5 rounded-full blur-[60px] pointer-events-none"></div>
            <div class="relative flex-1">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors" style="font-family: var(--font-display, 'Outfit');">{project.name}</h3>
              </div>

              <div class="flex flex-wrap gap-1.5 mb-4">
                {project.tech.split(', ').slice(0, 4).map((t) => (
                  <span class="px-2 py-0.5 text-[10px] rounded-md bg-white/5 text-white/50 border border-white/5 font-medium">{t}</span>
                ))}
                {project.tech.split(', ').length > 4 && (
                  <span class="px-2 py-0.5 text-[10px] rounded-md bg-teal-500/10 text-teal-400 border border-teal-500/20 font-medium">+{project.tech.split(', ').length - 4}</span>
                )}
              </div>

              <ul class="space-y-2.5">
                {project.items.slice(0, 3).map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-white/50 leading-relaxed">
                    <svg class="h-3.5 w-3.5 text-teal-400/50 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <a href={project.link.startsWith('http') ? project.link : `https://${project.link}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-teal-400/60 group-hover:text-teal-400 mt-4 transition-colors">
              View Project
              <svg class="h-3 w-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Other Projects -->
    {otherProjects.length > 0 && (
      <div class="mb-16 reveal">
        <h2 class="text-xl font-bold text-white mb-6">More Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {otherProjects.map((project) => (
            <div class="glass p-6 group relative overflow-hidden hover:border-teal-500/15 transition-all duration-300 flex flex-col">
              <div class="absolute top-0 right-0 w-24 h-24 bg-white/5 rounded-full blur-[60px] pointer-events-none"></div>
              <div class="relative flex-1">
                <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors mb-3" style="font-family: var(--font-display, 'Outfit');">{project.name}</h3>
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {project.tech.split(', ').slice(0, 3).map((t) => (
                    <span class="px-2 py-0.5 text-[10px] rounded-md bg-white/5 text-white/40 border border-white/5 font-medium">{t}</span>
                  ))}
                </div>
                <ul class="space-y-2">
                  {project.items.map((item) => (
                    <li class="flex items-start gap-2.5 text-sm text-white/50 leading-relaxed">
                      <svg class="h-3.5 w-3.5 text-teal-400/50 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
              <a href={project.link.startsWith('http') ? project.link : `https://${project.link}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-teal-400/60 group-hover:text-teal-400 mt-4 transition-colors">
                View Project
                <svg class="h-3 w-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Tech Stack Summary -->
    <div class="glass p-8 reveal">
      <h2 class="text-lg font-bold text-white mb-4">Technologies Across All Projects</h2>
      <div class="flex flex-wrap gap-2">
        {allTechs.map((tech) => (
          <span class="px-3 py-1.5 text-xs rounded-lg bg-white/5 text-white/50 border border-white/5 hover:border-white/10 transition-colors">{tech}</span>
        ))}
      </div>
      <div class="mt-4 pt-4 border-t border-white/5 text-xs text-white/25">{allTechs.length} unique technologies across {projects.length} projects</div>
    </div>
  </main>
</Layout>
