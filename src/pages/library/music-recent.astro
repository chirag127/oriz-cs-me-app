---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { lastfm: {}, listenbrainz: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/music.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Music Recent] music.json not found.');
}

const recentTracks = db.lastfm?.recentTracks || [];
const lbRecent = db.listenbrainz?.recentListens || [];

const fallbackGradients = [
  'linear-gradient(135deg, #e11d48, #881337)',
  'linear-gradient(135deg, #1e3a5f, #7c3aed)',
  'linear-gradient(135deg, #d97706, #b91c1c)',
  'linear-gradient(135deg, #7c3aed, #db2777)',
];
const fallbackEmojis = ['🎵', '🎶', '🎤', '🎧'];

function getVisuals(name: string) {
  if (!name)
    return { gradient: fallbackGradients[0], emoji: fallbackEmojis[0] };
  const idx = [...name].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Recent Tracks" description="Recently played music - from Last.fm and ListenBrainz">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/music" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Music
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-sky-500/10 flex items-center justify-center">
          <span class="text-xl">🎧</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Recent Tracks</h1>
      </div>
      <p class="text-white/40">Recently played songs - live scrobble history.</p>
    </div>

    <!-- Last.fm Recent -->
    <section class="mb-16">
      <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
        Last.fm - Recent Tracks
        <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
      </h2>
      {recentTracks.length > 0 ? (
        <div class="space-y-2">
          {recentTracks.map((track: any, i: number) => (
            <a href={track.url} target="_blank" rel="noopener noreferrer" class="glass p-4 flex items-center gap-4 hover:border-sky-500/15 transition-colors group rounded-2xl border border-white/5" style={`animation-delay: ${i * 30}ms`}>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg shrink-0" style={`background: ${getVisuals(track.name).gradient}`}>
                {track.imageUrl ? (
                  <img src={track.imageUrl} alt={track.name} class="w-full h-full object-cover rounded-lg" />
                ) : (
                  <span>{getVisuals(track.name).emoji}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate group-hover:text-sky-400 transition-colors">{track.name}</h3>
                <p class="text-xs text-white/30 truncate">{track.artist}</p>
              </div>
              {track.nowPlaying && (
                <span class="text-[0.6rem] text-emerald-400 font-medium uppercase animate-pulse">Now Playing</span>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center rounded-2xl border border-white/5"><p class="text-white/30">No recent tracks.</p></div>
      )}
    </section>

    <!-- ListenBrainz Recent -->
    {lbRecent.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          ListenBrainz - Recent Listens
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
        </h2>
        <div class="space-y-2">
          {lbRecent.map((listen: any, i: number) => (
            <div class="glass p-4 flex items-center gap-4 rounded-2xl border border-white/5" style={`animation-delay: ${i * 30}ms`}>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate">{listen.name}</h3>
                <p class="text-xs text-white/30 truncate">{listen.artist}</p>
              </div>
              {listen.listenedAt && (
                <span class="text-[0.6rem] text-white/20 shrink-0">{new Date(listen.listenedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
