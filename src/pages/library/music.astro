---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db = {
  lastfm: {
    stats: { playcount: 0 },
    topArtists: [] as any[],
    recentTracks: [] as any[],
    topTracks: [] as any[],
  },
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/music.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Music Hub] music.json not found.');
}

const numPlays = db.lastfm?.stats?.playcount || 0;
const artists = db.lastfm?.topArtists || [];
const recentTracks = db.lastfm?.recentTracks || [];

const fallbackGradients = [
  'linear-gradient(135deg, #e11d48, #881337)',
  'linear-gradient(135deg, #1e3a5f, #7c3aed)',
  'linear-gradient(135deg, #d97706, #b91c1c)',
  'linear-gradient(135deg, #7c3aed, #db2777)',
  'linear-gradient(135deg, #0c4a6e, #1e40af)',
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #365314, #3f6212)',
];
const fallbackEmojis = ['🎵', '🎶', '🎤', '🎧', '🎸', '🎹', '🥁'];

function getVisuals(name: string) {
  if (!name)
    return { gradient: fallbackGradients[0], emoji: fallbackEmojis[0] };
  const idx = [...name].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}

const currentTrack = recentTracks[0];
---

<Layout title="Music" description="Chirag Singhal's music taste - top artists, tracks, and listening habits synced from Last.fm">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">🎵</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Music</h1>
      </div>
      <p class="text-white/40">Top artists and listening habits - synced automatically from Last.fm.</p>
    </div>

    <!-- Sub-page Navigation -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href="/library/music-top-artists" class="text-xs px-3 py-1.5 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 transition-colors">Top Artists</a>
      <a href="/library/music-top-tracks" class="text-xs px-3 py-1.5 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20 hover:bg-teal-500/20 transition-colors">Top Tracks</a>
      <a href="/library/music-recent" class="text-xs px-3 py-1.5 rounded-full bg-sky-500/10 text-sky-400 border border-sky-500/20 hover:bg-sky-500/20 transition-colors">Recent</a>
      <a href="/library/mixcloud" class="text-xs px-3 py-1.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 hover:bg-indigo-500/20 transition-colors">Mixcloud</a>
    </div>

    <!-- Now Playing / Last Played -->
    {currentTrack && (
    <div class="glass-strong p-8 mb-12 relative overflow-hidden rounded-2xl border border-white/10">
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full blur-3xl opacity-10 bg-violet-500"></div>
      <div class="relative z-10 flex items-center gap-6">
        <div class="h-20 w-20 rounded-2xl bg-gradient-to-br from-violet-500/20 to-teal-500/20 flex items-center justify-center shrink-0 relative overflow-hidden">
          {currentTrack.imageUrl ? (
            <img src={currentTrack.imageUrl} alt="Album Art" class="w-full h-full object-cover" />
          ) : (
            <div class="flex items-end gap-[3px] h-8 relative z-10">
              <div class="w-[3px] bg-violet-400 rounded-full animate-[bounce_0.8s_ease-in-out_infinite]" style="height: 60%"></div>
              <div class="w-[3px] bg-violet-400 rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.1s]" style="height: 100%"></div>
              <div class="w-[3px] bg-violet-400 rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.2s]" style="height: 40%"></div>
              <div class="w-[3px] bg-violet-400 rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.3s]" style="height: 80%"></div>
              <div class="w-[3px] bg-violet-400 rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.15s]" style="height: 50%"></div>
            </div>
          )}
        </div>
        <div>
          <p class="text-xs text-white/30 uppercase tracking-wider mb-1">
            {currentTrack.nowPlaying ? 'Now Playing' : 'Last Played'}
          </p>
          <p class="text-lg text-white font-semibold">{currentTrack.name}</p>
          <p class="text-sm text-white/40">{currentTrack.artist}</p>
        </div>
      </div>
    </div>
    )}

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-sky-400">{numPlays.toLocaleString()}</div>
        <div class="text-xs text-white/30">Total Scrobbles</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-violet-400">{artists.length}</div>
        <div class="text-xs text-white/30">Top Artists Tracked</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{recentTracks.length}</div>
        <div class="text-xs text-white/30">Recent Tracks</div>
      </div>
    </div>

    <!-- Top Artists -->
    <section class="mb-16">
      <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
        Top Artists
        <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-violet-400 to-transparent rounded-full"></span>
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-4 gap-4">
        {artists.map((artist, i) => {
          const vis = getVisuals(artist.name);
          return (
          <a href={artist.url} target="_blank" rel="noopener noreferrer" class="glass rounded-2xl border border-white/5 hover:border-violet-500/15 transition-all group cursor-default text-center block" style={`animation-delay: ${i * 40}ms`}>
            <div class="w-20 h-20 mx-auto rounded-full mb-3 flex items-center justify-center text-3xl relative overflow-hidden mt-4" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-black/10"></div>
              {artist.imageUrl ? (
                <img src={artist.imageUrl} alt={artist.name} class="w-full h-full object-cover relative z-10" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
            </div>
            <div class="px-4 pb-4">
              <h3 class="text-xs font-semibold text-white truncate group-hover:text-violet-400 transition-colors">{artist.name}</h3>
              <div class="mt-1">
                <span class="text-[0.65rem] text-violet-400 font-medium">{artist.playcount.toLocaleString()} plays</span>
              </div>
            </div>
          </a>
        )})}
    </section>

    <!-- Last.fm Profile Link -->
    <div class="mt-20 p-6 rounded-2xl bg-gradient-to-br from-rose-500/5 to-pink-500/5 border border-rose-500/10 text-center flex flex-col items-center">
      <div class="h-12 w-12 rounded-full bg-rose-500/10 text-rose-500 flex items-center justify-center text-xl mb-4">
        🎵
      </div>
      <h3 class="text-lg font-bold text-white mb-2">Complete Profile</h3>
      <p class="text-sm text-white/40 mb-6 max-w-md">
        For the complete, unfiltered history of everything I've listened to.
      </p>
      <a href="https://last.fm" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-rose-500/10 text-rose-500 hover:text-rose-400 hover:bg-rose-500/20 font-semibold text-sm transition-all outline-none focus:ring-2 focus:ring-rose-500/50">
        View Last.fm Profile
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </main>
</Layout>

<style>
  @keyframes bounce {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1); }
  }
</style>
