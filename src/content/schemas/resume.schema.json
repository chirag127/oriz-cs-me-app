{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://me.oriz.in/schemas/resume.schema.json",
  "title": "Resume",
  "description": "Authored résumé content for the personal site. Drives /work/* pages and the homepage hero.",
  "type": "object",
  "required": [
    "tagline",
    "summary",
    "extendedSummary",
    "valueProposition",
    "availability",
    "skills",
    "experience",
    "education",
    "projects",
    "honors",
    "certifications"
  ],
  "additionalProperties": false,
  "properties": {
    "tagline":         { "type": "string", "minLength": 1 },
    "summary":         { "type": "string", "minLength": 1 },
    "extendedSummary": { "type": "string", "minLength": 1 },
    "valueProposition": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "icon"],
        "additionalProperties": false,
        "properties": {
          "title":       { "type": "string" },
          "description": { "type": "string" },
          "icon":        { "type": "string" }
        }
      }
    },
    "availability": {
      "type": "object",
      "required": ["status", "message", "preferredRoles"],
      "additionalProperties": false,
      "properties": {
        "status":         { "enum": ["available", "open-to-offers", "unavailable"] },
        "message":        { "type": "string" },
        "preferredRoles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "items"],
        "additionalProperties": false,
        "properties": {
          "category": { "type": "string" },
          "items":    { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "company", "location", "date", "items"],
        "additionalProperties": false,
        "properties": {
          "title":    { "type": "string" },
          "company":  { "type": "string" },
          "location": { "type": "string" },
          "date":     { "type": "string" },
          "items":    { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["degree", "institution", "location", "date", "items"],
        "additionalProperties": false,
        "properties": {
          "degree":      { "type": "string" },
          "institution": { "type": "string" },
          "location":    { "type": "string" },
          "date":        { "type": "string" },
          "items":       { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tech", "link", "items"],
        "additionalProperties": false,
        "properties": {
          "name":     { "type": "string" },
          "tech":     { "type": "string" },
          "link":     { "type": "string" },
          "items":    { "type": "array", "items": { "type": "string" } },
          "featured": { "type": "boolean" }
        }
      }
    },
    "honors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "location", "year"],
        "additionalProperties": false,
        "properties": {
          "title":       { "type": "string" },
          "description": { "type": "string" },
          "location":    { "type": "string" },
          "year":        { "type": "string" }
        }
      }
    },
    "certifications": { "type": "array", "items": { "type": "string" } }
  }
}
