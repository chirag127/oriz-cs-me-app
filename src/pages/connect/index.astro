---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import { socialLinks } from '../../content';

const devLinks = socialLinks.filter((l) =>
  [
    'GitHub',
    'Dev.to',
    'LeetCode',
    'Codewars',
    'NPM',
    'HackerNews',
    'StackOverflow',
    'Holopin',
  ].includes(l.name),
);
const socialPlatformLinks = socialLinks.filter((l) =>
  ['Bluesky', 'Mastodon', 'Reddit', 'Pixelfed'].includes(l.name),
);
const entertainmentLinks = socialLinks.filter((l) =>
  ['AniList', 'Letterboxd', 'Trakt'].includes(l.name),
);
const musicLinks = socialLinks.filter((l) =>
  ['Last.fm', 'ListenBrainz', 'Mixcloud'].includes(l.name),
);
const readingLinks = socialLinks.filter((l) =>
  ['Open Library', 'Backloggd'].includes(l.name),
);
const gamingLinks = socialLinks.filter((l) =>
  ['Lichess', 'Speedrun'].includes(l.name),
);

