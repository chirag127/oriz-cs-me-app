---
/*
 * /system — build manifest, infrastructure ledger (v2 datasheet).
 *
 * The most "meta" page on the site — describes the system itself: how the
 * site builds, where the data lives, what host the build runs on, what's
 * survived past failures.
 */

import Layout from '../../layouts/Layout.astro';

const deployTimeRaw =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString();
const builtAt = (() => {
  const d = new Date(deployTimeRaw);
  if (Number.isNaN(d.getTime())) return deployTimeRaw;
  return `${d.toISOString().slice(0, 16)}Z`;
})();
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev';
---

<Layout
  title="System"
  description="The build manifest. How this site builds, where the data lives, what survives."
  breadcrumb="SYSTEM"
  provenanceSection="/system"
  provenanceApis="self"
>
  <div class="spine">
    <header class="page-head">
      <h1>System</h1>
      <p class="lede">
        How this site builds, where the data lives, what host the build
        runs on. The site is a build manifest of itself.
      </p>
    </header>
    <div class="page-counts">
      built {builtAt} · sha {gitSha} · cloudflare pages · github actions cron
    </div>

    <section class="band">
      <p class="eyebrow band-eyebrow">BUILD MANIFEST</p>
      <div class="rows">
        <div class="leader-row">
          <span class="leader-name">deploy</span>
          <span class="leader-fill">cloudflare pages — me.oriz.in</span>
          <span class="leader-time mono">primary</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">mirror</span>
          <span class="leader-fill">github pages — chirag127.github.io/oriz-me</span>
          <span class="leader-time mono">survival</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">canonical</span>
          <span class="leader-fill">github — chirag127/oriz-me-data (jsonl)</span>
          <span class="leader-time mono">data</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">cache</span>
          <span class="leader-fill">turso libsql — rebuilt from jsonl on cron</span>
          <span class="leader-time mono">warm</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">framework</span>
          <span class="leader-fill">astro 6 · react 19 · tailwind v4</span>
          <span class="leader-time mono">build</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">cost</span>
          <span class="leader-fill">₹0 / month — every host on a free tier</span>
          <span class="leader-time mono">budget</span>
        </div>
      </div>
    </section>

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">DATA SOVEREIGNTY</p>
      <p class="band-note">
        Every datum on this site has a provenance — an upstream API, a
        timestamp it was scraped, a JSONL line it lives in. The git repo
        <code>chirag127/oriz-me-data</code> is the canonical store; cloud
        databases (Turso, Firestore) are caches rebuilt from the JSONL on
        every deploy. If every cloud provider used here disappears
        tomorrow, the data still <code>git clone</code>s to a fresh host.
      </p>
    </section>

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">SUB-PAGES</p>
      <div class="rows">
        <a class="leader-row me-link" href="/status/">
          <span class="leader-name">/status</span>
          <span class="leader-fill">ingester health — 8-day sparkline per source</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/system/changelog/">
          <span class="leader-name">/system/changelog</span>
          <span class="leader-fill">site change log + design milestones</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/system/admin/">
          <span class="leader-name">/system/admin</span>
          <span class="leader-fill">admin tools — auth-gated</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
      </div>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/me/">/me</a>
      <span aria-hidden="true">·</span>
      <a href="/work/">/work</a>
      <span aria-hidden="true">·</span>
      <a href="/code/">/code</a>
      <span aria-hidden="true">·</span>
      <a href="/library/">/library</a>
      <span aria-hidden="true">·</span>
      <a href="/gaming/">/gaming</a>
      <span aria-hidden="true">·</span>
      <a href="/connect/">/connect</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .rows { display: flex; flex-direction: column; }
  .me-link:hover .leader-name,
  .me-link:hover .leader-fill,
  .me-link:hover .leader-time { color: var(--archival); }
  .me-link:hover { background: var(--archival-wash); }
  .band-note {
    margin: 0;
    color: var(--ink);
    line-height: 1.6;
    font-size: 0.9375rem;
    max-width: 64ch;
  }
  .band-note code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--archival-wash);
    padding: 0.125em 0.375em;
  }
</style>
