---
import {
  experience,
  honors,
  projects,
  summary,
  tagline,
  valueProposition,
} from '../content';
import { testimonials } from '../content';
import {
  fetchBlogPosts,
  fetchDevToArticles,
  fetchGitHubRepos,
  fetchGitHubUser,
  fetchLeetCodeStats,
} from '../lib/api/index';
import Layout from '../layouts/Layout.astro';
import CommandPalette from
  '../components/CommandPalette.astro';
import HeroChatButton from
  '../components/islands/HeroChatButton';

const [, githubRepos, leetcodeStats, devtoArticles] =
  await Promise.all([
    fetchGitHubUser(),
    fetchGitHubRepos(),
    fetchLeetCodeStats(),
    fetchDevToArticles(),
    fetchBlogPosts(),
  ]);

const totalStars = githubRepos.reduce(
  (sum: number, r: any) =>
    sum + (r.stargazers_count || 0),
  0,
);
const recentArticles = devtoArticles.slice(0, 3);
const featuredProjects = projects
  .filter((p) => p.featured)
  .slice(0, 3);
const activeRole = experience[0];

/** Value prop icon SVGs */
const vpIcons: Record<string, string> = {
  server:
    'M5 12H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h18a2 ' +
    '2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2 M5 12H3a2 2 ' +
    '0 0 0-2 2v5a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2' +
    'v-5a2 2 0 0 0-2-2h-2 M7 8h.01 M7 16h.01',
  layers:
    'M12 2 2 7l10 5 10-5-10-5z M2 17l10 5 10-5 ' +
    'M2 12l10 5 10-5',
  cloud:
    'M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 ' +
    '0 0 1 0 9z',
};
---

<Layout
  title="Software Engineer & AI Specialist"
  description={summary}
>
  <CommandPalette />

  <div class="relative pb-16">
    <!-- ═══ HERO ═══ -->
    <section
      class="relative pt-12 pb-16 sm:pt-20 sm:pb-24
        overflow-hidden"
    >
      <!-- Ambient glow -->
      <div
        class="absolute inset-0 overflow-hidden
          pointer-events-none z-0"
      >
        <div
          class="absolute top-[-20%] right-[-10%]
            w-[600px] h-[500px] rounded-[100%]
            blur-[120px]"
          style="background: rgba(20,184,166,0.08);"
        ></div>
        <div
          class="absolute bottom-[-10%] left-[-10%]
            w-[500px] h-[500px] rounded-[100%]
            blur-[120px]"
          style="background: rgba(139,92,246,0.06);"
        ></div>
        <!-- Grid pattern -->
        <div
          class="absolute inset-0 opacity-[0.015]"
          style="background-image:
            linear-gradient(
              to right, white 1px, transparent 1px
            ),
            linear-gradient(
              to bottom, white 1px, transparent 1px
            );
            background-size: 64px 64px;"
        ></div>
      </div>

      <div
        class="relative z-10 mx-auto
          max-w-[var(--content-max-width)] px-6"
      >
        <div
          class="flex flex-col lg:flex-row items-start
            lg:items-center gap-12 lg:gap-16"
        >
          <!-- Left: Text content -->
          <div class="flex-1 max-w-2xl">
            <!-- Status badge -->
            <div
              class="inline-flex items-center gap-2 px-3
                py-1.5 rounded-full bg-[var(--primary-faint)]
                border border-[var(--primary-subtle)]
                text-[11px] font-semibold text-[var(--primary-light)]
                uppercase tracking-wider mb-6
                reveal"
            >
              <span
                class="h-1.5 w-1.5 rounded-full
                  bg-[var(--primary-light)] animate-pulse"
              ></span>
              {activeRole.title} @ {activeRole.company}
            </div>

            <h1
              class="text-4xl sm:text-5xl lg:text-6xl
                font-black tracking-tighter mb-4
                leading-[1.05] reveal"
              style="font-family:
                var(--font-display, 'Outfit');"
            >
              Engineering software,<br />
              <span
                class="text-transparent bg-clip-text
                  bg-gradient-to-r from-[var(--primary-light)]
                  to-[var(--primary-lighter)]"
              >
                AI agents
              </span> &<br />
              cloud-native systems.
            </h1>

            <p
              class="text-base sm:text-lg text-white/45
                max-w-lg font-medium leading-relaxed
                mb-8 reveal"
            >
              {summary}
            </p>

            <!-- CTAs -->
            <div
              class="flex flex-wrap items-center gap-3
                mb-8 reveal"
            >
              <a
                href="/work"
                class="group inline-flex items-center
                  gap-2 px-6 py-3 rounded-xl
                  bg-white text-black font-semibold
                  text-sm hover:bg-white/90
                  transition-all duration-200
                  hover:shadow-lg
                  hover:shadow-white/10"
              >
                View Work
                <svg
                  class="h-4 w-4 transition-transform
                    group-hover:translate-x-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
              <a
                href="/connect"
                class="inline-flex items-center gap-2
                  px-6 py-3 rounded-xl text-sm
                  font-semibold border
                  border-[var(--primary-subtle)] text-[var(--primary-light)]
                  hover:bg-[var(--primary-faint)]
                  transition-all duration-200"
              >
                <span
                  class="h-1.5 w-1.5 rounded-full
                    bg-[var(--primary-light)]"
                ></span>
                Hire Me
              </a>
              <HeroChatButton client:load />
            </div>

            <!-- Social links -->
            <div
              class="flex items-center gap-3
                text-white/25 reveal"
            >
              <a
                href="https://github.com/chirag127"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-white transition-colors
                  p-1.5"
                aria-label="GitHub"
              >
                <svg
                  class="h-5 w-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M12 0C5.37 0 0 5.37 0 12c0 5.31
                      3.435 9.795 8.205 11.385.6.105
                      .825-.255.825-.57
                      0-.285-.015-1.23-.015-2.235-3.015
                      .555-3.795-.735-4.035-1.41-.135
                      -.345-.72-1.41-1.23-1.695-.42-.225
                      -1.02-.78-.015-.795.945-.015 1.62
                      .87 1.845 1.23 1.08 1.815 2.805
                      1.305 3.495.99.105-.78.42-1.305
                      .765-1.605-2.67-.3-5.46-1.335-5.46
                      -5.925 0-1.305.465-2.385 1.23-3.225
                      -.12-.3-.54-1.53.12-3.18 0 0 1.005
                      -.315 3.3 1.23.96-.27 1.98-.405 3
                      -.405s2.04.135 3 .405c2.295-1.56
                      3.3-1.23 3.3-1.23.66 1.65.24 2.88
                      .12 3.18.765.84 1.23 1.905 1.23
                      3.225 0 4.605-2.805 5.625-5.475
                      5.925.435.375.81 1.095.81 2.22 0
                      1.605-.015 2.895-.015 3.3 0 .315
                      .225.69.825.57A12.02 12.02 0 0024
                      12c0-6.63-5.37-12-12-12z"
                  />
                </svg>
              </a>
              <a
                href="https://linkedin.com/in/chirag127"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[var(--primary-light)]
                  transition-colors p-1.5"
                aria-label="LinkedIn"
              >
                <svg
                  class="h-5 w-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0
                      -1.328-.027-3.037-1.852-3.037
                      -1.853 0-2.136 1.445-2.136
                      2.939v5.667H9.351V9h3.414v1.561h
                      .046c.477-.9 1.637-1.85 3.37-1.85
                      3.601 0 4.267 2.37 4.267
                      5.455v6.286zM5.337
                      7.433a2.062 2.062 0
                      01-2.063-2.065 2.064 2.064 0
                      112.063 2.065zm1.782
                      13.019H3.555V9h3.564v11.452z
                      M22.225 0H1.771C.792 0 0 .774 0
                      1.729v20.542C0 23.227.792 24 1.771
                      24h20.451C23.2 24 24 23.227 24
                      22.271V1.729C24 .774 23.2 0
                      22.222 0h.003z"
                  />
                </svg>
              </a>
              <a
                href="https://dev.to/chirag127"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-white transition-colors
                  p-1.5"
                aria-label="Dev.to"
              >
                <svg
                  class="h-5 w-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M7.42 10.05c-.18-.16-.46-.23
                      -.84-.23H6v4.36h.58c.38 0
                      .66-.08.84-.23.17-.16.26-.45
                      .26-.86v-2.18c0-.41-.09-.7
                      -.26-.86zm13.01-4.59H3.57C2.7
                      5.46 2 6.16 2 7.04v9.92c0
                      .88.7 1.58 1.57 1.58h16.86c.87
                      0 1.57-.7 1.57-1.58V7.04c0
                      -.88-.7-1.58-1.57-1.58zM9.93
                      13.45c0 .95-.68 1.66-1.87
                      1.66H6.11V8.89h1.95c1.19 0
                      1.87.71 1.87 1.66v2.9zm4.56
                      -3.66H12.3v1.36h1.38v.9H12.3
                      v1.36h2.19v.9h-2.48c-.54 0-.88
                      -.32-.88-.86V9.75c0-.54.34-.86
                      .88-.86h2.48v.9zm4.49
                      3.47c-.25.67-.85 1.15-1.59
                      1.15-.41 0-.7-.09-.94-.28-.24
                      -.19-.4-.46-.49-.83l-.08-.22
                      -1.12-3.97h1.05l.9 3.62.9
                      -3.62h1.05l-1.12 3.97-.08.18z"
                  />
                </svg>
              </a>
            </div>
          </div>

          <!-- Right: Avatar + floating badges -->
          <div
            class="relative flex-shrink-0 hidden
              lg:block reveal-scale"
          >
            <div class="relative w-72 h-72">
              <!-- Gradient ring -->
              <div
                class="absolute inset-0 rounded-3xl
                  bg-gradient-to-br from-[var(--primary-subtle)]
                  to-[var(--primary-muted)] blur-xl"
              ></div>
              <!-- Avatar -->
              <img
                src="/avatar.png"
                alt="Chirag Singhal"
                class="relative w-72 h-72 rounded-3xl
                  object-cover border-2
                  border-white/10
                  shadow-2xl"
                width="288"
                height="288"
                loading="eager"
              />
              <!-- Floating tech badges -->
              <div
                class="absolute -top-3 -right-3
                  px-3 py-1.5 rounded-full
                  bg-gray-900/90 border border-white/10
                  backdrop-blur-sm text-[10px]
                  font-bold text-teal-400
                  shadow-lg animate-float"
              >
                Python
              </div>
              <div
                class="absolute top-1/4 -left-6
                  px-3 py-1.5 rounded-full
                  bg-gray-900/90 border border-white/10
                  backdrop-blur-sm text-[10px]
                  font-bold text-violet-400
                  shadow-lg animate-float-delayed"
              >
                React
              </div>
              <div
                class="absolute -bottom-3 right-8
                  px-3 py-1.5 rounded-full
                  bg-gray-900/90 border border-white/10
                  backdrop-blur-sm text-[10px]
                  font-bold text-amber-400
                  shadow-lg animate-float"
              >
                AI Agents
              </div>
              <div
                class="absolute bottom-1/4 -right-5
                  px-3 py-1.5 rounded-full
                  bg-gray-900/90 border border-white/10
                  backdrop-blur-sm text-[10px]
                  font-bold text-emerald-400
                  shadow-lg animate-float-delayed"
              >
                FastAPI
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div
      class="mx-auto max-w-[var(--content-max-width)]
        px-6 space-y-20"
    >
      <!-- ═══ VALUE PROPOSITION ═══ -->
      <section class="reveal-stagger">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {valueProposition.map((vp) => (
            <div
              class="group p-6 rounded-2xl
                bg-white/[0.015] border border-white/5
                hover:border-[var(--primary-subtle)]
                hover:bg-white/[0.025]
                transition-all duration-300"
            >
              <div
                class="flex items-center justify-center
                  h-10 w-10 rounded-xl
                  bg-gradient-to-br from-[var(--primary-muted)]
                  to-[var(--primary-subtle)]
                  border border-white/5
                  mb-4 group-hover:border-[var(--primary-subtle)]
                  transition-colors"
              >
                <svg
                  class="h-5 w-5 text-[var(--primary-light)]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  {(vpIcons[vp.icon] || '').split(' M')
                    .map((seg: string, i: number) => (
                      <path d={i === 0 ? seg : `M${seg}`} />
                    ))}
                </svg>
              </div>
              <h3
                class="text-sm font-bold text-white mb-1.5"
              >
                {vp.title}
              </h3>
              <p class="text-xs text-white/35 leading-relaxed">
                {vp.description}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- ═══ KEY STATS ═══ -->
      <section class="reveal-stagger">
        <div
          class="grid grid-cols-2 lg:grid-cols-4 gap-4"
        >
          {[
            {
              label: 'GitHub Stars',
              value: totalStars || '100+',
              color: 'text-amber-400',
              icon: '⭐',
            },
            {
              label: 'LeetCode Solved',
              value: leetcodeStats?.totalSolved || '500+',
              color: 'text-emerald-400',
              icon: '🧩',
            },
            {
              label: 'Live Projects',
              value: projects.length,
              color: 'text-sky-400',
              icon: '🚀',
            },
            {
              label: 'Years Experience',
              value: '4+',
              color: 'text-violet-400',
              icon: '📅',
            },
          ].map((stat) => (
            <div
              class="group p-5 rounded-2xl
                bg-white/[0.015] border border-white/5
                hover:border-white/10
                transition-all duration-300
                text-center"
            >
              <div class="text-2xl mb-2">{stat.icon}</div>
              <div
                class={`text-3xl font-black text-white
                  mb-1 tracking-tight`}
                style="font-family:
                  var(--font-display, 'Outfit');"
              >
                {stat.value}
              </div>
              <div
                class="text-[10px] font-semibold
                  text-white/30 uppercase
                  tracking-widest"
              >
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ═══ EXPERIENCE SNAPSHOT ═══ -->
      <section
        class="reveal-stagger grid grid-cols-1
          md:grid-cols-2 gap-6"
      >
        <!-- Current Role -->
        <div
          class="p-6 rounded-2xl bg-white/[0.015]
            border border-white/5"
        >
          <div
            class="flex items-center gap-2 text-xs
              font-semibold text-[var(--primary-light)] uppercase
              tracking-wider mb-4"
          >
            <span
              class="h-1.5 w-1.5 rounded-full
                bg-[var(--primary-light)]"
            ></span>
            Current Role
          </div>
          <h3
            class="text-xl font-bold text-white mb-1"
            style="font-family:
              var(--font-display, 'Outfit');"
          >
            {activeRole.title}
          </h3>
          <p class="text-[var(--primary-light)]/70 text-sm mb-3">
            {activeRole.company} · {activeRole.date}
          </p>
          <p
            class="text-white/35 text-sm leading-relaxed
              mb-4"
          >
            {activeRole.items[0]}
          </p>
          <a
            href="/work"
            class="text-xs font-semibold text-white/30
              hover:text-[var(--primary-light)] transition-colors
              group inline-flex items-center gap-1"
          >
            View full resume
            <span
              class="inline-block transition-transform
                group-hover:translate-x-1"
            >
              →
            </span>
          </a>
        </div>

        <!-- Background -->
        <div
          class="p-6 rounded-2xl bg-white/[0.015]
            border border-white/5"
        >
          <div
            class="flex items-center gap-2 text-xs
              font-semibold text-amber-400 uppercase
              tracking-wider mb-4"
          >
            <span>🎓</span>
            Background
          </div>
          <div class="space-y-3">
            <div
              class="p-3 rounded-xl bg-white/[0.02]
                border border-white/5"
            >
              <h4
                class="text-sm font-bold text-white mb-0.5"
              >
                {honors[0].title}
              </h4>
              <p class="text-[var(--primary-light)]/60 text-xs">
                {honors[0].description}
              </p>
            </div>
            <div
              class="p-3 rounded-xl bg-white/[0.02]
                border border-white/5"
            >
              <h4
                class="text-sm font-bold text-white mb-0.5"
              >
                Honors & Awards
              </h4>
              <p class="text-white/35 text-xs">
                Smart India Hackathon finalist. Multiple
                hackathon wins.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ FEATURED PROJECTS ═══ -->
      <section class="reveal-stagger">
        <div
          class="flex items-end justify-between mb-8"
        >
          <div>
            <h2
              class="text-2xl font-black text-white mb-1"
              style="font-family:
                var(--font-display, 'Outfit');"
            >
              Featured Work
            </h2>
            <p class="text-white/30 text-sm font-medium">
              Flagship engineering projects & AI platforms
            </p>
          </div>
          <a
            href="/work/projects"
            class="hidden sm:inline-flex px-5 py-2
              rounded-xl border border-white/8
              text-white/50 text-xs font-semibold
              hover:bg-white/5 hover:text-white
              transition-all"
          >
            View All
          </a>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-3 gap-5"
        >
          {featuredProjects.map((project) => (
            <a
              href={
                project.link.startsWith('http')
                  ? project.link
                  : `https://${project.link}`
              }
              target="_blank"
              rel="noopener noreferrer"
              class="group relative overflow-hidden
                rounded-2xl bg-white/[0.015]
                border border-white/5
                hover:border-[var(--primary-subtle)]
                transition-all duration-300
                p-6 flex flex-col justify-between
                min-h-[200px]"
            >
              <!-- Tech tags -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {project.tech
                  .split(', ')
                  .slice(0, 3)
                  .map((tag: string) => (
                    <span
                      class="px-2 py-0.5 rounded-md
                        bg-white/[0.03]
                        border border-white/5
                        text-[9px] uppercase font-bold
                        text-white/40 tracking-wider
                        group-hover:border-[var(--primary-subtle)]
                        group-hover:text-[var(--primary-light)]/60
                        transition-colors"
                    >
                      {tag}
                    </span>
                  ))}
              </div>
              <!-- Content -->
              <div>
                <h3
                  class="text-lg font-bold text-white mb-1.5
                    group-hover:text-[var(--primary-lighter)]
                    transition-colors"
                  style="font-family:
                    var(--font-display, 'Outfit');"
                >
                  {project.name}
                </h3>
                <p
                  class="text-xs text-white/30
                    line-clamp-2 leading-relaxed"
                >
                  {project.items[0]}
                </p>
              </div>
              <!-- Arrow -->
              <div
                class="mt-4 flex items-center gap-1.5
                  text-[10px] font-bold text-[var(--primary-light)]/50
                  opacity-0 -translate-x-2
                  group-hover:opacity-100
                  group-hover:translate-x-0
                  transition-all duration-300"
              >
                VIEW PROJECT
                <svg
                  class="h-3 w-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <path d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- ═══ TESTIMONIALS ═══ -->
      <section class="reveal-stagger">
        <div class="mb-8">
          <h2
            class="text-2xl font-black text-white mb-1"
            style="font-family:
              var(--font-display, 'Outfit');"
          >
            What People Say
          </h2>
          <p class="text-white/30 text-sm font-medium">
            LinkedIn recommendations from colleagues
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-5"
        >
          {testimonials.map((t) => (
            <a
              href={t.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group p-6 rounded-2xl
                bg-white/[0.015] border border-white/5
                hover:border-[var(--primary-subtle)]
                hover:bg-white/[0.025]
                transition-all duration-300"
            >
              <!-- Quote -->
              <p
                class="text-sm text-white/40 leading-relaxed
                  mb-5 italic"
              >
                "{t.quote}"
              </p>
              <!-- Author -->
              <div class="flex items-center gap-3">
                <div
                  class="flex items-center justify-center
                    h-9 w-9 rounded-full
                    bg-gradient-to-br from-[var(--primary-subtle)]
                    to-[var(--primary-muted)]
                    text-xs font-bold text-white/60"
                >
                  {t.name
                    .split(' ')
                    .map((n: string) => n[0])
                    .join('')}
                </div>
                <div>
                  <div
                    class="text-sm font-semibold
                      text-white/70
                      group-hover:text-white
                      transition-colors"
                  >
                    {t.name}
                  </div>
                  <div class="text-[10px] text-white/25">
                    {t.role}
                    {t.company && ` @ ${t.company}`}
                    {' · '}{t.date}
                  </div>
                </div>
                <!-- LinkedIn icon -->
                <svg
                  class="ml-auto h-4 w-4 text-white/10
                    group-hover:text-[#0A66C2]
                    transition-colors"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0
                      -1.328-.027-3.037-1.852-3.037
