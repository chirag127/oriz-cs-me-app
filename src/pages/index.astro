---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<BaseLayout
	title="Chirag Singhal"
	description="Engineer building the chirag127 / oriz family — agent harnesses, Astro tooling, and personal-data infrastructure."
>
	<div class="page">
		<aside><Sidebar /></aside>
		<section class="hero">
			<h1>Chirag Singhal</h1>
			<p class="role">Engineer · Agent harnesses · Astro &amp; Firebase tooling</p>
			<p class="bio">
				Building the chirag127 / oriz family of sites and tools — small,
				static, parallel-by-default.
			</p>
		</section>
	</div>
</BaseLayout>

<style>
	.page {
		max-width: 70rem;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: 3rem;
	}
	@media (max-width: 720px) {
		.page {
			grid-template-columns: 1fr;
			gap: 2rem;
			padding: 2rem 1rem;
		}
	}
	.hero h1 {
		font-size: clamp(2rem, 4vw, 3.25rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		margin: 0 0 0.5rem;
	}
	.hero .role {
		color: var(--color-muted, #9b9ba3);
		margin: 0 0 1.5rem;
	}
	.hero .bio {
		max-width: 40rem;
		line-height: 1.6;
		margin: 0;
	}
</style>
