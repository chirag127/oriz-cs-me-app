---
import Layout from "../../layouts/Layout.astro";
import CommandPalette from "../../components/CommandPalette.astro";

const interests = [
    {
        category: "AI & Machine Learning",
        icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
        color: "amber",
        desc: "Building intelligent systems with LLMs, RAG pipelines, and autonomous agents. From NexusAI's multi-agent orchestration to Olivia's edge-first voice assistant — I'm obsessed with making AI actually useful, not just impressive demos.",
        tags: ["LangChain", "RAG", "Hugging Face", "Gemini"],
    },
    {
        category: "System Design",
        icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10",
        color: "violet",
        desc: "Distributed systems, microservices, event-driven architectures. StreamGuard handles 10k+ events/sec. OmniPublish unifies 17+ platforms. The art of building systems that scale gracefully while remaining maintainable is endlessly fascinating to me.",
        tags: ["Microservices", "Kafka", "Event-Driven", "HLD/LLD"],
    },
    {
        category: "Music",
        icon: "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3",
        color: "rose",
        desc: "Always listening. My Last.fm scrobbles tell the story — from late-night electronic coding sessions to afternoon lo-fi. Music is the background process that makes everything else better. Track what I'm listening to on Last.fm (username: lastfmwhy).",
        profile: { name: "Last.fm", href: "https://last.fm/user/lastfmwhy" },
    },
    {
        category: "Cinema",
        icon: "M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z",
        color: "amber",
        desc: "Tracking everything on Letterboxd and AniList. I appreciate storytelling in all its forms — from Nolan's time-bending narratives to Studio Ghibli's quiet beauty. Anime, films, series — if it tells a good story, I'm watching it.",
        profiles: [
            {
                name: "Letterboxd",
                href: "https://letterboxd.com/chirag127",
                color: "amber",
            },
            {
                name: "AniList",
                href: "https://anilist.co/user/chirag127",
                color: "sky",
            },
        ],
    },
    {
        category: "Reading",
        icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
        color: "emerald",
        desc: "Always have a book going. From technical papers and system design case studies to fiction that stretches the imagination. Reading is how you download decades of someone else's experience into your brain in a weekend.",
    },
    {
        category: "Chess",
        icon: "M6 3h12v2H6V3zm5.5 4C12.88 7 14 8.12 14 9.5c0 .48-.13.92-.35 1.3l.65.7h.7c.83 0 1.5.67 1.5 1.5v4c0 .83-.67 1.5-1.5 1.5h-9c-.83 0-1.5-.67-1.5-1.5v-4c0-.83.67-1.5 1.5-1.5h.7l.65-.7A2.49 2.49 0 017 9.5C7 8.12 8.12 7 9.5 7h2z",
        color: "sky",
        desc: "Playing on Lichess regularly. The intersection of pattern recognition, strategic thinking, and calculation appeals to my engineering brain. Every game is a system design problem — except your opponent is actively trying to break your architecture.",
        profile: { name: "Lichess", href: "https://lichess.org/@/chirag127" },
    },
    {
        category: "Security",
        icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
        color: "rose",
        desc: "Cryptography, OWASP, secure coding practices. Implemented 40+ hash algorithms and client-side encryption in Oriz. Kinde Auth with PKCE. reCAPTCHA v3. I believe security should be invisible to users but impenetrable to attackers.",
        tags: ["OWASP", "OAuth 2.0", "PKCE", "40+ Hash Algos"],
    },
    {
        category: "Cloud Native",
        icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
        color: "sky",
        desc: "Cloudflare Workers, serverless architectures, edge computing. Chirag Singhal runs on Cloudflare Pages for ₹0. Oriz's 8 serverless edge functions handle comments, payments, and file uploads. Building for the modern internet means building at the edge — close to the user, far from the bill.",
        tags: ["Cloudflare", "Serverless", "Docker", "Kubernetes"],
    },
];

const colorMap: Record<string, { bg: string; text: string; hover: string }> = {
    amber: {
        bg: "bg-amber-500/10",
        text: "text-amber-500",
        hover: "hover:text-amber-500",
    },
    violet: {
        bg: "bg-violet-500/10",
        text: "text-violet-400",
        hover: "hover:text-violet-400",
    },
    rose: {
        bg: "bg-rose-500/10",
        text: "text-rose-500",
        hover: "hover:text-rose-500",
    },
    sky: {
        bg: "bg-sky-500/10",
        text: "text-sky-500",
        hover: "hover:text-sky-500",
    },
    emerald: {
        bg: "bg-emerald-500/10",
        text: "text-emerald-400",
        hover: "hover:text-emerald-400",
    },
    teal: {
        bg: "bg-teal-500/10",
        text: "text-teal-400",
        hover: "hover:text-teal-400",
    },
};
---

<Layout
    title="Interests"
    description="The things that excite Chirag Singhal — AI, chess, cinema, music, and more"
>
    <CommandPalette />
    <main class="relative mx-auto max-w-[var(--content-max-width)] px-6 py-12">
        <div
            class="absolute top-0 right-0 w-96 h-96 bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"
        >
        </div>

        <!-- Page Header -->
        <div class="mb-10 relative">
            <a
                href="/me"
                class="inline-flex items-center gap-2 text-sm text-white/30 hover:text-white/50 mb-5 transition-colors group"
            >
                <svg
                    class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 19l-7-7 7-7"></path></svg
                >
                Back to Me
            </a>

            <div
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5"
            >
                <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"
                ></span>
                ME
            </div>
            <h1
                class="text-3xl sm:text-4xl font-black text-white mb-2"
                style="font-family: var(--font-display, 'Outfit');"
            >
                Interests
            </h1>
            <p class="text-base text-white/40 max-w-2xl">
                The things that keep me up at night — in the best way possible.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {
                interests.map((item) => {
                    const c = colorMap[item.color] ?? colorMap.amber!;
                    return (
                        <div class="glass-strong p-7 group">
                            <div class="flex items-center gap-3 mb-3">
                                <div
                                    class={`h-10 w-10 rounded-xl ${c.bg} flex items-center justify-center`}
                                >
                                    <svg
                                        class={`h-5 w-5 ${c.text}`}
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d={item.icon}
                                        />
                                    </svg>
                                </div>
                                <h2 class="text-base font-bold text-white">
                                    {item.category}
                                </h2>
                            </div>
                            <p class="text-sm text-white/50 leading-relaxed mb-3">
                                {item.desc}
                            </p>
                            {item.tags && (
                                <div class="flex flex-wrap gap-1.5">
                                    {item.tags.map((tag) => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                            )}
                            {item.profile && (
                                <a
                                    href={item.profile.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class={`inline-flex items-center gap-1 text-xs ${c.text}/70 ${c.text.replace("text-", "hover:text-")} transition-colors mt-1`}
                                >
                                    {item.profile.name} profile
                                    <svg
                                        class="h-3 w-3"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                        />
                                    </svg>
                                </a>
                            )}
                            {item.profiles && (
                                <div class="flex gap-3">
                                    {item.profiles.map((p) => {
                                        const pc =
                                            colorMap[p.color] || colorMap.amber!;
                                        return (
                                            <a
                                                href={p.href}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class={`inline-flex items-center gap-1 text-xs ${pc.text}/70 ${pc.hover} transition-colors`}
                                            >
                                                {p.name}
                                                <svg
                                                    class="h-3 w-3"
                                                    fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                                    />
                                                </svg>
                                            </a>
                                        );
                                    })}
                                </div>
                            )}
                        </div>
                    );
                })
            }
        </div>
    </main>
</Layout>
