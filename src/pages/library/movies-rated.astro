---
/**
 * Top Rated Movies — sorted by rating (movies only)
 */
import AgeGatedLayout from '../../layouts/AgeGatedLayout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let topRated: any[] = [];

try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/movies.json'),
    'utf-8',
  );
  const db = JSON.parse(raw);
  topRated = (db.watched || [])
    .filter((m: any) => m.rating)
    .sort(
      (a: any, b: any) =>
        (b.rating || 0) - (a.rating || 0),
    );
} catch {
  console.warn('[Movies] movies.json not found.');
}
const fallbackGradients = [
  'linear-gradient(135deg, #78350f, #92400e)',
  'linear-gradient(135deg, #1e3a8a, #1e40af)',
  'linear-gradient(135deg, #4c1d95, #5b21b6)',
  'linear-gradient(135deg, #064e3b, #065f46)',
  'linear-gradient(135deg, #831843, #9d174d)',
  'linear-gradient(135deg, #0f172a, #1e293b)',
];
const fallbackEmojis = ['🎬', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<AgeGatedLayout contentLabel="Films" declinePath="/library/"
  title="Top Rated Movies"
  description="Highest rated movies from my Trakt diary"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-12"
  >
    <!-- Breadcrumb -->
    <div class="flex items-center gap-1.5
      text-xs text-white/20 mb-8">
      <a
        href="/library"
        class="hover:text-white/40 transition-colors"
      >Library</a>
      <span>/</span>
      <a
        href="/library/movies"
        class="hover:text-white/40 transition-colors"
      >Movies</a>
      <span>/</span>
      <span class="text-white/40">Rankings</span>
    </div>

    <!-- Header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-xs font-medium text-amber-400 mb-4">
        RANKED
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
          <span class="text-xl">⭐</span>
        </div>
        <h1 class="text-4xl font-bold text-white uppercase tracking-tighter" style="font-family: 'Outfit', sans-serif;">Top Rated</h1>
      </div>
      <p class="text-white/40">{topRated.length} movies ranked by score.</p>
    </div>

    <!-- Grid Layout -->
    {topRated.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
        {topRated.map((movie, i) => {
          const vis = getVisuals(movie.title);
          return (
            <div class="glass rounded-2xl border border-white/5 hover:border-amber-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                
                {movie.posterUrl ? (
                  <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                    <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                  </div>
                )}

                <!-- Rating Badge -->
                <div class="absolute top-2 right-2 z-20 bg-amber-500/20 backdrop-blur-md rounded-full px-2 py-0.5 border border-amber-500/30">
                  <span class="text-[10px] font-black text-amber-400">{movie.rating}</span>
                </div>

                <!-- Rank Badge -->
                <div class="absolute bottom-2 left-2 z-20 text-[10px] font-mono text-white/30">
                  #{i + 1}
                </div>
              </div>

              <div class="px-3 pb-4">
                <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-amber-400 transition-colors">
                  {movie.title}
                </h3>
                <p class="text-[10px] text-white/30 truncate mt-0.5">
                  {movie.year} · {(movie.genres || [])[0]}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20 text-white/20 text-sm glass rounded-2xl border border-white/5">
        No rated movies found.
      </div>
    )}

    <!-- Trakt Profile Link -->
    <div class="mt-20 py-8 border-t border-white/5 text-center">
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-red-500/10 text-red-500 hover:text-red-400 hover:bg-red-500/20 font-bold text-xs uppercase tracking-widest transition-all">
        Full History on Trakt
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</AgeGatedLayout>
