---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db = { wantToRead: [] as any[] };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/books.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Books Want to Read] books.json not found.');
}

const wantToRead = db.wantToRead || [];

const fallbackGradients = [
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #92400e, #b45309)',
  'linear-gradient(135deg, #4a148c, #7b1fa2)',
  'linear-gradient(135deg, #1a237e, #283593)',
  'linear-gradient(135deg, #1a1a1a, #37474f)',
  'linear-gradient(135deg, #0c1445, #1565c0)',
];
const fallbackEmojis = ['📚', '📖', '📘', '📕', '📗', '📙', '🔖', '📓'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Want to Read" description="Books Chirag Singhal wants to read">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/books" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Books
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-xs font-medium text-amber-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-rose-500/10 flex items-center justify-center">
          <span class="text-xl">📋</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Want to Read</h1>
      </div>
      <p class="text-white/40">Reading queue - {wantToRead.length} books.</p>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-rose-400">{wantToRead.length}</div>
        <div class="text-xs text-white/30">Queued</div>
      </div>
    </div>

    {wantToRead.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
        {wantToRead.map((book: any, i: number) => {
          const vis = getVisuals(book.title);
          return (
            <div class="glass rounded-2xl border border-white/5 hover:border-rose-500/20 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-3xl relative overflow-hidden bg-white/[0.02]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                
                {book.coverUrl ? (
                  <img src={book.coverUrl} alt={book.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style={`background: ${vis.gradient}`}>
                    <span class="drop-shadow-lg opacity-40">{vis.emoji}</span>
                  </div>
                )}
              </div>

              <div class="px-3 pb-4">
                <h3 class="text-xs font-bold text-white/90 truncate group-hover:text-rose-400 transition-colors">
                  {book.title}
                </h3>
                <p class="text-[10px] text-white/30 truncate mt-0.5">
                  {(book.authors || [])[0]}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="glass p-12 text-center rounded-2xl border border-white/5"><p class="text-white/30">Reading queue is empty.</p></div>
    )}
  </main>
</Layout>
