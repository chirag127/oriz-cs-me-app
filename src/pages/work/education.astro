---
import { education, honors } from '../../content';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

const milestones = [
  { year: '2020', label: 'JEE Advanced', detail: 'AIR 11870 — Top 1% in India' },
  { year: '2020', label: 'CBSE Board', detail: '97% — School Topper (Rank 1)' },
  { year: '2024', label: 'B.Tech Graduation', detail: 'CGPA 8.81 — College Topper (Rank 1)' },
];
---

<Layout title="Education" description="Academic background of Chirag Singhal — AKTU B.Tech CSE, JEE Advanced Rank Holder">
  <CommandPalette />
  <main class="relative mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <div class="absolute top-0 right-0 w-96 h-96 bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-64 h-64 bg-violet-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Work</a>

    <!-- Page Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/5 border border-teal-500/15 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        EDUCATION
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">Education</h1>
      <p class="text-base text-white/40">Academic excellence and competitive exam achievements</p>
    </div>

    <!-- Key Milestones -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12 reveal-stagger">
      {milestones.map((m) => (
        <div class="glass p-5 text-center">
          <div class="text-xs text-teal-400 font-medium mb-1">{m.year}</div>
          <div class="text-base font-bold text-white">{m.label}</div>
          <div class="text-xs text-white/40 mt-1">{m.detail}</div>
        </div>
      ))}
    </div>

    <!-- Education Cards -->
    <div class="space-y-6 mb-12 reveal-stagger">
      {education.map((edu) => (
        <div class="glass p-8 hover:border-teal-500/15 transition-all duration-300 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-40 h-40 bg-violet-500/5 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="relative">
            <span class="text-sm text-violet-400 font-semibold">{edu.date}</span>
            <h2 class="text-xl font-bold text-white mt-1 mb-1" style="font-family: var(--font-display, 'Outfit');">{edu.degree}</h2>
            <p class="text-sm text-teal-400 font-medium mb-1">{edu.institution}</p>
            <p class="text-xs text-white/40 mb-5">{edu.location}</p>
            <ul class="space-y-3">
              {edu.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-white/60">
                  <svg class="h-4 w-4 text-teal-400/60 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Honors Section -->
    <div class="glass-strong p-8 reveal">
      <div class="flex items-center gap-3 mb-6">
        <svg class="h-5 w-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <h2 class="text-lg font-bold text-white">Honors & Awards</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {honors.map((honor) => (
          <div class="flex items-start gap-3 p-4 rounded-xl bg-white/[0.015] border border-white/5 hover:border-white/10 transition-colors">
            <div class="h-10 w-10 rounded-lg bg-amber-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
            </div>
            <div>
              <div class="text-sm font-medium text-white">{honor.title}</div>
              <div class="text-xs text-white/40">{honor.description}</div>
              <div class="text-[10px] text-white/25 mt-0.5">{honor.location} · {honor.year}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
