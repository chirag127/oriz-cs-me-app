---
/*
 * /connect — social profiles + contact form (v2 datasheet).
 */

import { socialLinks } from '../../content';
import Layout from '../../layouts/Layout.astro';

// Stable order: github → linkedin → twitter/x → bluesky → mastodon → reddit → hn → dev.to
const ORDER = [
  'github',
  'linkedin',
  'x',
  'twitter',
  'bluesky',
  'mastodon',
  'reddit',
  'hackernews',
  'dev.to',
  'devto',
  'youtube',
  'pixelfed',
];

const sortedSocials = [...socialLinks].sort((a, b) => {
  const ia = ORDER.indexOf(a.name.toLowerCase());
  const ib = ORDER.indexOf(b.name.toLowerCase());
  return (ia === -1 ? 999 : ia) - (ib === -1 ? 999 : ib);
});
---

<Layout
  title="Connect"
  description="Social profiles, contact, public conversation channels."
  breadcrumb="CONNECT"
  provenanceSection="/connect"
  provenanceApis="bluesky · mastodon · reddit · hackernews · authored"
>
  <div class="spine">
    <header class="page-head">
      <h1>Connect</h1>
      <p class="lede">
        Every public profile + the contact form. Most threads I post live on
        one of these — search there first, message here only if it&apos;s
        long-form.
      </p>
    </header>
    <div class="page-counts">
      {sortedSocials.length} profiles · contact form via firebase
    </div>

    <section class="band">
      <p class="eyebrow band-eyebrow">PROFILES</p>
      <table class="ranked-table">
        <thead>
          <tr>
            <th class="rank">#</th>
            <th>platform</th>
            <th>handle</th>
            <th class="right">link</th>
          </tr>
        </thead>
        <tbody>
          {sortedSocials.map((s, i) => {
            const rank = String(i + 1).padStart(2, '0');
            return (
              <tr>
                <td class="rank">{rank}</td>
                <td>{s.name}</td>
                <td>{s.username ?? '—'}</td>
                <td class="right">
                  <a href={s.url} target="_blank" rel="noopener noreferrer">
                    {s.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">SUB-PAGES</p>
      <div class="me-rows">
        <a class="leader-row me-link" href="/connect/contact/">
          <span class="leader-name">/connect/contact</span>
          <span class="leader-fill">contact form — emails forwarded to gmail</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/connect/bluesky/">
          <span class="leader-name">/connect/bluesky</span>
          <span class="leader-fill">recent posts (atproto)</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/connect/mastodon/">
          <span class="leader-name">/connect/mastodon</span>
          <span class="leader-fill">federated thread archive</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/connect/reddit/">
          <span class="leader-name">/connect/reddit</span>
          <span class="leader-fill">comments + submissions</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/connect/hackernews/">
          <span class="leader-name">/connect/hackernews</span>
          <span class="leader-fill">submissions + karma</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
      </div>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/me/">/me</a>
      <span aria-hidden="true">·</span>
      <a href="/work/">/work</a>
      <span aria-hidden="true">·</span>
      <a href="/code/">/code</a>
      <span aria-hidden="true">·</span>
      <a href="/library/">/library</a>
      <span aria-hidden="true">·</span>
      <a href="/gaming/">/gaming</a>
      <span aria-hidden="true">·</span>
      <a href="/system/">/system</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .me-rows { display: flex; flex-direction: column; }
  .me-link:hover .leader-name,
  .me-link:hover .leader-fill,
  .me-link:hover .leader-time { color: var(--archival); }
  .me-link:hover { background: var(--archival-wash); }
  .ranked-table a {
    color: var(--archival);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .ranked-table a:hover { text-decoration-color: var(--archival); }
</style>
