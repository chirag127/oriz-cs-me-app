---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<BaseLayout
	title="Uses — Chirag Singhal"
	description="Hardware and software I use day-to-day. A uses.tech-style page."
>
	<div class="page">
		<aside><Sidebar /></aside>
		<section>
			<h1>Uses</h1>
			<p>
				Hardware and software I use day-to-day —
				<a href="https://uses.tech" rel="noopener">uses.tech</a>-style.
			</p>
			<p><em>Stub. Coming soon.</em></p>
		</section>
	</div>
</BaseLayout>

<style>
	.page {
		max-width: 70rem;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: 3rem;
	}
	@media (max-width: 720px) {
		.page { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 1rem; }
	}
	h1 { font-size: 2rem; margin: 0 0 1rem; letter-spacing: -0.01em; }
</style>
