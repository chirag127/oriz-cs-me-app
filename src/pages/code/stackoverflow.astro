---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { stackoverflow: { user: null, tags: [] } };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/dev-stats.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[StackOverflow] dev-stats.json not found.');
}

const user = db.stackoverflow?.user;
const tags = db.stackoverflow?.tags || [];
---

<Layout title="StackOverflow" description="Chirag Singhal's StackOverflow profile — reputation, badges, and tags">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <!-- Header -->
    <div class="mb-10 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-[11px] font-semibold text-teal-400 uppercase tracking-wider mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CODE
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white mb-2" style="font-family: var(--font-display, 'Outfit');">StackOverflow</h1>
      <p class="text-base text-white/40">Developer reputation and community contributions.</p>
    </div>

    {user ? (
      <>
        <!-- Profile Hero -->
        <div class="glass-strong p-8 mb-8 reveal">
          <div class="flex items-center gap-4 mb-6">
            {user.profileImage && (
              <img src={user.profileImage} alt="Avatar" class="w-16 h-16 rounded-full ring-2 ring-orange-500/20" />
            )}
            <div>
              <h2 class="text-xl font-bold text-white">{user.displayName}</h2>
              <p class="text-sm text-white/40">Member since {new Date(user.creationDate * 1000).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
            </div>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
              <div class="text-2xl font-bold text-orange-400">{user.reputation?.toLocaleString()}</div>
              <div class="text-xs text-white/40">Reputation</div>
            </div>
            <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
              <div class="text-2xl font-bold text-yellow-400">{user.badgeCounts?.gold || 0}</div>
              <div class="text-xs text-white/40">Gold Badges</div>
            </div>
            <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
              <div class="text-2xl font-bold text-gray-300">{user.badgeCounts?.silver || 0}</div>
              <div class="text-xs text-white/40">Silver Badges</div>
            </div>
            <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
              <div class="text-2xl font-bold text-amber-600">{user.badgeCounts?.bronze || 0}</div>
              <div class="text-xs text-white/40">Bronze Badges</div>
            </div>
          </div>
        </div>

        <!-- Top Tags -->
        {tags.length > 0 && (
          <div class="glass p-8 mb-8 reveal">
            <h2 class="text-xl font-bold text-white mb-6">Top Tags</h2>
            <div class="flex flex-wrap gap-3">
              {tags.map((tag: any) => (
                <a
                  href={`https://stackoverflow.com/questions/tagged/${tag.name}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 rounded-lg bg-white/[0.02] border border-white/5 hover:border-orange-500/30 transition-colors"
                >
                  <span class="text-sm text-white font-medium">{tag.name}</span>
                  <span class="text-xs text-orange-400 ml-2">&times; {tag.count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-white/40">StackOverflow data not available. Run fetch-data first.</p>
      </div>
    )}

    <div class="glass p-6 text-center">
      <a href="https://stackoverflow.com/users/18901471/chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-orange-400 hover:underline">View on StackOverflow &rarr;</a>
    </div>
  </main>
</Layout>
