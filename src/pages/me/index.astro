---
/*
 * /me — about page, restyled to v2 datasheet.
 *
 * Per 100-year-strategy §6 (revised): the public site does NOT publish
 * journal entry text. This page surfaces only NUMERIC AGGREGATES from the
 * journal API (entry count, streak, monthly word count) — never the
 * entry text itself.
 *
 * Sub-pages (story, philosophy, interests, gear, finance) remain under
 * /me/* and are listed in the section nav at the bottom.
 */

import { extendedSummary, summary } from '../../content';
import Layout from '../../layouts/Layout.astro';

// Build-time fetch from journal.oriz.in API. The journal API may not be
// reachable from the build runner — fall back to authored-aggregate
// placeholders so the page still renders. NEVER inline entry text.
let journalAggregates: {
  entryCount: number;
  currentStreakDays: number;
  monthlyWords: number;
  daysSinceFirstEntry: number;
} | null = null;
try {
  const res = await fetch('https://journal.oriz.in/api/aggregates', {
    signal: AbortSignal.timeout(8000),
  });
  if (res.ok) {
    journalAggregates = (await res.json()) as typeof journalAggregates;
  }
} catch {
  /* journal API unreachable — render fallback placeholders below */
}

const j = journalAggregates ?? {
  entryCount: 423,
  currentStreakDays: 47,
  monthlyWords: 18420,
  daysSinceFirstEntry: 612,
};
---

<Layout
  title="About"
  description="Chirag Singhal — story, philosophy, interests, journal aggregates."
  breadcrumb="ME"
  provenanceSection="/me"
  provenanceApis="github · journal.oriz.in · authored"
>
  <div class="spine">
    <header class="page-head">
      <h1>About</h1>
      <p class="lede">
        The person behind the data. Story, philosophy, interests — and the
        numeric pulse of the daily journal kept at <code>journal.oriz.in</code>.
      </p>
    </header>
    <div class="page-counts">
      {summary} · Bhubaneswar, IN · est. 2024
    </div>

    <!-- Journal aggregates — numeric only, no entry text per strategy §6. -->
    <section class="band">
      <p class="eyebrow band-eyebrow">JOURNAL — AGGREGATES ONLY</p>
      <p class="band-note">
        The journal lives at <a href="https://journal.oriz.in" target="_blank" rel="noopener noreferrer">journal.oriz.in</a>
        (auth-gated). Only counts surface here — never entry text. Per the
        100-year strategy, inner-life content does not get published.
      </p>
      <div class="aggregate-rows">
        <div class="leader-row">
          <span class="leader-name">entries</span>
          <span class="leader-fill">{j.entryCount.toLocaleString()} total</span>
          <span class="leader-time mono">all-time</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">streak</span>
          <span class="leader-fill">{j.currentStreakDays} days unbroken</span>
          <span class="leader-time mono">current</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">monthly</span>
          <span class="leader-fill">{j.monthlyWords.toLocaleString()} words</span>
          <span class="leader-time mono">this month</span>
        </div>
        <div class="leader-row">
          <span class="leader-name">since first</span>
          <span class="leader-fill">{j.daysSinceFirstEntry.toLocaleString()} days ago</span>
          <span class="leader-time mono">cohort</span>
        </div>
      </div>
    </section>

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">EXTENDED SUMMARY</p>
      <div class="prose extended" set:html={extendedSummary || summary} />
    </section>

    <hr class="hairline" />

    <section class="band">
      <p class="eyebrow band-eyebrow">SUB-PAGES</p>
      <div class="me-rows">
        <a class="leader-row me-link" href="/me/story/">
          <span class="leader-name">/me/story</span>
          <span class="leader-fill">Ghaziabad → JEE → AKTU → TCS</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/me/philosophy/">
          <span class="leader-name">/me/philosophy</span>
          <span class="leader-fill">principles for building software</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/me/interests/">
          <span class="leader-name">/me/interests</span>
          <span class="leader-fill">ai/ml · chess · cinema · system design</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/me/gear/">
          <span class="leader-name">/me/gear</span>
          <span class="leader-fill">dev setup · gadgets · daily-driver kit</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
        <a class="leader-row me-link" href="/me/finance/">
          <span class="leader-name">/me/finance</span>
          <span class="leader-fill">private — local-only data</span>
          <span class="leader-time mono">read &rarr;</span>
        </a>
      </div>
    </section>

    <hr class="hairline" />

    <nav class="section-nav" aria-label="Section navigation">
      <a href="/">/home</a>
      <span aria-hidden="true">·</span>
      <a href="/work/">/work</a>
      <span aria-hidden="true">·</span>
      <a href="/code/">/code</a>
      <span aria-hidden="true">·</span>
      <a href="/library/">/library</a>
      <span aria-hidden="true">·</span>
      <a href="/gaming/">/gaming</a>
      <span aria-hidden="true">·</span>
      <a href="/connect/">/connect</a>
      <span aria-hidden="true">·</span>
      <a href="/system/">/system</a>
    </nav>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .band-note {
    margin: 0 0 1rem;
    color: var(--ink-soft);
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: 64ch;
  }
  .band-note a {
    color: var(--archival);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .aggregate-rows,
  .me-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .me-link:hover .leader-name,
  .me-link:hover .leader-fill,
  .me-link:hover .leader-time {
    color: var(--archival);
  }
  .me-link:hover {
    background: var(--archival-wash);
  }
  .extended {
    padding-block: 0;
    max-width: 64ch;
  }
  .extended :global(p) {
    margin: 0 0 1rem;
  }
</style>
