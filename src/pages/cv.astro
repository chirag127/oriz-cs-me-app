---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<BaseLayout
	title="CV — Chirag Singhal"
	description="Curriculum vitae for Chirag Singhal."
>
	<div class="page">
		<aside><Sidebar /></aside>
		<section>
			<h1>CV</h1>
			<p><em>Stub. Coming soon.</em></p>
		</section>
	</div>
</BaseLayout>

<style>
	.page {
		max-width: 70rem;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: 3rem;
	}
	@media (max-width: 720px) {
		.page { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 1rem; }
	}
	h1 { font-size: 2rem; margin: 0 0 1rem; letter-spacing: -0.01em; }
</style>
