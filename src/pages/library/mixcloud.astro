---
import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { mixcloud: { user: null, cloudcasts: [] } };
try {
  const raw = await fs.readFile(
    path.resolve('./src/content/generated/music-platforms.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Mixcloud] music-platforms.json not found.');
}

const user = db.mixcloud?.user;
const cloudcasts = db.mixcloud?.cloudcasts || [];
---

<Layout title="Mixcloud" description="Chirag Singhal on Mixcloud - DJ mixes and radio shows">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-indigo-500/10 flex items-center justify-center">
          <span class="text-xl">🎧</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Mixcloud</h1>
      </div>
      <p class="text-white/40">DJ mixes and radio shows - from {CONFIG.user.mixcloud}.</p>
    </div>

    {user && (
      <div class="glass-strong p-8 mb-12 rounded-2xl border border-white/10">
        <div class="flex items-center gap-4 mb-4">
          {user.pictures?.medium && <img src={user.pictures.medium} alt="Avatar" class="w-16 h-16 rounded-full" />}
          <div>
            <h2 class="text-xl font-bold text-white">{user.name || CONFIG.user.mixcloud}</h2>
            <p class="text-sm text-white/30">@{CONFIG.user.mixcloud}</p>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center p-3 rounded-xl bg-white/[0.02]">
            <div class="text-lg font-bold text-indigo-400">{user.cloudcastCount}</div>
            <div class="text-xs text-white/30">Mixes</div>
          </div>
          <div class="text-center p-3 rounded-xl bg-white/[0.02]">
            <div class="text-lg font-bold text-white">{user.followerCount}</div>
            <div class="text-xs text-white/30">Followers</div>
          </div>
          <div class="text-center p-3 rounded-xl bg-white/[0.02]">
            <div class="text-lg font-bold text-white">{user.listenCount?.toLocaleString()}</div>
            <div class="text-xs text-white/30">Listens</div>
          </div>
        </div>
      </div>
    )}

    <h2 class="text-xl font-semibold text-white mb-6 relative inline-block">
      Mixes
      <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-indigo-400 to-transparent rounded-full"></span>
    </h2>
    {cloudcasts.length > 0 ? (
      <div class="space-y-4">
        {cloudcasts.map((cast: any) => (
          <div class="glass p-5 rounded-2xl border border-white/5">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-white truncate">{cast.name}</h3>
                {cast.description && <p class="text-xs text-white/30 mt-1 line-clamp-2">{cast.description}</p>}
              </div>
              <a href={cast.url} target="_blank" rel="noopener noreferrer" class="shrink-0 text-indigo-400 text-xs hover:underline">Play</a>
            </div>
            <div class="flex items-center gap-4 text-xs text-white/30">
              {cast.playCount > 0 && <span>▶ {cast.playCount}</span>}
              {cast.favoriteCount > 0 && <span>❤ {cast.favoriteCount}</span>}
              {cast.duration > 0 && <span>⏱ {Math.floor(cast.duration / 60)}m</span>}
            </div>
            {cast.embedUrl && (
              <div class="mt-3">
                <iframe
                  width="100%"
                  height="60"
                  src={cast.embedUrl}
                  frameborder="0"
                  loading="lazy"
                  class="rounded-lg"
                ></iframe>
              </div>
            )}
            {cast.tags?.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-2">
                {cast.tags.slice(0, 5).map((tag: string) => (
                  <span class="text-[0.55rem] px-1.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400/70">{tag}</span>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center rounded-2xl border border-white/5">
        <p class="text-white/30">No mixes found. Run fetch-data first.</p>
      </div>
    )}

    <div class="mt-12 glass p-6 text-center rounded-2xl border border-white/5">
      <a href={`https://www.mixcloud.com/${CONFIG.user.mixcloud}`} target="_blank" rel="noopener noreferrer" class="text-sm text-indigo-400 hover:underline">View on Mixcloud →</a>
    </div>
  </main>
</Layout>
