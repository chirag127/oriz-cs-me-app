---
/*
 * ProvenanceStrip — the v2 signature element.
 *
 * Renders below the header on every page. A single line of mono text:
 *
 *   ── synced 2026-06-19T03:07Z · 41 sources · 12,847 records ──
 *
 * with a 4px pulsing archival-blue circle to the LEFT of the timestamp
 * (1.5s ease-in-out infinite — the only animation on the entire site).
 * Box-drawing em-dashes (U+2500), middle dots (U+00B7).
 *
 * Timestamp is rendered AT BUILD TIME from `import.meta.env.PUBLIC_DEPLOY_TIME`,
 * falling back to `new Date().toISOString()` when env is absent.
 *
 * Per-section narrowing: pass `apis` to override the "41 sources" tail with
 * a comma-separated API list (e.g. on /library: "letterboxd + anilist + last.fm").
 */

interface Props {
  /** Optional section pin shown after `synced ...`. e.g. '/library'. */
  section?: string;
  /** Override the right-half list of sources fed into THIS page. */
  apis?: string;
  /** Override the record count. Defaults to a brief-aligned placeholder. */
  records?: number | string;
  /** Override the source count. Defaults to a brief-aligned placeholder. */
  sources?: number | string;
}

const { section, apis, records = '12,847', sources = 41 } = Astro.props;

// Build-time timestamp resolution. Inject via env in the matrix-deploy
// workflow, fall back to the moment the build ran on local dev.
const deployTimeRaw =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString();

// Coerce to ISO without milliseconds — `2026-06-19T03:07Z` shape.
function toCompactIso(input: string): string {
  // Already ISO with seconds + Z?
  const date = new Date(input);
  if (Number.isNaN(date.getTime())) return input;
  // YYYY-MM-DDTHH:MMZ
  const iso = date.toISOString();
  return `${iso.slice(0, 16)}Z`;
}

const builtAt = toCompactIso(deployTimeRaw);

// Right-half text. If `apis` is supplied, it replaces the "N sources · N records"
// pair so the strip narrows to the APIs that actually fed this page.
const tail = apis ? apis : `${sources} sources · ${records} records`;
---

<div class="provenance-strip" role="contentinfo">
  <span class="provenance-line mono" aria-label={`Synced ${builtAt}, ${tail}`}>
    <span class="dash" aria-hidden="true">──</span>
    <span class="sync-dot" aria-hidden="true"></span>
    <span class="label">synced</span>
    <time datetime={deployTimeRaw}>{builtAt}</time>
    {section && (
      <>
        <span class="dot" aria-hidden="true">·</span>
        <span class="section-pin">{section}</span>
      </>
    )}
    <span class="dot" aria-hidden="true">·</span>
    <span class="tail">{tail}</span>
    <span class="dash" aria-hidden="true">──</span>
  </span>
</div>

<style>
  .provenance-strip {
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  }
  .provenance-line {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0 0.55ch;
    max-width: var(--container-spine);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
    padding-block: 0.55rem;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
    font-feature-settings: "tnum" 1, "zero" 1, "calt" 0;
  }
  .dash {
    color: var(--rule);
    letter-spacing: 0;
  }
  .sync-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--archival);
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--archival) 30%, transparent);
    animation: sync-pulse 1.5s ease-in-out infinite;
    margin-inline: 0.45ch;
  }
  .label {
    color: var(--ink-soft);
  }
  time {
    color: var(--ink);
  }
  .dot {
    color: var(--ink-soft);
  }
  .section-pin {
    color: var(--archival);
  }
  .tail {
    color: var(--ink-soft);
  }

  @keyframes sync-pulse {
    0%, 100% {
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--archival) 30%, transparent);
      opacity: 1;
    }
    50% {
      box-shadow: 0 0 0 4px color-mix(in oklab, var(--archival) 12%, transparent);
      opacity: 0.6;
    }
  }

  /* Reduced motion — keep the dot solid (the brief explicitly says so). */
  @media (prefers-reduced-motion: reduce) {
    .sync-dot {
      animation: none;
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--archival) 30%, transparent);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .provenance-line {
      font-size: 11px;
      padding-block: 0.5rem;
    }
    /* Per the brief: mobile truncates to `synced 03:07Z · 41 sources`,
       record count moves to a long-press tooltip. We hide the tail's
       record portion via overflow on the line and rely on aria-label. */
    .dash {
      display: none;
    }
  }
</style>
