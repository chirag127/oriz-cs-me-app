# Cloudflare
.wrangler/

# Generated API data — committed weekly by snapshot-weekly.yml so the Astro
# SSG site has authoritative data baked into the build. Firestore is the
# canonical store between snapshots; these files are a weekly mirror.
# (Do NOT re-add to .gitignore — that turns the weekly commit into a no-op.)
*.log

# TypeScript incremental build cache
*.tsbuildinfo

# Local scratch / one-off diagnostic dumps (do not commit)
*_error*.txt
*_errors*.txt
dns_*.json
search_results.md
setup-domains.log
missing_*.txt

# Test output
test-results/
playwright-report/
