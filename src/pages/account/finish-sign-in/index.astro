---
import FinishSignIn from '../../../components/FinishSignIn.tsx';
/*
 * /account/finish-sign-in — Email-link sign-in callback target.
 *
 * Firebase sends the email-link click here; the FinishSignIn island reads
 * the URL fragment + window.localStorage email and completes the auth.
 * Mirrors oriz-home/src/pages/account/finish-sign-in/index.astro.
 */
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Finishing sign-in"
  description="Completing your email-link sign-in."
  breadcrumb="ACCOUNT · FINISH"
  provenanceSection="/account"
>
  <div class="spine">
    <header class="page-head">
      <h1>Finishing sign-in</h1>
      <p class="lede">
        One moment — Firebase is verifying your email link.
      </p>
    </header>

    <section class="band">
      <FinishSignIn
        client:only="react"
        successPath="/account/"
      />
    </section>
  </div>
</Layout>

<style>
  .band { padding-block: clamp(1.5rem, 4vw, 2.5rem); }
</style>
